---
export interface Props {
  position?: 'bottom-right' | 'bottom-left';
  title?: string;
}

const { position = 'bottom-right', title = 'Seekingtex Fabric Advisor AI' } = Astro.props;
---

<div
  id="ai-chat"
  class="fixed z-50 flex flex-col"
  class:list={[position === 'bottom-right' ? 'bottom-4 right-4' : 'bottom-4 left-4']}
  data-chat
>
  <!-- Toggle Button -->
  <button
    id="ai-chat-toggle"
    class="flex items-center justify-center w-14 h-14 rounded-full bg-blue-600 text-white shadow-lg hover:bg-blue-700 hover:scale-105 transition-transform"
    aria-label="Open AI chat"
    type="button"
  >
    <svg
      class="w-7 h-7"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M12 8V4m0 0L9 7m3-3l3 3M4 16h16M4 16l2 4h12l2-4M4 16l-2-4h20l-2 4"></path>
    </svg>
  </button>

  <!-- Chat Panel -->
  <div
    id="ai-chat-panel"
    class="hidden flex-col bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-2xl w-80 max-w-[calc(100vw-2rem)] overflow-hidden"
    role="dialog"
    aria-label={title}
  >
    <!-- Header -->
    <div class="flex items-center px-4 py-3 gap-3 bg-blue-600 text-white">
      <div class="flex items-center justify-center w-10 h-10 rounded-full bg-white/20 shrink-0">
        <svg
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 8V4m0 0L9 7m3-3l3 3M4 16h16M4 16l2 4h12l2-4M4 16l-2-4h20l-2 4"></path>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="font-semibold text-sm">{title}</div>
        <div class="text-xs text-white/80">
          Tell me your location, experience & purpose — I will suggest gear, safety & learning
        </div>
      </div>
      <button id="ai-chat-close" class="text-white/80 hover:text-white" type="button" aria-label="Close">
        <svg
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Hint Chips -->
    <div id="ai-chat-hints" class="px-3 pt-3 flex flex-wrap gap-1.5">
      <button
        type="button"
        class="text-xs px-2.5 py-1 rounded-full bg-sky-50 text-sky-700 border border-sky-200 hover:bg-sky-100 transition-colors"
        data-hint="I need a lightweight breathable fabric for yoga and fitness apparel.">Sportswear fabric</button
      >
      <button
        type="button"
        class="text-xs px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100 transition-colors"
        data-hint="I need waterproof fabric for outdoor jackets and adventure gear.">Waterproof fabric</button
      >
      <button
        type="button"
        class="text-xs px-2.5 py-1 rounded-full bg-amber-50 text-amber-700 border border-amber-200 hover:bg-amber-100 transition-colors"
        data-hint="What certifications do your antibacterial fabrics have?">Fabric certifications</button
      >
      <button
        type="button"
        class="text-xs px-2.5 py-1 rounded-full bg-purple-50 text-purple-700 border border-purple-200 hover:bg-purple-100 transition-colors"
        data-hint="Compare recycled polyester vs organic cotton for sustainable apparel.">Compare eco fabrics</button
      >
    </div>

    <!-- Messages -->
    <div id="ai-chat-messages" class="flex-1 overflow-y-auto max-h-72 p-4 space-y-3 min-h-[180px]">
      <div class="bg-gray-100 dark:bg-gray-900 text-gray-700 dark:text-gray-300 p-3 rounded-lg text-sm">
        Tell me where you paddle, your experience level, and what you want to do — I will recommend gear, safety tips,
        and learning resources.
      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-gray-200 dark:border-gray-800 p-3">
      <form id="ai-chat-form" class="flex gap-2">
        <input
          id="ai-chat-input"
          type="text"
          placeholder="Type your question..."
          class="flex-1 px-3 py-2 text-sm border border-gray-300 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button
          type="submit"
          class="px-3 py-2 text-sm font-medium rounded-lg bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
          id="ai-chat-send"
        >
          <svg
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const toggle = document.getElementById('ai-chat-toggle');
    const panel = document.getElementById('ai-chat-panel');
    const close = document.getElementById('ai-chat-close');
    const form = document.getElementById('ai-chat-form');
    const input = document.getElementById('ai-chat-input');
    const messages = document.getElementById('ai-chat-messages');
    const sendBtn = document.getElementById('ai-chat-send');

    if (!toggle || !panel || !close || !form || !input || !messages || !sendBtn) return;

    // Hint chips
    const hints = document.getElementById('ai-chat-hints');
    if (hints) {
      hints.addEventListener('click', function (e) {
        const target = e.target;
        if (target.tagName === 'BUTTON' && target.getAttribute('data-hint')) {
          input.value = target.getAttribute('data-hint');
          form.dispatchEvent(new Event('submit'));
        }
      });
    }

    function open() {
      panel.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      setTimeout(function () {
        input.focus();
      }, 100);
    }
    function closePanel() {
      panel.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', function () {
      if (panel.classList.contains('hidden')) {
        open();
      } else {
        closePanel();
      }
    });
    close.addEventListener('click', closePanel);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) closePanel();
    });

    function addMessage(text, isUser) {
      const div = document.createElement('div');
      div.className = isUser
        ? 'bg-blue-600 text-white p-3 rounded-lg text-sm ml-8'
        : 'bg-gray-100 dark:bg-gray-900 text-gray-700 dark:text-gray-300 p-3 rounded-lg text-sm mr-8';
      div.textContent = text;
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function addTyping() {
      const div = document.createElement('div');
      div.id = 'ai-typing';
      div.className = 'bg-gray-100 dark:bg-gray-900 text-gray-500 p-3 rounded-lg text-sm mr-8';
      div.textContent = 'Thinking...';
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function removeTyping() {
      const el = document.getElementById('ai-typing');
      if (el) el.remove();
    }

    function addSources(sources) {
      if (!sources || sources.length === 0) return;
      const div = document.createElement('div');
      div.className = 'text-xs text-gray-400 mt-1 px-1';
      div.textContent =
        'Sources: ' +
        sources
          .map(function (s) {
            return s.title;
          })
          .join(', ');
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const question = input.value.trim();
      if (!question) return;

      addMessage(question, true);
      input.value = '';
      sendBtn.disabled = true;

      addTyping();

      try {
        const res = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: question }),
        });
        const data = await res.json();
        removeTyping();

        if (res.ok && data.answer) {
          addMessage(data.answer, false);
          addSources(data.sources);
        } else {
          addMessage("Sorry, I couldn't process that request.", false);
        }
      } catch {
        removeTyping();
        addMessage('Network error. Please try again.', false);
      } finally {
        sendBtn.disabled = false;
      }
    });
  })();
</script>
