---
export interface RelatedLink {
  title: string;
  description: string;
  href: string;
  icon?: string;
  label?: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  links: RelatedLink[];
}

const { title, subtitle, links } = Astro.props;
---

<section class="bg-gray-50 py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-semibold text-gray-900">{title}</h2>
      {subtitle && <p class="mt-2 text-gray-500">{subtitle}</p>}
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="group block bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-lg transition-shadow"
          >
            {link.label && (
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-sky-100 text-sky-700 mb-3">
                {link.label}
              </span>
            )}
            <h3 class="font-semibold text-gray-900 group-hover:text-sky-600 transition-colors">{link.title}</h3>
            <p class="mt-2 text-sm text-gray-500 line-clamp-2">{link.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
