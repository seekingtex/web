---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(6 182 212);
    --aw-color-secondary: rgb(14 116 144);
    --aw-color-accent: rgb(34 211 238);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(100 116 139 / 80%);
    --aw-color-bg-page: rgb(248 250 252);

    --aw-color-bg-page-dark: rgb(8 12 30);

    ::selection {
      background-color: rgb(6 182 212 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 211 238);
    --aw-color-secondary: rgb(6 182 212);
    --aw-color-accent: rgb(103 232 249);

    --aw-color-text-heading: rgb(240 242 245);
    --aw-color-text-default: rgb(220 224 230);
    --aw-color-text-muted: rgb(180 185 195 / 72%);
    --aw-color-bg-page: rgb(8 12 30);

    ::selection {
      background-color: rgb(34 211 238 / 30%);
    }
  }
</style>
