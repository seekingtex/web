---
export interface Props {
  datePublished?: string;
  dateUpdated?: string;
  author?: string;
  reviewer?: string;
  department?: string;
}

const {
  datePublished,
  dateUpdated = '2026',
  author = 'Seekingtex Textile Team',
  reviewer = 'Marine Engineering Department',
  department = 'Quality & Engineering',
} = Astro.props;
---

<section class="not-prose mt-10 mb-8 p-5 rounded-xl border border-sky-200 bg-gradient-to-br from-sky-50 to-blue-50 dark:from-sky-950/30 dark:to-blue-950/20 dark:border-sky-800">
  <div class="flex items-start gap-4">
    <div class="w-10 h-10 rounded-full bg-sky-100 dark:bg-sky-900/50 flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    <div class="text-sm text-gray-600 dark:text-slate-400">
      <p class="font-semibold text-gray-900 dark:text-slate-100">Expert Review</p>
      <p class="mt-1">
        Written by <span class="font-medium text-gray-800 dark:text-slate-200">{author}</span>
        {datePublished && <span> &middot; Published {datePublished}</span>}
        {dateUpdated && <span> &middot; Updated {dateUpdated}</span>}
      </p>
      <p>
        Reviewed by <span class="font-medium text-gray-800 dark:text-slate-200">{reviewer}</span>
        {department && <span> &middot; {department}</span>}
      </p>
    </div>
  </div>
</section>
