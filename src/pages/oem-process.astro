---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `OEM/ODM Manufacturing Process — From Inquiry to Production | ${SITE.name}`,
  description: `Complete OEM/ODM manufacturing process with ${SITE.name}. Step-by-step: inquiry, specification, sample development, OEKO-TEX compliance, bulk production, and FOB shipping. 12,000 m² ISO factory.`,
  ignoreTitleTemplate: true,
};

const steps = [
  {
    number: '01',
    title: 'Inquiry & Requirement Analysis',
    desc: 'Submit your product requirements, target specs, or reference fabric. Our OEM team reviews MOQ feasibility, material options, compliance needs (OEKO-TEX, REACH), and provides a preliminary quotation within 24 hours.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  },
  {
    number: '02',
    title: 'Engineering Review & NDA',
    desc: 'Our engineering team reviews your specifications — yarn type, weave construction, weight, width, finish requirements, and performance targets. We sign NDA and begin detailed technical proposal.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    number: '03',
    title: 'Sample Development & Lab Dip',
    desc: 'In-house textile lab develops sample yardage with your specified weave, finish, and color. Lab dips produced within 7–10 working days for color approval. Pre-production samples for performance validation.',
    icon: 'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2-1v2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5',
  },
  {
    number: '04',
    title: 'Compliance Documentation',
    desc: 'Complete compliance package: OEKO-TEX Standard 100 certificate, ISO 9001 traceability records, REACH chemical declarations, and any additional testing reports required for your market.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    number: '05',
    title: 'Bulk Production & QC',
    desc: 'Production runs follow our 100-point quality checklist. Continuous inline inspection for weight, width, and defects. Lab samples tested for tensile, colorfastness, hydrostatic head, and shrinkage.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  },
  {
    number: '06',
    title: 'Packaging & Labeling',
    desc: 'Custom packaging service: roll wrapping with PE film, branded labels and hang tags, spec sheet insertion, barcode/UPC labeling, and packing in woven bags or cartons.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    number: '07',
    title: 'Final Inspection & Sample Retention',
    desc: 'Final inspection per ASTM D5430 grading standards. Sample swatches are retained from every roll for traceability and future reference. Test reports generated for each batch.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    number: '08',
    title: 'FOB Shanghai Logistics',
    desc: 'Finished rolls palletized, wrapped, and container-loaded at Shanghai port. Complete export documentation: commercial invoice, packing list, bill of lading, certificate of origin, and compliance certificates. Real-time tracking provided.',
    icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<Layout metadata={metadata}>
  <JsonLd
    type="Article"
    article={{
      headline: 'OEM/ODM Manufacturing Process — From Inquiry to Production',
      description: 'Complete step-by-step OEM/ODM manufacturing process for functional fabrics. From inquiry to FOB shipping.',
      datePublished: '2026-07-07',
    }}
    data={{ url: 'https://seekingtex.com/oem-process' }}
  />
  <JsonLd type="BreadcrumbList" breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'OEM/ODM', href: '/oem-odm-manufacturer' }, { name: 'Manufacturing Process' }]} />

  <section class="bg-gradient-to-br from-[#001830] via-[#002d4a] to-[#003355] text-white py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-xs font-medium uppercase tracking-[0.2em] text-sky-300">OEM/ODM Process</span>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">From Inquiry to Production</h1>
      <p class="mt-4 text-lg text-white/70">End-to-end manufacturing process for functional fabrics. OEKO-TEX certified, FOB Shanghai.</p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="/oem-odm-manufacturer" class="px-8 py-4 bg-white text-gray-900 rounded-full font-semibold hover:bg-gray-50 transition">&larr; OEM/ODM Overview</a>
        <a href="/contact" class="px-8 py-4 border border-white/30 text-white rounded-full font-medium hover:bg-white/10 transition">Start Your Project</a>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto py-24 px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-semibold text-gray-900">The 8-Step OEM Process</h2>
      <p class="mt-4 text-lg text-gray-500">From initial inquiry to finished fabric at your warehouse — here is exactly how we work.</p>
    </div>
    <div class="space-y-8">
      {steps.map((s) => (
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-sky-100 flex items-center justify-center">
            <span class="text-2xl font-bold text-sky-600">{s.number}</span>
          </div>
          <div class="flex-1 bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-5 h-5 text-sky-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={s.icon} /></svg>
              <h3 class="text-lg font-semibold text-gray-900">{s.title}</h3>
            </div>
            <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gray-50 py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-semibold text-gray-900">Ready to Start Your OEM Project?</h2>
      <p class="mt-4 text-lg text-gray-500">Submit your requirements. We will reply with a detailed quotation and lead time within 24 hours.</p>
      <div class="mt-10 flex justify-center gap-4">
        <a href="/contact" class="px-10 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">Contact OEM Team</a>
        <a href="/oem-odm-manufacturer" class="px-10 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition">View Capabilities</a>
      </div>
      <p class="mt-8 text-sm text-gray-400">MOQ 500 yards per SKU. FOB Shanghai.</p>
    </div>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>Seekingtex OEM/ODM manufacturing process in 8 steps: 1) Inquiry and requirement analysis with 24-hour quotation, 2) Engineering review under NDA, 3) Sample development and lab dip within 7-10 working days, 4) OEKO-TEX/REACH compliance documentation, 5) Bulk production with 100-point QC checklist and lab testing, 6) Custom packaging and labeling, 7) Final inspection per ASTM D5430 with sample retention, 8) FOB Shanghai logistics with full export documentation. 12,000 m² ISO factory. MOQ 500 yards per SKU.</p>
  </section>
</Layout>
