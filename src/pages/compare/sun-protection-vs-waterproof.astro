---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';

const metadata = {
  title: 'Sun Protection vs Waterproof Fabric — Which Do You Need?',
  description:
    'Compare UPF 50+ sun protection fabrics and waterproof breathable fabrics across performance, applications, breathability, durability, and cost.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <JsonLd
    type="Article"
    article={{
      headline: 'Sun Protection vs Waterproof Fabric — Which Do You Need?',
      description:
        'Compare UPF 50+ sun protection fabrics and waterproof breathable fabrics across performance, applications, breathability, durability, and cost.',
      datePublished: '2026-07-06',
    }}
    data={{ url: 'https://seekingtex.com/compare/sun-protection-vs-waterproof' }}
  />
  <JsonLd
    type="BreadcrumbList"
    breadcrumbs={[
      { name: 'Home', href: '/' },
      { name: 'Compare', href: '/compare' },
      { name: 'Sun Protection vs Waterproof' },
    ]}
  />
  <section class="max-w-4xl mx-auto py-24 px-6">
    <a href="/products" class="text-sm text-sky-600 hover:text-sky-700">&larr; Products</a>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">Sun Protection vs Waterproof Fabric</h1>
    <p class="mt-4 text-lg text-gray-500">
      A practical comparison to help you choose the right functional fabric for your product's end-use environment.
    </p>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">UPF 50+ Sun Protection Fabric</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>Protection:</strong> Blocks 98%+ of UVA and UVB radiation. Fiber-level UV stabilizers provide permanent
              protection.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>Breathability:</strong> Naturally breathable — no membrane needed. Ideal for hot-weather and high-activity
              use.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>Versatility:</strong> Available in knits and wovens for sportswear, casual wear, children's wear, and
              outdoor apparel.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>Weight:</strong> Lightweight (80-200 gsm). Comfortable for all-day wear in warm conditions.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>Best for:</strong> Summer shirts, children's wear, sportswear, hats, travel apparel, and everyday sun
              protection.</span>
          </li>
        </ul>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">Waterproof Breathable Fabric</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>Protection:</strong> Hydrostatic head 5000-30000mm. Membrane blocks liquid water while allowing vapor
              escape.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>Breathability:</strong> MVTR 5000-30000+ g/m²/24hr. Depends on membrane type and laminate configuration.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>Construction:</strong> 2-layer, 2.5-layer, or 3-layer laminate. Requires careful care to maintain membrane
              integrity.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>Weight:</strong> Moderate to heavy (120-300+ gsm). Membrane and lamination add weight.</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>Best for:</strong> Rain jackets, ski wear, outdoor shells, tactical gear, workwear, and wet-weather
              protection.</span>
          </li>
        </ul>
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Quick Decision Guide</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b-2 border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">Factor</th>
              <th class="px-4 py-3 text-center font-semibold text-sky-700">Sun Protection</th>
              <th class="px-4 py-3 text-center font-semibold text-emerald-700">Waterproof</th>
            </tr>
          </thead>
          <tbody>
            {
              [
                ['Primary Function', 'UV radiation blocking', 'Liquid water barrier'],
                ['Breathability', 'Excellent (natural)', 'Good to excellent (membrane dependent)'],
                ['Weight', 'Light (80-200 gsm)', 'Moderate to heavy (120-300+ gsm)'],
                ['Durability', 'UPF is permanent, fabric durable', 'Membrane may delaminate over time'],
                ['Cost', 'Moderate', 'Higher (membrane + lamination)'],
                ['Care', 'Standard washing', 'Requires technical care'],
                ['Climate', 'Hot, sunny, UV-intense', 'Rainy, snowy, wet environments'],
                ['Layering', 'Single layer or base layer', 'Outer shell only'],
                ['UPF Protection', 'UPF 50+ (fiber-level)', 'Often UPF 50+ automatically (dense construction)'],
                ['Stretch Available', 'Yes (knit/stretch woven)', 'Limited (laminated structures)'],
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  {row.map((cell, j) => (
                    <td
                      class={`px-4 py-3 border-b border-gray-200 ${j === 0 ? 'font-medium text-gray-700' : 'text-center text-gray-600'}`}
                    >
                      {cell}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-16 bg-gradient-to-br from-sky-50 to-blue-50 rounded-2xl p-8 border border-sky-200">
      <h2 class="text-xl font-semibold text-gray-900">Which Should You Choose?</h2>
      <p class="mt-4 text-gray-600 text-sm leading-relaxed">
        Choose <strong>sun protection fabric</strong> if your product is for everyday wear in sunny conditions — summer shirts,
        children's wear, sportswear, and casual apparel. UPF 50+ is essential protection against skin cancer risk. Choose
        <strong>waterproof fabric</strong> if your product must protect against rain, snow, or moisture — outerwear, ski wear,
        tactical gear, and outdoor shells. For all-weather products, Seekingtex offers fabrics that combine both UPF 50+ and
        waterproof properties in a single laminate.
      </p>
      <div class="mt-6 flex gap-4 flex-wrap">
        <a
          href="/products"
          class="px-6 py-3 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition"
          >Browse Products</a
        >
        <a
          href="/guides"
          class="px-6 py-3 border border-gray-200 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition"
          >Read Guides</a
        >
      </div>
    </section>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>
      Comprehensive comparison between UPF 50+ sun protection fabrics and waterproof breathable fabrics. Covers
      protection, breathability, weight, durability, cost, care, climate suitability, layering, UPF rating, and stretch
      availability. Sun protection fabrics offer permanent fiber-level UV blocking, natural breathability, lightweight
      comfort, and moderate cost. Waterproof fabrics offer hydrostatic head membrane protection, MVTR breathability,
      heavier weight, higher cost, and technical care requirements. Decision guide recommends sun protection for
      everyday/hot weather use, waterproof for rain/wet/snow environments, and combined fabrics for all-weather
      products.
    </p>
  </section>
</Layout>
