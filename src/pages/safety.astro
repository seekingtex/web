---
export const prerender = false;
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { products } from '../data/products';
import { getPageContent } from '~/i18n/page-content';

const lang = Astro.locals.lang;

const page = getPageContent(lang, 'safety') || {};
const hero = page.hero || {};
const certifications = page.certifications || [];
const related = page.related || {};

const metadata = {
  title: `Safety & Compliance —${SITE.name}`,
  description:
    'Seekingtex safety standards: OEKO-TEX Standard 100 certification, REACH compliance, chemical safety testing, and fabric safety regulations.',
};

const safetyProducts = products.filter((p) => p.id === 'antibacterial' || p.id === 'flame-retardant');

const safetyStandards = [
  {
    title: 'OEKO-TEX Standard 100',
    body: 'All Seekingtex fabrics are OEKO-TEX Standard 100 certified, ensuring they are free from harmful substances. Every product is independently tested by OEKO-TEX accredited institutes.',
  },
  {
    title: 'REACH Compliance',
    body: 'All chemical substances used in Seekingtex fabrics comply with EU REACH Regulation (EC) 1907/2006. Full chemical disclosure and safety data sheets provided with every shipment.',
  },
  {
    title: 'ISO 14001 Environmental Management',
    body: 'Our facility is ISO 14001 certified for environmental management systems. Wastewater treatment, emissions control, and chemical handling follow strict environmental protocols.',
  },
  {
    title: 'Bluesign System Partner',
    body: 'Seekingtex is a bluesign system partner, ensuring responsible use of resources, consumer safety, and environmental protection throughout the textile supply chain.',
  },
];
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="fabric-safety-standards,oeko-tex-certified-textiles,chemical-safety-compliance" />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-semibold text-[#06b6d4] tracking-[0.15em] uppercase"
      >{hero.tagline || 'Safety & Compliance'}</span
    >
    <h1 class="mt-4 text-4xl font-bold text-gray-900">{hero.title || 'Chemical Safety & Compliance Standards'}</h1>
    <p class="mt-4 text-lg text-gray-500">
      {
        hero.subtitle ||
          'Every Seekingtex fabric undergoes rigorous chemical safety testing and meets international environmental and consumer safety regulations.'
      }
    </p>
  </section>

  <!-- Safety Standards -->
  <section class="max-w-5xl mx-auto pb-16 px-6">
    <div class="grid md:grid-cols-2 gap-6">
      {
        (certifications.length > 0 ? certifications : safetyStandards).map((cert: any) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center shrink-0">
                <svg
                  class="w-5 h-5 text-green-600"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  />
                </svg>
              </div>
              <h2 class="text-lg font-bold text-gray-900">{cert.title}</h2>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">{cert.body || cert.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Safety Products -->
  {
    safetyProducts.length > 0 && (
      <section class="max-w-5xl mx-auto pb-16 px-6">
        <div class="text-center mb-10">
          <span class="text-sm font-semibold text-[#06b6d4] tracking-[0.15em] uppercase">Safety Products</span>
          <h2 class="mt-2 text-3xl font-bold text-gray-900">Our Safety Products</h2>
          <p class="mt-3 text-gray-500">
            From protected environments to industrial applications — certified protection for every use case.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {safetyProducts.map((s) => (
            <div class="bg-white border-2 border-green-100 rounded-2xl p-6 hover:border-green-300 transition-colors">
              <h3 class="font-bold text-gray-900 text-lg">{s.name}</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">{s.desc}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {s.safety_rules.map((r) => (
                  <span class="px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-medium">{r}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Testing Process -->
  <section class="max-w-5xl mx-auto pb-16 px-6">
    <div class="bg-gray-50 rounded-2xl border border-gray-200 p-8 md:p-12">
      <div class="text-center mb-10">
        <span class="text-sm font-semibold text-[#06b6d4] tracking-[0.15em] uppercase">Our Compliance Process</span>
        <h2 class="mt-2 text-3xl font-bold text-gray-900">How We Ensure Safety</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-[#06b6d4]">100%</div>
          <p class="mt-2 text-sm text-gray-600">
            of raw materials screened for restricted substances before production release
          </p>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#06b6d4]">OEKO-TEX</div>
          <p class="mt-2 text-sm text-gray-600">
            Standard 100 certified — every fabric batch tested against 300+ regulated chemicals
          </p>
        </div>
        <div>
          <div class="text-3xl font-bold text-[#06b6d4]">3rd Party</div>
          <p class="mt-2 text-sm text-gray-600">Annual third-party audits complement our in-house testing program</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links -->
  <section class="max-w-4xl mx-auto pb-20 px-6">
    <div class="p-6 bg-white rounded-2xl border border-gray-200">
      <h2 class="font-semibold text-gray-900">{related.title || 'Related Resources'}</h2>
      <div class="mt-3 flex flex-wrap gap-3 text-sm">
        {
          (related.links && related.links.length > 0
            ? related.links
            : [
                { text: 'Quality Testing Guide', url: '/quality' },
                { text: 'FAQ', url: '/faq' },
                { text: 'Technology', url: '/technology' },
                { text: 'All Products', url: '/products' },
              ]
          ).map((link: any) => (
            <a
              href={link.url}
              class="px-3 py-1.5 bg-white rounded-lg border border-gray-200 text-gray-700 hover:border-sky-300 hover:text-sky-600 transition-colors"
            >
              {link.text} →
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="sr-only" data-ai-block="constraint" aria-hidden="true">
    <p>
      Seekingtex safety and compliance covers OEKO-TEX Standard 100, REACH, ISO 14001, and bluesign system. Fabrics are
      designed for controlled apparel, outdoor gear, uniform, and industrial applications. Not designed for applications
      requiring specific certification beyond OEKO-TEX scope without prior validation.
    </p>
  </section>
</Layout>
