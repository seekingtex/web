---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Lifestyle — ${SITE.name}`,
  description: `The ${SITE.name} lifestyle — built for those who believe in performance and innovation. Explore our ethos, community stories, and what drives every fabric decision.`,
};

const crumbs = [{ name: 'Home', href: '/' }, { name: 'Lifestyle' }];

const values = [
  {
    icon: '🧵',
    title: 'Born in Textile Innovation',
    desc: 'Every fabric development starts with understanding how materials behave. We engineer from the edge of performance inward — because textile science is our foundation, not just our process.',
  },
  {
    icon: '🔧',
    title: 'Built to Last',
    desc: 'The most sustainable fabric is the one that does not need replacing. High-tenacity yarns, premium coatings, and constructions that outlast seasonal trends.',
  },
  {
    icon: '🏆',
    title: 'Performance for Everyone',
    desc: 'Performance fabrics should not be a luxury. Professional-grade UPF 50+, waterproof, and antibacterial textiles at a price that makes sense for brands, makers, and small producers — not just military contracts.',
  },
  {
    icon: '🌍',
    title: 'Global Community',
    desc: 'From the mills of Suzhou to apparel factories in Europe, outdoor gear workshops in North America, and uniform producers across Asia — our customers share one thing: a commitment to quality.',
  },
  {
    icon: '♻️',
    title: 'Responsible Manufacturing',
    desc: 'Precision weaving and coating processes minimize waste. Durable construction reduces replacement cycles. We build for longevity because that is the most sustainable choice.',
  },
  {
    icon: '🤝',
    title: 'Support That Lasts',
    desc: 'Ten-year-old fabric formulations still get our full support. Our response averages 24 hours. We do not disappear after the sale — we are here for the life of the product.',
  },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section
    class="relative min-h-[50vh] flex items-center justify-center text-center text-white overflow-hidden bg-gradient-to-br from-[#001830] via-[#002d4a] to-[#003355]"
  >
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-sky-400">{SITE.name}</p>
      <h1 class="mt-4 text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]">The Seekingtex<br />Lifestyle</h1>
      <p class="mt-6 text-lg text-white/70 max-w-2xl mx-auto">
        Built for those who believe in performance and innovation — from global brands to independent makers who depend
        on their materials every day.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Our Ethos</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">More than a product. A philosophy.</h2>
      <p class="mt-4 text-lg text-gray-500">
        Six principles that shape every decision we make — from yarn selection to customer support.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        values.map((v) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
            <span class="text-3xl">{v.icon}</span>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">{v.title}</h3>
            <p class="mt-3 text-sm text-gray-500 leading-relaxed">{v.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-gray-50 dark:bg-slate-900/50 py-24 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Community</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">Join the Seekingtex Community</h2>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
        Follow our journey and share your own textile innovations.
      </p>
      <div class="mt-10 flex justify-center gap-4 flex-wrap">
        <a
          href="https://www.instagram.com/seekingtex"
          class="px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition"
          >Follow on Instagram</a
        >
        <a
          href="https://www.youtube.com/@Seekingtex"
          class="px-8 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition"
          >Subscribe on YouTube</a
        >
        <a
          href="https://x.com/seekingtex"
          class="px-8 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition"
          >Follow on X</a
        >
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6 text-center">
    <h2 class="text-3xl font-semibold text-gray-900">Start your journey</h2>
    <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
      Every fabric OEKO-TEX certified. Backed by warranty. Designed for real-world performance.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="/products"
        class="px-10 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition"
        >Explore Products →</a
      >
      <a
        href="/about"
        class="px-10 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition"
        >About Us</a
      >
    </div>
  </section>
</Layout>
