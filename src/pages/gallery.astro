---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Gallery — ${SITE.name}`,
  description: `Browse the ${SITE.name} gallery — fabric samples, factory workshops, production floor, and customer applications from around the world.`,
};

const crumbs = [{ name: 'Home', href: '/' }, { name: 'Gallery' }];

const albums = [
  {
    title: 'Functional Fabrics',
    desc: 'UPF 50+, waterproof, quick-dry, antibacterial, and stretch fabric samples for various applications.',
    images: [
      '/images/seekingtex/hero/hero-5.webp',
      '/images/seekingtex/hero/hero-5.webp',
      '/images/seekingtex/hero/fabric-design-sample.webp',
    ],
  },
  {
    title: 'Performance Textiles',
    desc: 'High-performance textiles for outdoor apparel, workwear, medical, and industrial use.',
    images: [
      '/images/seekingtex/products/fabric-performance-sample.webp',
      '/images/seekingtex/hero/fabric-design-sample.webp',
    ],
  },
  {
    title: 'Factory & Workshops',
    desc: 'Our 12,000 m² manufacturing facility in Suzhou, China.',
    images: [
      '/images/seekingtex/factory/fabric-factory-building.webp',
      '/images/seekingtex/hero/production-workshop.webp',
      '/images/seekingtex/factory/fabric-warehouse-storage.webp',
      '/images/seekingtex/factory/fabric-pressure-testing.webp',
    ],
  },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{SITE.name}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">Gallery</h1>
    <p class="mt-3 text-lg text-muted">Fabric samples, factory floor, and customer applications</p>
  </section>

  {albums.map((album) => (
    <section class="px-6 sm:px-6 pb-16 mx-auto max-w-6xl">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900">{album.title}</h2>
        <p class="mt-1 text-sm text-muted">{album.desc}</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {album.images.map((src) => (
          <div class="rounded-xl overflow-hidden bg-gray-100 aspect-[4/3]">
            <img src={src} alt={`${album.title} — ${SITE.name}`} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        ))}
      </div>
    </section>
  ))}

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">Want to see more?</h2>
      <p class="mt-2 text-sm text-muted">Follow us on social media for the latest fabric releases, factory updates, and customer applications.</p>
      <div class="mt-6 flex justify-center gap-4">
        <a href="https://www.instagram.com/seekingtex" class="px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90">Instagram</a>
        <a href="https://www.youtube.com/@Seekingtex" class="px-6 py-3 border border-gray-300 rounded-md font-semibold hover:bg-gray-50 transition">YouTube</a>
      </div>
    </div>
  </section>
</Layout>
