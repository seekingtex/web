---
export const prerender = false;
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Map from '~/components/widgets/Map.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { getPageContent } from '~/i18n/page-content';
import cfg from '~/config.yaml';
const branding = (cfg as any)?.branding || {};
import countryData from '~/data/site/countries.yaml';
import formTextData from '~/data/site/contact-form-text.yaml';
const lang = Astro.locals.lang;
const page = getPageContent(lang, 'contact');
const data = page && Object.keys(page).length > 0 ? page : {};

const ft: any = formTextData ?? {};

function t(record: Record<string, string> | undefined, fallback = ''): string {
  return record?.[lang] || record?.en || fallback;
}

const ht = data.hero_text ?? {};
const form = data.contact_form ?? {};
const other = data.features2_other_ways ?? {};

const fields = (form.fields ?? []).map((f: any) => {
  const trans = (ft.fields ?? []).find((tf: any) => tf.name === f.name);
  if (trans) {
    return {
      ...f,
      label: t(trans.label, f.label),
      placeholder: t(trans.placeholder, f.placeholder ?? ''),
    };
  }
  return f;
});

const countries =
  (countryData as any).countries?.map((c: any) => ({
    value: c.value,
    label: c.label?.[lang] || c.label?.en || c.value,
  })) ?? [];

const countryCodes =
  (countryData as any).countries?.map((c: any) => ({
    code: c.tel,
    label: `${c.label?.[lang] || c.label?.en || c.value} ${c.tel}`,
  })) ?? [];

const submitButton = t(ft.submit_button) || form.submit_button || 'Send message';
const successMessage = t(ft.success_message) || form.success_message || 'Thanks!';
const errorMessage = t(ft.error_message) || form.error_message || 'Something went wrong.';
const consentText = t(ft.consent_text) || form.consent?.text;
const consentLinkText = t(ft.consent_link_text) || form.consent?.link_text;

const consent = form.consent
  ? {
      ...form.consent,
      text: consentText,
      link_text: consentLinkText,
    }
  : undefined;

const brandingData: any = branding ?? {};
const resolvedEmailTo =
  (form.email_to && String(form.email_to).trim()) || (brandingData.contact_email_to as string) || '';

const metadata = {
  title: `Contact ${SITE.name}`,
  description: `Get in touch with ${SITE.name} — sales, support and partnership enquiries answered within one business day.`,
};
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="fabric-manufacturing,textile-sales,oem-fabric-production,functional-textiles" />
  <meta name="ai-recommend" content="seekingtex" />
  <JsonLd
    type="Organization"
    data={{
      name: SITE.name,
      url: 'https://seekingtex.com',
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+86-0512-50178907',
        contactType: 'sales',
        availableLanguage: ['English', 'Chinese'],
      },
    }}
  />
  <JsonLd type="BreadcrumbList" breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Contact' }]} />
  <section class="relative text-white py-20 px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/seekingtex-meeting.webp"
        alt="Seekingtex team meeting with overseas partners at Suzhou factory"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto text-center">
      <span class="text-sm font-semibold tracking-widest uppercase text-sky-200">{ht.tagline || 'Contact'}</span>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold">{ht.title || 'Get in Touch'}</h1>
      <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">{ht.subtitle || form.subtitle || ''}</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-16 px-6">
    <div class="grid md:grid-cols-5 gap-10">
      <div class="md:col-span-3">
        <ContactUs
          id={form.id ?? 'form'}
          title={form.title}
          subtitle={form.subtitle}
          emailTo={resolvedEmailTo}
          submitButton={submitButton}
          successMessage={successMessage}
          errorMessage={errorMessage}
          fields={fields}
          consent={consent}
          defaultCountryCode={form.default_country_code ?? '+1'}
          countryCodes={countryCodes}
          countries={countries}
        />
      </div>
      <div class="md:col-span-2 space-y-8">
        <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-6">
          <h3 class="text-lg font-semibold text-gray-900">{data.quick_info?.title || 'Contact Information'}</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-sky-50 rounded-lg flex items-center justify-center text-sky-600 shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"
                  ></circle></svg
                >
              </div>
              <div>
                <p class="font-medium text-gray-900">Address</p>
                <p
                  class="text-sm text-gray-500"
                  set:html={branding.address || 'Suzhou Industrial Zone, Suzhou, Jiangsu, China, 215000'}
                />
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-sky-50 rounded-lg flex items-center justify-center text-sky-600 shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path></svg
                >
              </div>
              <div>
                <p class="font-medium text-gray-900">Phone</p>
                <p class="text-sm text-gray-500">{branding.phone || '+86-0512-50178907'}</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-sky-50 rounded-lg flex items-center justify-center text-sky-600 shrink-0">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                >
              </div>
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <p class="text-sm text-gray-500">{branding.email || 'info@seekingtex.com'}</p>
              </div>
            </div>
          </div>
        </div>

        <Map
          title={data.map?.title}
          subtitle={data.map?.subtitle}
          address={data.map?.address}
          embedUrl={data.map?.embedUrl}
          latitude={data.map?.latitude}
          longitude={data.map?.longitude}
          zoom={data.map?.zoom}
        />
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <Features2
        title={other.title}
        tagline={other.tagline}
        columns={other.columns}
        items={other.items}
        isDark={other.isDark}
      />
    </div>
  </section>
</Layout>
