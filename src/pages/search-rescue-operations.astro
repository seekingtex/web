---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

const metadata = {
  title: `Tactical & Military Textiles — High-Performance Fabrics for Defense — ${SITE.name}`,
  description: `${SITE.name} technical fabrics engineered for military and tactical applications. Advanced materials, multi-layer constructions, superior durability, and mission-ready performance for defense and security forces worldwide.`,
};

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Tactical & Military Textiles' },
];

const sections = [
  {
    title: 'Advanced Materials for Tactical Applications',
    content: 'The foundation of any reliable military textile lies in the quality of its construction materials. Seekingtex utilizes high-tenacity nylon, advanced polyester blends, and cutting-edge aramid hybrid fabrics — each chosen for optimal durability in extreme conditions. Our fabrics offer superior UV resistance, chemical resilience, and abrasion protection, ensuring your gear performs flawlessly mission after mission.',
  },
  {
    title: 'Design Principles for Optimal Tactical Performance',
    content: 'Every Seekingtex tactical fabric features advanced weave structures for directional strength and superior multi-layer construction with integrated functional finishes. If one performance layer is compromised, the remaining layers retain full functionality — keeping personnel operational and safe. Our constructions prioritize durability, comfort, and environmental protection critical for tactical environments.',
  },
  {
    title: 'Specialized Finishes & Treatments',
    content: 'Seekingtex fabrics are engineered as adaptable platforms for diverse tactical missions. Features include FR treatment, IR signature management, chemical/biological protection, waterproof breathable laminates, and antimicrobial finishes for maximum operational capability.',
  },
  {
    title: 'Uncompromising Production Process',
    content: 'Our manufacturing employs precision weaving and controlled coating application in climate-controlled environments. Every fabric batch undergoes tensile testing, hydrostatic head verification, abrasion testing, and comprehensive chemical safety screening before shipping.',
  },
];

const features = [
  { label: 'FR Treatment', desc: 'Inherent and treated flame retardant' },
  { label: 'IR Signature Management', desc: 'Near-IR reflectance for camouflage' },
  { label: 'Chemical/Bio Protection', desc: 'Barrier against chemical agents' },
  { label: 'Waterproof Breathable', desc: 'Rated to 20,000 mm hydrostatic head' },
  { label: 'Antimicrobial', desc: '>99% bacterial reduction' },
  { label: 'Tensile > 400 N', desc: 'High-strength construction' },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">Tactical Solutions</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">Tactical & Military Textiles</h1>
    <p class="mt-3 text-lg text-muted max-w-3xl mx-auto">
      Seekingtex tactical fabrics are engineered for the uncompromising demands of military and defense.
      With no margin for error, our textiles deliver unwavering reliability, superior performance,
      and absolute protection in the most perilous environments.
    </p>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {features.map((f) => (
        <div class="text-center p-4 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
          <span class="block text-sm font-bold text-primary">{f.label}</span>
          <span class="block text-xs text-muted mt-1">{f.desc}</span>
        </div>
      ))}
    </div>
  </section>

  {sections.map((s, i) => (
    <section class={`px-6 sm:px-6 py-16 mx-auto max-w-4xl ${i % 2 === 0 ? 'bg-gray-50 dark:bg-gray-900' : ''}`}>
      <div class={i % 2 === 0 ? 'max-w-4xl mx-auto' : ''}>
        <h2 class="text-2xl font-bold">{s.title}</h2>
        <p class="mt-4 text-muted leading-relaxed">{s.content}</p>
      </div>
    </section>
  ))}

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-4xl">
    <div class="rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-8">
      <h2 class="text-2xl font-bold text-center">Built for Those Who Serve</h2>
      <p class="mt-4 text-muted leading-relaxed text-center max-w-3xl mx-auto">
        Choosing Seekingtex is an investment in confidence — confidence in your fabric's integrity,
        its operational excellence, and its capacity to perform flawlessly when lives are on the line.
        Our textiles are trusted partners in defense and security operations worldwide.
      </p>
      <div class="text-center mt-8">
        <a href="/contact" class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90">
          Request tactical specifications →
        </a>
      </div>
    </div>
  </section>
  <ExperienceLayer
    title="How Our Fabrics Perform in Real Missions"
    subtitle="First-hand accounts from military and tactical operators who rely on Seekingtex fabrics in the field."
    stories={[
      {
        quote: "We deployed two batches of Seekingtex tactical fabric for field trials — they outperformed our existing supplier for durability after 6 months of continuous use.",
        narrative: "During a defense procurement evaluation, a military logistics unit tested Seekingtex tactical fabrics alongside three existing suppliers. The fabrics were subjected to field conditions including extreme temperatures, abrasion, repeated laundering, and exposure to chemical agents. Seekingtex fabric showed the least degradation in tensile strength and maintained its FR properties within specification throughout the trial period.",
        context: "Defense procurement evaluation, 2024",
        source: "Military Procurement Officer"
      },
      {
        quote: "What sets Seekingtex apart is the coating consistency. After 300+ hours of field use in harsh conditions, our uniforms still hold the waterproof rating like day one.",
        narrative: "A special operations unit conducting training exercises in tropical environments tested Seekingtex waterproof breathable fabric for field uniforms. The uniforms were subjected to daily use, river crossings, and jungle conditions. After 6 months, the fabric maintained its hydrostatic head rating above 15,000 mm with no delamination or coating failure. The unit has since recommended Seekingtex for the next procurement cycle.",
        context: "Special operations field trial, 2023-2025",
        source: "Unit Logistics Officer"
      },
    ]}
  />
  <RelatedPages
    title="Related Resources"
    subtitle="Explore more about Seekingtex's tactical and military capabilities"
    links={[
      { title: 'Medical & Healthcare Textiles', description: 'Protective fabrics for medical and healthcare applications.', href: '/disaster-relief-humanitarian-aid', label: 'Use Case' },
      { title: 'Industrial & Technical Textiles', description: 'Heavy-duty performance fabrics for industrial applications.', href: '/commercial-workboats', label: 'Product' },
      { title: 'Engineering Perfection', description: 'Our engineering philosophy — precision manufacturing and rigorous quality control.', href: '/engineering-perfection', label: 'Philosophy' },
      { title: 'Solutions by Industry', description: 'Find the right fabric for your industry sector.', href: '/solutions/by-industry', label: 'Overview' },
    ]}
  />
</Layout>
