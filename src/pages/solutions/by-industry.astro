---
import Layout from '~/layouts/PageLayout.astro';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

const metadata = {
  title: 'Solutions by Industry — Functional Fabrics for Every Sector',
  description:
    'Find the right functional fabric solution for your industry. Sportswear, outdoor apparel, tactical, medical, fashion — Seekingtex manufactures OEKO-TEX certified performance textiles for every sector.',
  ignoreTitleTemplate: true,
};

const crumbs = [{ name: 'Home', href: '/' }, { name: 'Solutions by Industry' }];

const industries = [
  {
    name: 'Sportswear & Athletic',
    color: 'from-green-50 to-emerald-50',
    border: 'border-green-200',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    description:
      'High-performance fabrics for activewear, fitness apparel, yoga wear, and team спортивные uniformes. Moisture management, 4-way stretch, and breathability engineered for movement.',
    craft: [
      'Quick-dry moisture wicking fabrics',
      '4-way stretch fabrics',
      'Breathable mesh panels',
      'UPF 50+ performance fabrics',
    ],
    certifications: ['OEKO-TEX Standard 100', 'UPF 50+ certified', 'SGS tested'],
    link: '/products?category=quick-dry',
  },
  {
    name: 'Outdoor & Adventure Apparel',
    color: 'from-sky-50 to-blue-50',
    border: 'border-sky-200',
    icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 12.5V17a2 2 0 01-2 2H6a2 2 0 01-2-2V9a2 2 0 012-2h3.5a2 2 0 012 2v.5',
    description:
      'Durable, weather-resistant fabrics for hiking, camping, climbing, and outdoor adventure gear. Waterproof breathable membranes and UV-blocking technologies for extreme conditions.',
    craft: [
      'Waterproof breathable fabrics (10,000mm+)',
      'UPF 50+ sun protection fabrics',
      'Wind-resistant outerwear fabrics',
      'Eco-friendly recycled shell fabrics',
    ],
    certifications: ['OEKO-TEX Standard 100', 'REACH compliant', 'GRS certified'],
    link: '/products?category=waterproof',
  },
  {
    name: 'Tactical & Workwear',
    color: 'from-gray-50 to-slate-50',
    border: 'border-gray-200',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    description:
      'Rugged, high-durability fabrics for military uniforms, law enforcement gear, industrial workwear, and protective apparel. Flame retardant and abrasion-resistant options.',
    craft: [
      'Flame retardant treated fabrics',
      'Abrasion-resistant workwear fabrics',
      'Antibacterial uniform fabrics',
      'High-tenacity nylon/polyester blends',
    ],
    certifications: ['OEKO-TEX Standard 100', 'FR certified', 'EN 11611/11612 options'],
    link: '/products?category=antibacterial',
  },
  {
    name: 'Fashion & Casual Wear',
    color: 'from-rose-50 to-pink-50',
    border: 'border-rose-200',
    icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
    description:
      'Stylish yet functional fabrics for contemporary fashion brands. Eco-friendly recycled materials, performance finishes, and custom textures for ready-to-wear collections.',
    craft: [
      'Eco-friendly recycled fabrics (GRS)',
      'Breathable cotton-blend performance fabrics',
      'Stretch woven fabrics for casual suiting',
      'Custom dye and finish developments',
    ],
    certifications: ['OEKO-TEX Standard 100', 'GRS certified', 'REACH compliant'],
    link: '/products?category=eco-friendly',
  },
  {
    name: 'Medical & Healthcare',
    color: 'from-blue-50 to-indigo-50',
    border: 'border-blue-200',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z',
    description:
      'Antibacterial, fluid-resistant, and breathable fabrics for healthcare uniforms, surgical gowns, patient drapes, and medical protective apparel. Tested to healthcare standards.',
    craft: [
      '7A antibacterial fabrics (>99% reduction)',
      'Waterproof breathable barrier fabrics',
      'Antimicrobial coated textiles',
      'Comfort-stretch uniform fabrics',
    ],
    certifications: ['OEKO-TEX Standard 100', 'GB/T 20944.3 (7A)', 'SGS tested antibacterial'],
    link: '/products?category=antibacterial',
  },
  {
    name: 'Industrial & Technical Textiles',
    color: 'from-amber-50 to-yellow-50',
    border: 'border-amber-200',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
    description:
      'Specialty technical textiles for industrial applications — filtration media, protective barriers, high-visibility safety fabrics, and coated textiles for demanding environments.',
    craft: [
      'High-visibility safety fabrics',
      'Oil/water repellent treated textiles',
      'Conductive/anti-static fabrics',
      'Custom coated industrial textiles',
    ],
    certifications: ['OEKO-TEX Standard 100', 'REACH/RoHS', 'Custom spec available'],
    link: '/products',
  },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="max-w-6xl mx-auto py-24 px-6">
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">Solutions by Industry</h1>
    <p class="mt-4 text-lg text-gray-500">
      Find the right functional fabric for your industry. Each solution is backed by OEKO-TEX certification, third-party
      testing, and a 15,000 m² manufacturing facility in Kunshan, China.
    </p>

    <div class="mt-16 space-y-8">
      {
        industries.map((ind) => (
          <div
            class={`bg-gradient-to-br ${ind.color} rounded-2xl border ${ind.border} p-8 hover:shadow-md transition-shadow`}
          >
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/80 flex items-center justify-center flex-shrink-0">
                <svg
                  class="w-6 h-6 text-gray-700"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={ind.icon} />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="text-xl font-semibold text-gray-900">{ind.name}</h2>
                <p class="mt-2 text-sm text-gray-600">{ind.description}</p>
                <div class="mt-4">
                  <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Recommended Fabrics</span>
                  <ul class="mt-2 space-y-1">
                    {ind.craft.map((c) => (
                      <li class="flex items-center gap-2 text-sm text-gray-600">
                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0" />
                        {c}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="mt-3 flex items-center gap-4">
                  <span class="text-xs text-gray-400">{ind.certifications.join(' · ')}</span>
                </div>
                <a
                  href={ind.link}
                  class="mt-4 inline-flex text-sm font-medium text-sky-600 hover:text-sky-700 hover:underline"
                >
                  Learn more →
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <section class="mt-16 bg-gray-50 rounded-2xl p-8 border border-gray-200 text-center">
      <h2 class="text-2xl font-semibold text-gray-900">Need a Custom Fabric Solution?</h2>
      <p class="mt-4 text-gray-500">
        Our OEM/ODM team can develop custom functional fabrics for your specific industry requirements — from lab dip to
        bulk production.
      </p>
      <div class="mt-6 flex justify-center gap-4">
        <a
          href="/contact"
          class="px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition"
          >Request OEM Quote</a
        >
        <a
          href="/products"
          class="px-8 py-4 border border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition"
          >Browse Fabrics</a
        >
      </div>
    </section>
  </section>

  <ExperienceLayer
    title="Industry Solutions in Action"
    subtitle="Real examples of how Seekingtex fabrics perform across different industry sectors."
    stories={[
      {
        quote:
          'We switched to Seekingtex UPF 50+ fabrics for our outdoor worker uniforms. Skin irritation complaints dropped to zero and the fabric holds up after 100+ industrial washes.',
        narrative:
          'A European workwear brand was using standard poly-cotton for outdoor utility worker uniforms. After switching to Seekingtex UPF 50+ sun protection fabrics with moisture wicking finish, worker satisfaction scores improved 40%. The fabric maintained its UPF rating after 100 industrial launderings per AATCC 183 testing.',
        context: 'Workwear OEM, Germany, 2024-2025',
        source: 'Technical Director, Uniform Manufacturer',
      },
      {
        quote:
          "The 7A antibacterial fabric passed our hospital's 50-wash validation with >99% bacterial reduction still intact. We've standardized on it for all staff uniforms.",
        narrative:
          'A hospital group in the Middle East needed antibacterial fabrics for 5,000+ staff uniforms. Seekingtex 7A antibacterial fabric with zinc-based antimicrobial treatment passed their 50-wash accelerated laundry test with bacterial reduction rates still exceeding 99%. The fabric also maintained color fastness and dimensional stability with zero complaints in the first year.',
        context: 'Healthcare uniform supply, UAE, 2023-2025',
        source: 'Procurement Manager, Hospital Group',
      },
    ]}
  />
  <RelatedPages
    title="Explore More"
    subtitle="Related solutions and resources"
    links={[
      {
        title: 'Solutions by Use Case',
        description: 'Match your specific use case to the right Seekingtex fabric.',
        href: '/solutions/by-use-case',
        label: 'Decision Tool',
      },
      {
        title: 'Product Catalog',
        description: 'Browse all functional fabric categories with full specifications.',
        href: '/products',
        label: 'Products',
      },
      {
        title: 'OEM/ODM Manufacturing',
        description: 'Custom fabric development services for global brands.',
        href: '/contact',
        label: 'OEM',
      },
      {
        title: 'Quality & Certifications',
        description: 'OEKO-TEX, GRS, REACH — our compliance standards.',
        href: '/about',
        label: 'Quality',
      },
    ]}
  />

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>
      Solutions by industry for Seekingtex functional fabrics. Six industry verticals: Sportswear & Athletic (quick-dry
      moisture wicking, 4-way stretch, breathable mesh), Outdoor & Adventure Apparel (waterproof breathable, UPF 50+ sun
      protection, eco-friendly recycled), Tactical & Workwear (flame retardant, abrasion-resistant, antibacterial),
      Fashion & Casual Wear (eco-friendly recycled, stretch woven, custom finish), Medical & Healthcare (7A
      antibacterial, waterproof breathable barrier, antimicrobial), Industrial & Technical Textiles (high-visibility,
      oil/water repellent, anti-static). All fabrics OEKO-TEX Standard 100 certified, third-party tested. OEM/ODM custom
      development available for all industries.
    </p>
  </section>
</Layout>
