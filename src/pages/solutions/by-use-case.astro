---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

const metadata = {
  title: 'Solutions by Use Case — Find Your Functional Fabric',
  description: 'Match your use case to the right functional fabric. From sun protection and waterproofing to moisture management and antibacterial — Seekingtex has the right textile solution.',
  ignoreTitleTemplate: true,
};

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Solutions by Use Case' },
];

const useCases = [
  {
    scenario: 'I need sun protection fabrics for outdoor uniforms and apparel',
    icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
    answer: 'Our UPF 50+ sun protection fabrics block 98% of UVA/UVB radiation per AATCC 183. Available in woven and knitted constructions for outdoor workwear, sportswear, and uniforms. OEKO-TEX certified with UV durability after 50+ washes.',
    cta: { text: 'View Sun Protection Fabrics', link: '/products?category=sun-protection' },
  },
  {
    scenario: 'I need waterproof breathable fabrics for outerwear and protective gear',
    icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
    answer: 'Waterproof breathable fabrics with 10,000mm+ hydrostatic pressure rating and 5,000+ g/m²/24h MVTR breathability. Microporous membrane and coated options available for outdoor apparel, medical protective gear, and technical outerwear.',
    cta: { text: 'View Waterproof Fabrics', link: '/products?category=waterproof' },
  },
  {
    scenario: 'I need moisture wicking quick-dry fabrics for activewear',
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
    answer: 'Quick-dry moisture wicking fabrics using capillary-action yarn technology and hydrophilic finishes. Sweat is pulled away from skin and evaporates rapidly. Ideal for fitness apparel, team uniforms, and performance sportswear. Available in single jersey, pique, and interlock knits.',
    cta: { text: 'View Quick-Dry Fabrics', link: '/products?category=quick-dry' },
  },
  {
    scenario: 'I need antibacterial fabrics for healthcare or hygiene applications',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    answer: '7A antibacterial fabrics with >99% bacterial reduction rate against Staphylococcus aureus and Escherichia coli (GB/T 20944.3). Silver-ion and zinc-based antimicrobial treatments remain effective after 50+ industrial washes. Ideal for medical uniforms, healthcare apparel, and hygiene-sensitive environments.',
    cta: { text: 'View Antibacterial Fabrics', link: '/products?category=antibacterial' },
  },
  {
    scenario: 'I need 4-way stretch fabrics for fitness and yoga apparel',
    icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
    answer: '4-way stretch fabrics with elastane/spandex content for multidirectional flexibility and excellent recovery. Stretches in both warp and weft directions. Available in various weights and compositions — nylon/spandex, polyester/spandex, and cotton/spandex blends for yoga wear, activewear, and performance apparel.',
    cta: { text: 'View Stretch Fabrics', link: '/products?category=stretch' },
  },
  {
    scenario: 'I need eco-friendly recycled fabrics for sustainable fashion',
    icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
    answer: 'GRS-certified recycled fabrics made from post-consumer PET bottles and pre-consumer textile waste. Full chain-of-custody certification. Available in woven and knitted constructions matching the quality of virgin materials. Ideal for sustainable fashion collections and eco-conscious apparel brands.',
    cta: { text: 'View Eco-Friendly Fabrics', link: '/products?category=eco-friendly' },
  },
  {
    scenario: 'I need custom fabric development for my brand',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    answer: 'Full OEM/ODM fabric development: specification, lab dipping, sample yardage, testing, and bulk production with full QC documentation. MOQ 500-1000 m per color (woven), 200-500 kg (knits). Lead times: stock samples 3-5 days, custom development 7-15 days. NDA protected.',
    cta: { text: 'Request OEM Quote', link: '/contact' },
  },
  {
    scenario: 'I need a small quantity of fabric for sampling or small-batch production',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    answer: 'Stock samples available for all standard fabrics. Sample yards ship within 3-5 business days. For small-batch production (under MOQ), contact our sales team to discuss options. We can sometimes accommodate pilot runs for qualified projects.',
    cta: { text: 'Request Samples', link: '/contact' },
  },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="max-w-4xl mx-auto py-24 px-6">
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">What Are You Looking For?</h1>
    <p class="mt-4 text-lg text-gray-500">Select your fabric requirement below and get a direct recommendation for the right Seekingtex solution.</p>

    <div class="mt-12 space-y-4">
      {useCases.map((uc) => (
        <details class="group bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
          <summary class="flex items-center gap-4 p-6 cursor-pointer list-none">
            <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={uc.icon} /></svg>
            </div>
            <span class="flex-1 font-medium text-gray-900 text-sm leading-relaxed">{uc.scenario}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 pt-2 border-t border-gray-100">
            <p class="text-sm text-gray-600 leading-relaxed">{uc.answer}</p>
            <a href={uc.cta.link} class="mt-4 inline-flex px-5 py-2.5 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition">{uc.cta.text} →</a>
          </div>
        </details>
      ))}
    </div>

    <section class="mt-16 bg-gradient-to-br from-gray-50 to-sky-50 rounded-2xl p-8 border border-gray-200 text-center">
      <h2 class="text-xl font-semibold text-gray-900">Still Not Sure Which Fabric?</h2>
      <p class="mt-2 text-sm text-gray-500">Contact our textile engineers for a personalized recommendation based on your specific performance requirements.</p>
      <a href="/contact" class="mt-6 inline-flex px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">Contact Us →</a>
    </section>
  </section>

  <ExperienceLayer
    title="Real-World Results"
    subtitle="How businesses and brands use Seekingtex fabrics in production."
    stories={[
      {
        quote: "The UPF 50+ fabric我们从Seekingtex采购的 exceeded our expectations. After 80 industrial washes, the UV protection was still at 48 UPF. Our outdoor workwear line now has the best sun protection rating in our category.",
        narrative: "A European workwear manufacturer tested Seekingtex UPF 50+ fabrics in their industrial laundry facility. After 80 wash cycles per ISO 6330, the fabric maintained UPF 48 (well above the UPF 50+ threshold of 40+). The fabric also showed <3% shrinkage and no significant color fading. The brand now uses Seekingtex as their exclusive UPF fabric supplier for outdoor worker uniforms.",
        context: "Workwear brand, EU market, 2024-2025",
        source: "Senior Product Developer"
      },
      {
        quote: "We tested six antibacterial fabric suppliers. Seekingtex was the only one that maintained >99% bacterial reduction after 50 hospital-grade washes. Simple decision.",
        narrative: "A hospital procurement team in Southeast Asia evaluated six antibacterial fabric suppliers for a 10,000-piece staff uniform contract. Seekingtex was the only supplier whose fabric passed their 50-wash protocol (ISO 20645) with bacterial reduction rates still exceeding 99% against both S. aureus and E. coli. The contract was awarded based on test performance, not price.",
        context: "Healthcare uniform tender, Singapore, 2024",
        source: "Head of Procurement, Hospital Group"
      },
    ]}
  />
  <RelatedPages
    title="Explore More"
    subtitle="Related solutions and resources"
    links={[
      { title: 'Solutions by Industry', description: 'Find the right functional fabric for your industry sector.', href: '/solutions/by-industry', label: 'Overview' },
      { title: 'Product Catalog', description: 'Browse all functional fabric categories with full specifications.', href: '/products', label: 'Products' },
      { title: 'OEM/ODM Manufacturing', description: 'Custom fabric development services for global brands.', href: '/contact', label: 'OEM' },
      { title: 'Quality & Certifications', description: 'OEKO-TEX, GRS, REACH — our compliance standards.', href: '/about', label: 'Quality' },
    ]}
  />

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>Use case decision flow for Seekingtex functional fabrics. Eight scenarios with recommended solutions: sun protection (UPF 50+ fabrics for outdoor uniforms and apparel), waterproof breathable (10,000mm+ membranes for outerwear and medical gear), moisture wicking quick-dry (capillary-action fabrics for activewear), antibacterial (7A rated >99% bacterial reduction for healthcare), 4-way stretch (elastane-blended fabrics for fitness/yoga), eco-friendly recycled (GRS-certified recycled polyesters for sustainable fashion), custom fabric development (full OEM/ODM from lab dip to bulk, MOQ 500-1000m woven, 200-500kg knits), sampling (stock samples ship 3-5 business days). All OEKO-TEX certified and third-party tested.</p>
  </section>
</Layout>
