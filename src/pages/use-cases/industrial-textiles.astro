---
import PageLayout from '~/layouts/PageLayout.astro';
import { articleSchema } from '~/lib/seo/schema';
import { nodes } from '~/content/graph/nodes';
import { getPageContent } from '~/i18n/page-content';

const lang = 'en';
const page = getPageContent(lang, 'industrial-textiles');
const node = nodes.find((n) => n.id === 'industrial-textiles');

const graphJsonLd = node
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema({
          headline: page.seo?.headline || 'Industrial & Technical Textiles 鈥?OEM Manufacturing',
          description:
            page.seo?.description ||
            'Seekingtex manufactures high-performance fabrics for industrial and technical applications: heavy-duty workwear, protective clothing, specialized performance textiles.',
          datePublished: page.seo?.datePublished || '2024-06-01',
          dateModified: page.seo?.dateModified || '2026-06-01',
          author: 'Seekingtex',
          publisher: 'Seekingtex',
        }),
        {
          '@type': 'Product',
          name: node?.name?.en || 'Industrial & Technical Textiles',
          description:
            node?.description?.en ||
            'High-performance fabrics for industrial workwear, protective clothing, and specialized technical applications.',
          brand: { '@type': 'Brand', name: 'Seekingtex' },
          category: 'Industrial & Technical Textiles',
        },
      ],
    }
  : null;

const metadata = {
  title: page.seo?.headline || 'Industrial & Technical Textiles 鈥?OEM Manufacturing',
  description:
    page.seo?.description ||
    'Seekingtex manufactures high-performance fabrics for industrial and technical applications: heavy-duty workwear, protective clothing, specialized performance textiles.',
};
---

<PageLayout metadata={metadata}>
  <script
    slot="before"
    is:inline
    type="application/ld+json"
    set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''}
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Use Case'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">
      {page.headline || 'Industrial & Technical Textile Solutions'}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">
      {
        page.subtitle ||
          'Seekingtex high-performance fabrics for industrial applications, technical textiles, and specialized performance requirements.'
      }
    </p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''} />
  </section>
</PageLayout>
