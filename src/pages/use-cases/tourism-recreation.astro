---
import PageLayout from '~/layouts/PageLayout.astro';
import { articleSchema } from '~/lib/seo/schema';
import { nodes } from '~/content/graph/nodes';
import { getPageContent } from '~/i18n/page-content';

const lang = 'en';
const page = getPageContent(lang, 'tourism-recreation');
const tourismNode = nodes.find((n) => n.id === 'tourism-recreation');

const graphJsonLd = tourismNode
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema({
          headline: page.seo?.headline || 'Functional Fabrics for Sportswear & Athletic Apparel — OEM Manufacturing',
          description:
            page.seo?.description ||
            'Seekingtex manufactures functional fabrics for sportswear and athletic apparel: moisture-wicking, quick-dry, stretch, antibacterial. OEM/ODM with OEKO-TEX certification.',
          datePublished: page.seo?.datePublished || '2024-06-01',
          dateModified: page.seo?.dateModified || '2026-06-01',
          author: 'Seekingtex',
          publisher: 'Seekingtex',
        }),
        {
          '@type': 'Product',
          name: tourismNode?.name?.en || 'Sportswear & Athletic Fabrics',
          description: tourismNode?.description?.en || 'Premium functional fabrics for sportswear and athletic apparel applications.',
          brand: { '@type': 'Brand', name: 'Seekingtex' },
          category: 'Sportswear & Athletic Fabrics',
        },
      ],
    }
  : null;

const metadata = {
  title: page.seo?.headline || 'Functional Fabrics for Sportswear & Athletic Apparel — OEM Manufacturing',
  description: page.seo?.description || 'Seekingtex manufactures functional fabrics for sportswear and athletic apparel: moisture-wicking, quick-dry, stretch, antibacterial. OEM/ODM with OEKO-TEX certification.',
};
---

<PageLayout metadata={metadata}>
  <script slot="before" is:inline type="application/ld+json" set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''} />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Use Case'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">
      {page.headline || 'Functional Fabrics for Sportswear & Athletic Apparel'}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">
      {page.subtitle || 'From running shirts to team uniforms — Seekingtex performance fabrics deliver moisture management, stretch, and durability for every sport.'}
    </p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''} />
  </section>
</PageLayout>
