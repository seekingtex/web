---
export const prerender = true;

import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';
import TrustBadges from '~/components/common/TrustBadges.astro';
import { SITE } from 'astrowind:config';
import { getPageContent } from '~/i18n/page-content';
import { languages } from '~/i18n/config';
import aboutData from '~/data/site/about.yaml';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'about');

const hero = page.hero ?? {};
const stats = page.stats ?? {};
const wwb = page.features3_what_we_build ?? {};
const more = page.features3_more ?? {};
const values = page.steps2_values ?? {};
const milestones = page.steps2_milestones ?? {};
const locations = page.features2_locations ?? {};

const about = (aboutData as any) || {};
const origin = about.origin || {};
const philosophy = about.philosophy || {};
const design = about.design || {};

const metadata = {
  title: `About ${SITE.name} — Functional Fabric Manufacturer & Textile Engineering`,
  description: `${SITE.name} was founded with a simple belief: textile products should be engineered like they matter. Learn our story, fabric philosophy, and design principles.`,
};
const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'About' }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <Hero tagline={hero.tagline} image={hero.image} title={hero.title} subtitle={hero.subtitle} />

  <Stats title={stats.title} stats={stats.stats} />

  <!-- Brand Origin Story -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{origin.tagline || 'Our Origin'}</span>
        <h2
          class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900 dark:text-slate-100 leading-tight"
          set:html={origin.heading ||
            'Built on fabric expertise,<br /><span class="text-sky-600">driven by purpose</span>'}
        />
        <div class="mt-8 space-y-5 text-gray-600 dark:text-slate-400 leading-relaxed">
          {(origin.paragraphs || []).map((p: string) => <p set:html={p} />)}
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden bg-gray-100 dark:bg-slate-800 aspect-[4/3]">
        <img
          src={origin.image || '/images/seekingtex/hero/tech-meeting.webp'}
          alt={origin.image_alt || 'Seekingtex textile workshop'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Fabric Philosophy -->
  <section class="bg-gray-50 dark:bg-slate-900/50 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase"
          >{philosophy.tagline || 'Our Philosophy'}</span
        >
        <h2 class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900 dark:text-slate-100">
          {philosophy.heading || 'Rooted in fabric expertise'}
        </h2>
        <p class="mt-4 text-lg text-gray-500 dark:text-slate-400">{philosophy.description || ''}</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {
          (philosophy.cards || []).map((card: any) => (
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 border border-gray-200 dark:border-slate-700">
              <div class="w-14 h-14 bg-blue-50 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-2xl">
                {card.emoji || ''}
              </div>
              <h3 class="mt-5 text-lg font-semibold text-gray-900 dark:text-slate-100">{card.title || ''}</h3>
              <p class="mt-3 text-gray-500 dark:text-slate-400 text-sm leading-relaxed">{card.description || ''}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Design Philosophy -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="rounded-2xl overflow-hidden bg-gray-100 dark:bg-slate-800 aspect-[4/3] order-last md:order-first">
        <img
          src={design.image || '/images/seekingtex/hero/design-studio.webp'}
          alt={design.image_alt || 'Seekingtex design and engineering'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase"
          >{design.tagline || 'Design Philosophy'}</span
        >
        <h2
          class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900 dark:text-slate-100 leading-tight"
          set:html={design.heading ||
            'Engineered for performance<br /><span class="text-sky-600">in every condition</span>'}
        />
        <div class="mt-8 space-y-5 text-gray-600 dark:text-slate-400 leading-relaxed">
          {(design.paragraphs || []).map((p: string) => <p set:html={p} />)}
        </div>
        <div class="mt-8 grid grid-cols-3 gap-4">
          {
            (design.stats || []).map((s: any) => (
              <div class="text-center p-4 bg-gray-50 dark:bg-slate-800 rounded-xl">
                <div class="text-2xl font-bold text-sky-600">{s.value || ''}</div>
                <div class="text-xs text-gray-500 dark:text-slate-400 mt-1" set:html={s.label || ''} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <TrustBadges
    title="Built to standards that matter"
    subtitle="Every Seekingtex fabric is certified, tested, and backed by a warranty that means something."
  />

  <Features3
    title={wwb.title}
    subtitle={wwb.subtitle}
    columns={wwb.columns}
    isBeforeContent={wwb.isBeforeContent}
    items={wwb.items}
  />

  <Features3 columns={more.columns} isAfterContent={more.isAfterContent} items={more.items} image={more.image} />

  <Steps2 title={values.title} subtitle={values.subtitle} items={values.items} />

  <Steps2
    title={milestones.title}
    subtitle={milestones.subtitle}
    isReversed={milestones.isReversed}
    items={milestones.items}
  />

  <Features2 title={locations.title} tagline={locations.tagline} columns={locations.columns} items={locations.items} />
</Layout>
