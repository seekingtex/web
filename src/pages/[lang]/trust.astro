---
export const prerender = true;

import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { getPageContent } from '~/i18n/page-content';
import { languages } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'trust');

const hero = page.hero ?? {};
const stats = page.stats ?? {};
const certs = page.features3_certifications ?? {};
const testimonials = page.testimonials ?? {};
const steps = page.steps2_manufacturing ?? {};
const faqs = page.faqs ?? {};
const cta = page.cta ?? {};

const metadata = {
  title: `Trust ${SITE.name} — Certifications, Quality & Global Standards`,
  description: `${SITE.name} products are CE certified. Learn about our quality testing, material compliance, and the standards behind every product.`,
};
const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'Trust' }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <Hero tagline={hero.tagline} image={hero.image} title={hero.title} subtitle={hero.subtitle} />

  <Stats title={stats.title} stats={stats.stats} />

  <Features3
    title={certs.title}
    subtitle={certs.subtitle}
    columns={certs.columns}
    isBeforeContent={certs.isBeforeContent}
    items={certs.items}
  />

  <Testimonials
    tagline={testimonials.tagline}
    title={testimonials.title}
    subtitle={testimonials.subtitle}
    testimonials={testimonials.items}
  />

  <Steps2 title={steps.title} subtitle={steps.subtitle} items={steps.items} />

  <FAQs title={faqs.title} subtitle={faqs.subtitle} columns={faqs.columns} items={faqs.items} />

  <CallToAction title={cta.title} subtitle={cta.subtitle} actions={cta.actions} />
</Layout>
