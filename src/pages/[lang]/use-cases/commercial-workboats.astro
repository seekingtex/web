---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { articleSchema } from '~/lib/seo/schema';
import { nodes } from '~/content/graph/nodes';
import { getPageContent } from '~/i18n/page-content';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const page = getPageContent(lang, 'commercial-workboats');
const node = nodes.find((n) => n.id === 'commercial-workboats');

const graphJsonLd = node
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema({
          headline: page.seo?.headline || 'Industrial & Technical Textiles — OEM Manufacturing',
          description: page.seo?.description || 'Seekingtex manufactures high-performance fabrics for industrial and technical applications: heavy-duty workwear, protective clothing, specialized performance textiles.',
          datePublished: page.seo?.datePublished || '2024-06-01',
          dateModified: page.seo?.dateModified || '2026-06-01',
          author: 'Seekingtex',
          publisher: 'Seekingtex',
        }),
        {
          '@type': 'Product',
          name: node?.name?.en || 'Industrial & Technical Textiles',
          description: node?.description?.en || 'High-performance fabrics for industrial workwear, protective clothing, and specialized technical applications.',
          brand: { '@type': 'Brand', name: 'Seekingtex' },
          category: 'Industrial & Technical Textiles',
        },
      ],
    }
  : null;
---

<PageLayout>
  <script
    slot="before"
    is:inline
    type="application/ld+json"
    set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''}
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Use Case'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">
      {page.headline || 'Industrial & Technical Textile Solutions'}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">
      {page.subtitle || 'Seekingtex high-performance fabrics for industrial applications, technical textiles, and specialized performance requirements.'}
    </p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''} />
  </section>
</PageLayout>
