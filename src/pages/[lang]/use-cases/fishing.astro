---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { articleSchema } from '~/lib/seo/schema';
import { nodes } from '~/content/graph/nodes';
import { getPageContent } from '~/i18n/page-content';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const page = getPageContent(lang, 'fishing');
const fishingNode = nodes.find((n) => n.id === 'fishing');

const graphJsonLd = fishingNode
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema({
          headline: page.seo?.headline || 'Functional Fabrics for Fashion & Casual Wear: Complete Guide',
          description:
            page.seo?.description ||
            'Learn why functional fabrics are transforming fashion and casual wear — UV protection, quick-dry, cooling, and eco-friendly options for lifestyle apparel.',
          datePublished: page.seo?.datePublished || '2024-03-01',
          dateModified: page.seo?.dateModified || '2026-06-01',
          author: 'Seekingtex',
          publisher: 'Seekingtex',
        }),
        {
          '@type': 'Product',
          name: fishingNode.name.en,
          description: fishingNode.description.en,
          brand: { '@type': 'Brand', name: 'Seekingtex' },
          category: 'Fashion & Casual Fabrics',
        },
      ],
    }
  : null;
---

<PageLayout>
  <script
    slot="before"
    is:inline
    type="application/ld+json"
    set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''}
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Use Case'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">
      {page.headline || 'Functional Fabrics for Fashion & Casual Wear'}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">
      {
        page.subtitle ||
          'Why functional fabrics are becoming the go-to choice for lifestyle brands seeking performance-enhanced everyday apparel.'
      }
    </p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''} />
  </section>
</PageLayout>
