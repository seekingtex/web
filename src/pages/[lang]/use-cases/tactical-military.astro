---
export const prerender = true;

import PageLayout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/i18n/utils';
import { languages } from '~/i18n/config';
import { articleSchema } from '~/lib/seo/schema';
import { nodes } from '~/content/graph/nodes';
import { getPageContent } from '~/i18n/page-content';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const page = getPageContent(lang, 'tactical-military');
const node = nodes.find((n) => n.id === 'tactical-military');

const graphJsonLd = node
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        articleSchema({
          headline: page.seo?.headline || 'Tactical & Workwear Fabrics 鈥?OEM Manufacturing for Duty Professionals',
          description:
            page.seo?.description ||
            'Seekingtex manufactures professional-grade functional fabrics for tactical and workwear applications. Ripstop nylon/cotton, DWR coating, antibacterial treatment.',
          datePublished: page.seo?.datePublished || '2024-06-01',
          dateModified: page.seo?.dateModified || '2026-06-01',
          author: 'Seekingtex',
          publisher: 'Seekingtex',
        }),
        {
          '@type': 'Product',
          name: node?.name?.en || 'Tactical & Workwear Fabrics',
          description:
            node?.description?.en ||
            'Professional-grade functional fabrics designed for tactical and workwear applications.',
          brand: { '@type': 'Brand', name: 'Seekingtex' },
          category: 'Tactical & Workwear Fabrics',
        },
      ],
    }
  : null;
---

<PageLayout>
  <script
    slot="before"
    is:inline
    type="application/ld+json"
    set:html={graphJsonLd ? JSON.stringify(graphJsonLd) : ''}
  />

  <section class="mx-auto max-w-4xl px-6 py-16">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{page.label || 'Use Case'}</span>
    <h1 class="font-semibold text-gray-900 dark:text-gray-100 mt-4 text-4xl">
      {page.headline || 'High-Performance Fabrics for Tactical & Workwear Applications'}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mt-3">
      {
        page.subtitle ||
          'Seekingtex sets the standard for tactical fabrics 鈥?engineered for the uncompromising reliability, durability, and performance that duty professionals demand.'
      }
    </p>

    <div class="mt-12 prose prose-gray dark:prose-invert max-w-none" set:html={page.body || ''} />
  </section>
</PageLayout>
