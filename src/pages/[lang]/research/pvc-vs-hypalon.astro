---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const metadata = {
  title: `Polyester vs Nylon — Technical Comparison for Functional Fabrics | ${SITE.name}`,
  description: `Head-to-head comparison of polyester and nylon for functional fabric construction: durability, moisture management, UV resistance, weight, cost, and application-specific recommendations for uniform, workwear, and performance textiles.`,
  ignoreTitleTemplate: true,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Polyester vs Nylon — Technical Comparison for Functional Fabrics',
  description: metadata.description,
  author: { '@type': 'Organization', name: SITE.name },
  datePublished: '2024-02-10',
  dateModified: '2025-05-15',
};
---

<Layout metadata={metadata}>
  <JsonLd data={jsonLd} />

  <article class="max-w-4xl mx-auto px-6 py-16">
    <nav class="text-sm text-gray-500 mb-8">
      <a href={`/${lang}/`} class="hover:text-sky-600">{SITE.name}</a>
      <span class="mx-2">/</span>
      <a href={`/${lang}/research`} class="hover:text-sky-600">{t('home.research.title')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{t('home.research.pvcHypalon')}</span>
    </nav>

    <div class="mb-4">
      <span class="inline-block text-xs font-semibold uppercase tracking-wider text-sky-600 bg-sky-50 px-3 py-1 rounded-full">Materials</span>
      <span class="ml-3 text-sm text-gray-400">10 min read</span>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 mb-6">{t('home.research.pvcHypalon')}</h1>
    <p class="text-xl text-gray-500 mb-12 leading-relaxed">{t('home.research.pvcHypalon.desc')}</p>

    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-p:text-gray-600 prose-li:text-gray-600">
      <h2>Material Overview</h2>

      <h3>Polyester (PET)</h3>
      <p>
        Polyester is a synthetic fiber used extensively in textile manufacturing. For functional fabrics, high-tenacity polyester (typically 150D – 600D) is the most common choice. Modern polyester formulations include UV stabilizers and moisture-wicking finishes to improve performance in uniform and activewear applications.
      </p>

      <h3>Nylon (Polyamide)</h3>
      <p>
        Nylon is a synthetic polyamide renowned for exceptional strength-to-weight ratio and abrasion resistance. It is the preferred material for high-durability workwear, outdoor gear, and performance textiles that require maximum toughness and elasticity.
      </p>

      <h2>Side-by-Side Comparison</h2>
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-gray-100">
            <th class="p-3 text-left font-semibold text-gray-900 border">Property</th>
            <th class="p-3 text-left font-semibold text-gray-900 border">Polyester</th>
            <th class="p-3 text-left font-semibold text-gray-900 border">Nylon</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="p-3 border font-medium">Tensile strength</td><td class="p-3 border">Good (3–6 g/denier)</td><td class="p-3 border">Excellent (5–9 g/denier)</td></tr>
          <tr><td class="p-3 border font-medium">Abrasion resistance</td><td class="p-3 border">Good</td><td class="p-3 border">Excellent</td></tr>
          <tr><td class="p-3 border font-medium">Moisture management</td><td class="p-3 border">Excellent (hydrophobic)</td><td class="p-3 border">Fair (absorbent)</td></tr>
          <tr><td class="p-3 border font-medium">UV resistance</td><td class="p-3 border">Excellent</td><td class="p-3 border">Fair (requires stabilizers)</td></tr>
          <tr><td class="p-3 border font-medium">Elastic recovery</td><td class="p-3 border">Good</td><td class="p-3 border">Excellent</td></tr>
          <tr><td class="p-3 border font-medium">Chemical resistance</td><td class="p-3 border">Excellent</td><td class="p-3 border">Good</td></tr>
          <tr><td class="p-3 border font-medium">Dyeability</td><td class="p-3 border">Disperse dyes</td><td class="p-3 border">Acid dyes (brighter colors)</td></tr>
          <tr><td class="p-3 border font-medium">Cost (per kg)</td><td class="p-3 border">$2 – $4</td><td class="p-3 border">$4 – $8</td></tr>
          <tr><td class="p-3 border font-medium">Pilling resistance</td><td class="p-3 border">Good</td><td class="p-3 border">Fair to good</td></tr>
        </tbody>
      </table>

      <h2>Which Should You Choose?</h2>

      <h3>Choose Polyester When:</h3>
      <ul>
        <li>Moisture wicking and quick drying are priorities</li>
        <li>The application requires UV resistance for outdoor use</li>
        <li>Cost efficiency is a primary concern</li>
        <li>You need consistent color fastness across production runs</li>
        <li>Easy-care, wrinkle-resistant properties are desired</li>
      </ul>

      <h3>Choose Nylon When:</h3>
      <ul>
        <li>Maximum durability and tear strength are required</li>
        <li>The fabric will face high abrasion (workwear, outdoor gear)</li>
        <li>Excellent elastic recovery is needed for stretch applications</li>
        <li>You are producing high-end performance apparel</li>
        <li>Weight savings are critical (nylon is lighter for the same strength)</li>
      </ul>

      <h2>Manufacturing Differences</h2>
      <p>
        Polyester and nylon require different dyeing processes and finishing treatments. Polyester uses disperse dyes at high temperature and pressure, offering excellent wash fastness. Nylon uses acid dyes that produce brighter colors but may require additional fixation steps. Finishing processes such as water repellency and antimicrobial treatments work effectively on both substrates.
      </p>

      <h2>Seekingtex Recommendation</h2>
      <p>
        For most uniform and workwear applications, high-quality polyester offers the best balance of cost, performance, and durability. Seekingtex uses high-tenacity polyester with UV stabilizers and moisture-wicking finishes for its standard product lines. For clients requiring maximum abrasion resistance and strength, we offer nylon-based fabrics with customized finishes.
      </p>
    </div>

    <div class="mt-16 pt-8 border-t border-gray-200">
      <a href={`/${lang}/research`} class="text-sky-600 hover:text-sky-700 font-medium">&larr; {t('home.research.tagline')}</a>
    </div>
  </article>
</Layout>
