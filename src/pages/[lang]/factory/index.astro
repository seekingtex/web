---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'factory');

const hero = page.hero ?? {};
const intro = page.intro ?? [];
const stats = page.stats ?? [];
const workshopsSection = page.workshops_section ?? {};
const workshops = workshopsSection.workshops ?? [];
const equipmentSection = page.equipment_section ?? {};
const equipment = equipmentSection.items ?? [];
const processCta = page.process_cta ?? {};

const flowSection = page.production_flow ?? {};
const stages = flowSection.stages ?? [];
const workforceSection = page.workforce ?? {};
const departments = workforceSection.departments ?? [];
const traceSection = page.material_traceability ?? {};
const suppliers = traceSection.suppliers ?? [];
const qcDash = page.qc_dashboard ?? {};
const qcDashStats = qcDash.stats ?? [];

const metadata = {
  title: `Textile Factory & OEM/ODM Manufacturer — ${SITE.name}`,
  description: `${SITE.name} operates a 12,000 m²  & ISO-certified textile factory in Qingdao, China. OEM/ODM manufacturing of functional fabrics, performance textiles, industrial fabrics. MOQ 500 meters, lead time 30 days. Bulk wholesale & private label.`,
};
const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'Factory' }];

const renderIntro = (text) => text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{SITE.name}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">{hero.title}</h1>
    <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-4xl">
    {
      intro.map((p, i) => (
        <p class="text-muted leading-relaxed" class:list={{ 'mt-6': i > 0 }} set:html={renderIntro(p)} />
      ))
    }
  </section>

  <section class="px-6 sm:px-6 pb-8 mx-auto max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {
        stats.map((s) => (
          <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
            <span class="block text-3xl font-bold text-primary">{s.value}</span>
            <span class="text-sm text-muted mt-1">{s.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{workshopsSection.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{workshopsSection.title}</h2>
    </div>
    <div class="space-y-8">
      {
        workshops.map((w, i) => (
          <div
            class={`grid md:grid-cols-2 gap-8 items-center ${i % 2 === 1 ? 'md:direction-rtl' : ''}`}
            style={i % 2 === 1 ? 'direction: rtl;' : ''}
          >
            <div class={i % 2 === 1 ? 'direction: ltr;' : ''}>
              <h3 class="text-xl font-bold">{w.title}</h3>
              <p class="mt-3 text-muted leading-relaxed">{w.description}</p>
            </div>
            <div class={i % 2 === 1 ? 'direction: ltr;' : ''}>
              <img src={w.image} alt={w.title} class="w-full h-64 object-cover rounded-xl" loading="lazy" />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-5xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">B2B Information</p>
      <h2 class="mt-2 text-3xl font-bold">Manufacturing & Trade Terms</h2>
      <p class="mt-2 text-muted max-w-2xl mx-auto">
        Seekingtex is a brand of <strong>Qingdao Vatrad Group Co., Ltd.</strong> — &amp; ISO certified, with 10+ years of
        export experience.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">MOQ</h3>
        <p class="mt-2 text-sm text-muted">{page.b2b_moq}</p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">Lead Time</h3>
        <p class="mt-2 text-sm text-muted">
          Standard production: 30–45 days from order confirmation. Sample/prototype lead time: 15–20 days. Rush orders
          available.
        </p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">Payment Terms</h3>
        <p class="mt-2 text-sm text-muted">
          T/T 30% deposit, 70% before shipment. L/C, Western Union, and PayPal available for qualifying partners. Net
          terms negotiable.
        </p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">Shipping & Logistics</h3>
        <p class="mt-2 text-sm text-muted">
          FOB Qingdao, CIF, DDP available. In-house freight team handles container loading, documentation, and customs
          clearance for smooth delivery worldwide.
        </p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">Certifications</h3>
        <p class="mt-2 text-sm text-muted">
          quality management. OEKO-TEX Standard 100 certification on all standard fabric lines. Factory audit reports
          available.
        </p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
        <h3 class="font-bold text-lg">Quality Assurance</h3>
        <p class="mt-2 text-sm text-muted">
          100% visual and dimensional inspection on every batch. Tensile, color fastness, and GSM testing on every
          production lot. Third-party inspection (SGS/BV) accepted before shipment.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-6xl bg-gray-50 dark:bg-gray-900 rounded-2xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{equipmentSection.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{equipmentSection.title}</h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {
        equipment.map((eq) => (
          <div class="flex items-center justify-between p-4 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800">
            <span class="font-medium">{eq.name}</span>
            <span class="text-sm text-muted">{eq.spec}</span>
          </div>
        ))
      }
    </div>
    <div class="text-center mt-8">
      <a
        href={`/${lang}${equipmentSection.view_full_link || '/factory/equipment'}`}
        class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
      >
        {equipmentSection.view_full || 'View full equipment list →'}
      </a>
    </div>
  </section>

  <!-- Production Flow with QC Checkpoints -->
  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">
        {flowSection.tagline || 'Production Flow'}
      </p>
      <h2 class="mt-2 text-3xl font-bold">{flowSection.title || 'From Yarn to Finished Fabric'}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">
        {
          flowSection.subtitle ||
            'Every fabric batch passes through 6 production stages with QC checkpoints at every step.'
        }
      </p>
    </div>
    <div class="space-y-6">
      {
        stages.map((f) => (
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden">
            <div class="grid md:grid-cols-5 gap-0">
              <div class="md:col-span-2 p-6 bg-gray-50 dark:bg-gray-950 border-r border-gray-200 dark:border-gray-800">
                <div class="flex items-center gap-3 mb-3">
                  <span class="w-10 h-10 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center text-lg font-bold text-sky-600 shrink-0">
                    {f.stage}
                  </span>
                  <h3 class="text-lg font-bold">{f.title}</h3>
                </div>
                <p class="text-sm text-muted leading-relaxed">{f.description}</p>
              </div>
              <div class="md:col-span-3 p-6">
                <div class="mb-3">
                  <span class="text-xs font-bold text-sky-600 uppercase tracking-wider">QC Checkpoint</span>
                  <p class="mt-1 text-sm text-gray-700 dark:text-gray-300">{f.qc_check}</p>
                </div>
                <div>
                  <span class="text-xs font-bold text-amber-600 uppercase tracking-wider">Pass / Fail Threshold</span>
                  <p class="mt-1 text-sm text-gray-700 dark:text-gray-300">{f.qc_threshold}</p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Workforce Details -->
  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl bg-gray-50 dark:bg-gray-900 rounded-2xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">
        {workforceSection.tagline || 'Our People'}
      </p>
      <h2 class="mt-2 text-3xl font-bold">{workforceSection.title || 'Workforce & Expertise'}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">
        {
          workforceSection.engineers_detail ||
            '25+ textile engineers, average 7+ years in textile manufacturing. 2 shifts/day with optional night shift.'
        }
      </p>
    </div>
    <div class="grid md:grid-cols-4 gap-6">
      {
        departments.map((d) => (
          <div class="p-5 rounded-xl bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800">
            <div class="text-2xl font-bold text-sky-600">{d.count}</div>
            <h3 class="mt-1 font-semibold">{d.name}</h3>
            <p class="mt-1 text-xs text-muted">{d.role}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- QC Dashboard -->
  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{qcDash.tagline || 'QC by the Numbers'}</p>
      <h2 class="mt-2 text-3xl font-bold">{qcDash.title || 'Quality Control Metrics'}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">
        {qcDash.subtitle || 'Real pass/fail data from our production line.'}
      </p>
    </div>
    <div class="grid md:grid-cols-3 lg:grid-cols-6 gap-6">
      {
        qcDashStats.map((s) => (
          <div class="text-center p-6 rounded-xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
            <div class="text-3xl font-bold text-sky-600">{s.value}</div>
            <div class="mt-2 text-sm font-semibold">{s.label}</div>
            <p class="mt-1 text-xs text-muted">{s.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Material Traceability -->
  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl bg-gray-50 dark:bg-gray-900 rounded-2xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">
        {traceSection.tagline || 'Traceability'}
      </p>
      <h2 class="mt-2 text-3xl font-bold">{traceSection.title || 'Material Tracking & Batch Control'}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">
        {
          traceSection.description ||
            'Every batch of raw material is assigned a unique lot number. Full upstream traceability for any quality or compliance inquiry.'
        }
      </p>
    </div>
    <div class="max-w-3xl mx-auto space-y-3 mb-8">
      <div
        class="flex items-center justify-between p-3 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800"
      >
        <span class="text-sm font-medium">Tracking system</span>
        <span class="text-sm text-muted">{traceSection.system || 'Custom ERP + batch tags'}</span>
      </div>
      <div
        class="flex items-center justify-between p-3 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800"
      >
        <span class="text-sm font-medium">Coverage</span>
        <span class="text-sm text-muted">{traceSection.coverage || '100% of production materials'}</span>
      </div>
      <div
        class="flex items-center justify-between p-3 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800"
      >
        <span class="text-sm font-medium">Records retained</span>
        <span class="text-sm text-muted">{traceSection.records_retained || '10 years'}</span>
      </div>
    </div>
    <div class="max-w-3xl mx-auto">
      <h3 class="text-sm font-semibold text-sky-600 uppercase tracking-wider mb-3">Supplier Material Certifications</h3>
      <div class="grid md:grid-cols-2 gap-3">
        {
          suppliers.map((s) => (
            <div class="p-4 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800">
              <div class="font-semibold text-sm">{s.material}</div>
              <div class="text-xs text-muted mt-1">{s.source}</div>
              <div class="text-xs text-muted">{s.certified}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">{processCta.title}</h2>
      <p class="mt-2 text-sm text-muted">{processCta.desc}</p>
      <a
        href={`/${lang}${processCta.link || '/factory/process'}`}
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
      >
        {processCta.label || 'View production process →'}
      </a>
    </div>
  </section>
</Layout>
