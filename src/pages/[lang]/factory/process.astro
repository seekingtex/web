---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'factory-process');

const hero = page.hero ?? {};
const intro = page.intro ?? '';
const steps = page.steps ?? [];
const cta = page.cta ?? {};

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: 'Factory', href: `/${lang}/factory` },
  { name: hero.title },
];

const metadata = {
  title: `Manufacturing Process — From Raw Material to Finished Boat | ${SITE.name}`,
  description: `${SITE.name} manufacturing process: material inspection, PVC automatic cutting, fiberglass lay-up, heat sealing, SUP digital printing, assembly, quality testing, and shipping.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 mx-auto max-w-5xl">
    <a href={`/${lang}${hero.back_link || '/factory'}`} class="text-sm text-gray-500 hover:underline"
      >&larr; {hero.back_label || 'Back to Factory'}</a
    >
    <div class="mt-4 max-w-3xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{hero.tagline}</p>
      <h1 class="mt-2 text-3xl md:text-4xl font-bold">{hero.title}</h1>
      <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl">
    <p class="text-muted leading-relaxed mb-12">
      {intro}
    </p>

    <div class="space-y-10">
      {
        steps.map((s) => (
          <div class="relative pl-16">
            <div class="absolute left-0 top-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold">
              {s.step}
            </div>
            <div class="border-l-2 border-gray-200 dark:border-gray-700 pl-8 pb-2">
              <div class="flex items-start justify-between gap-4">
                <h2 class="text-xl font-bold">{s.title}</h2>
                <span class="text-xs text-muted whitespace-nowrap shrink-0 mt-1">{s.duration}</span>
              </div>
              <p class="mt-2 text-muted leading-relaxed">{s.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">{cta.title}</h2>
      <p class="mt-2 text-sm text-muted">{cta.desc}</p>
      <a
        href={`/${lang}${cta.link || '/factory/equipment'}`}
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
      >
        {cta.label || 'View equipment →'}
      </a>
    </div>
  </section>
</Layout>
