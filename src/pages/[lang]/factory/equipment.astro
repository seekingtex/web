---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const page = getPageContent(lang, 'factory-equipment') || {};
const hero = page.hero || {};
const categories = page.categories || [];
const cta = page.cta || {};

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: 'Factory', href: `/${lang}/factory` },
  { name: hero.tagline || 'Equipment' },
];

const metadata = {
  title: `Manufacturing Equipment — Weaving, Coating, Dyeing & Finishing | ${SITE.name}`,
  description: `${SITE.name} factory equipment: automatic weaving machines, coating lines, dyeing equipment, digital printers for fabrics, finishing machines, and test rigs.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 mx-auto max-w-5xl">
    <a href={`/${lang}${hero.back_link}`} class="text-sm text-gray-500 hover:underline">&larr; {hero.back_label}</a>
    <div class="mt-4 max-w-3xl">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{hero.tagline}</p>
      <h1 class="mt-2 text-3xl md:text-4xl font-bold">{hero.title}</h1>
      <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-5xl space-y-16">
    {
      categories.map((cat) => (
        <div>
          <h2 class="text-2xl font-bold mb-6">{cat.title}</h2>
          <div class="grid gap-4">
            {cat.items.map((eq) => (
              <div class="p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h3 class="font-bold">{eq.name}</h3>
                    <p class="text-sm text-primary font-medium mt-0.5">{eq.spec}</p>
                    <p class="text-sm text-muted mt-2">{eq.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">{cta.title}</h2>
      <p class="mt-2 text-sm text-muted">{cta.desc}</p>
      <a
        href={`/${lang}${cta.link}`}
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
      >
        {cta.label}
      </a>
    </div>
  </section>
</Layout>
