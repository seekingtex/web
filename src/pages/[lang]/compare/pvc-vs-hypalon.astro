---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const metadata = {
  title: `${t('compare.pvcVsHypalon.title') || 'PVC vs Hypalon — Which Coated Fabric Is Better?'}`,
  description:
    t('compare.pvcVsHypalon.desc') ||
    'Compare PVC and Hypalon CSM coated fabrics across durability, UV resistance, cost, repairability, and lifespan.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <JsonLd
    type="Article"
    article={{
      headline: t('compare.pvcVsHypalon.headline') || 'PVC vs Hypalon — Which Coated Fabric Is Better?',
      description:
        t('compare.pvcVsHypalon.desc') ||
        'Compare PVC and Hypalon CSM coated fabrics across durability, UV resistance, cost, repairability, and lifespan.',
      datePublished: '2026-07-07',
    }}
    data={{ url: `https://seekingtex.com/${lang}/compare/pvc-vs-hypalon` }}
  />
  <JsonLd
    type="BreadcrumbList"
    breadcrumbs={[
      { name: t('home') || 'Home', href: `/${lang}/` },
      { name: t('compare.label') || 'Compare', href: `/${lang}/compare` },
      { name: t('compare.pvcVsHypalon.short') || 'PVC vs Hypalon' },
    ]}
  />
  <section class="max-w-4xl mx-auto py-24 px-6">
    <a href={`/${lang}/products`} class="text-sm text-sky-600 hover:text-sky-700"
      >&larr; {t('compare.backToProducts') || 'Products'}</a
    >
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">
      {t('compare.pvcVsHypalon.heading') || 'PVC vs Hypalon Coated Fabric'}
    </h1>
    <p class="mt-4 text-lg text-gray-500">
      {
        t('compare.pvcVsHypalon.subtitle') ||
          'The definitive comparison between PVC (polyvinyl chloride) and Hypalon CSM (chlorosulfonated polyethylene) — two dominant coated fabrics used in industrial textile applications worldwide.'
      }
    </p>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">{t('compare.pvcVsHypalon.col1Title') || 'PVC Fabric'}</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.cost') || 'Cost:'}</strong>
              {
                t('compare.pvcVsHypalon.costDesc') ||
                  '30-50% cheaper than Hypalon. Most affordable coated fabric on the market.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.weight') || 'Weight:'}</strong>
              {
                t('compare.pvcVsHypalon.weightDesc') ||
                  'Lighter than Hypalon. Easier to carry, pack, and transport when deflated.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.repair') || 'Repairability:'}</strong>
              {
                t('compare.pvcVsHypalon.repairDesc') ||
                  'Excellent. PVC patches bond easily with standard PVC glue or solvent welding.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.weld') || 'Weld Type:'}</strong>
              {
                t('compare.pvcVsHypalon.weldDesc') ||
                  'High-frequency (RF) welding creates strong, consistent seams. Fusion bonding available.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.bestFor') || 'Best for:'}</strong>
              {
                t('compare.pvcVsHypalon.bestForDesc') ||
                  'Industrial textiles, protective covers, inflatable structures, budget-friendly applications, seasonal use.'
              }</span>
          </li>
        </ul>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">
          {t('compare.pvcVsHypalon.col2Title') || 'Hypalon CSM Rubber'}
        </h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.cost') || 'Cost:'}</strong>
              {
                t('compare.pvcVsHypalon.hypalonCostDesc') ||
                  'Premium material. Significantly more expensive than PVC across all boat sizes.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.weight') || 'Weight:'}</strong>
              {
                t('compare.pvcVsHypalon.hypalonWeightDesc') ||
                  'Heavier than PVC. Less portable but more robust in demanding conditions.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.repair') || 'Repairability:'}</strong>
              {
                t('compare.pvcVsHypalon.hypalonRepairDesc') ||
                  'Moderate. Requires two-part adhesive (glue). Repair patches need careful preparation.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.construction') || 'Construction:'}</strong>
              {
                t('compare.pvcVsHypalon.constructionDesc') ||
                  'Hand-glued seams or chemical bonding. No RF welding possible with Hypalon.'
              }</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span
              ><strong>{t('compare.pvcVsHypalon.bestFor') || 'Best for:'}</strong>
              {
                t('compare.pvcVsHypalon.hypalonBestDesc') ||
                  'Premium industrial textiles, commercial applications, harsh environments, tropical climates, long-term use.'
              }</span>
          </li>
        </ul>
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">
        {t('compare.pvcVsHypalon.tableTitle') || 'Side-by-Side Comparison'}
      </h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b-2 border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">{t('compare.factor') || 'Factor'}</th>
              <th class="px-4 py-3 text-center font-semibold text-sky-700"
                >{t('compare.pvcVsHypalon.pvcShort') || 'PVC'}</th
              >
              <th class="px-4 py-3 text-center font-semibold text-emerald-700"
                >{t('compare.pvcVsHypalon.hypalonShort') || 'Hypalon CSM'}</th
              >
            </tr>
          </thead>
          <tbody>
            {
              [
                [
                  t('compare.pvcVsHypalon.r1') || 'Relative Cost',
                  t('compare.pvcVsHypalon.r1a') || '$ (budget-friendly)',
                  t('compare.pvcVsHypalon.r1b') || '$$$ (premium)',
                ],
                [
                  t('compare.pvcVsHypalon.r2') || 'Weight per m²',
                  t('compare.pvcVsHypalon.r2a') || '600-900 g/m²',
                  t('compare.pvcVsHypalon.r2b') || '1100-1500 g/m²',
                ],
                [
                  t('compare.pvcVsHypalon.r3') || 'UV Resistance',
                  t('compare.pvcVsHypalon.r3a') || 'Good (with UV coating)',
                  t('compare.pvcVsHypalon.r3b') || 'Excellent (inherent)',
                ],
                [
                  t('compare.pvcVsHypalon.r4') || 'Chemical Resistance',
                  t('compare.pvcVsHypalon.r4a') || 'Good',
                  t('compare.pvcVsHypalon.r4b') || 'Excellent (oil, fuel, acid)',
                ],
                [
                  t('compare.pvcVsHypalon.r5') || 'Abrasion Resistance',
                  t('compare.pvcVsHypalon.r5a') || 'Moderate',
                  t('compare.pvcVsHypalon.r5b') || 'Excellent',
                ],
                [
                  t('compare.pvcVsHypalon.r6') || 'Cold Flexibility',
                  t('compare.pvcVsHypalon.r6a') || 'Stiffens below 0°C',
                  t('compare.pvcVsHypalon.r6b') || 'Flexible to -20°C',
                ],
                [
                  t('compare.pvcVsHypalon.r7') || 'Lifespan (typical)',
                  t('compare.pvcVsHypalon.r7a') || '8-12 years',
                  t('compare.pvcVsHypalon.r7b') || '15-20+ years',
                ],
                [
                  t('compare.pvcVsHypalon.r8') || 'Color Retention',
                  t('compare.pvcVsHypalon.r8a') || 'Fades over time',
                  t('compare.pvcVsHypalon.r8b') || 'Excellent long-term',
                ],
                [
                  t('compare.pvcVsHypalon.r9') || 'Seam Strength',
                  t('compare.pvcVsHypalon.r9a') || 'RF weld = very strong',
                  t('compare.pvcVsHypalon.r9b') || 'Glued = good',
                ],
                [
                  t('compare.pvcVsHypalon.r10') || 'Ease of Repair',
                  t('compare.pvcVsHypalon.r10a') || 'Easy (PVC glue)',
                  t('compare.pvcVsHypalon.r10b') || 'Moderate (2-part adhesive)',
                ],
                [
                  t('compare.pvcVsHypalon.r11') || 'Temperature Range',
                  t('compare.pvcVsHypalon.r11a') || '-10°C to 50°C',
                  t('compare.pvcVsHypalon.r11b') || '-20°C to 70°C',
                ],
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                  {row.map((cell, j) => (
                    <td
                      class={`px-4 py-3 border-b border-gray-200 ${j === 0 ? 'font-medium text-gray-700' : 'text-center text-gray-600'}`}
                    >
                      {cell}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-16 bg-gradient-to-br from-sky-50 to-blue-50 rounded-2xl p-8 border border-sky-200">
      <h2 class="text-xl font-semibold text-gray-900">
        {t('compare.pvcVsHypalon.recTitle') || 'Which Should You Choose?'}
      </h2>
      <p class="mt-4 text-gray-600 text-sm leading-relaxed">
        {
          t('compare.pvcVsHypalon.recDesc') ||
            'Choose PVC if you need an affordable, lightweight coated fabric for general industrial applications. Modern PVC-coated fabrics offer excellent durability for most users at half the cost of Hypalon. Choose Hypalon if you operate in harsh environments with extreme UV exposure, need chemical/oil resistance, or require fabric longevity of 15+ years.'
        }
      </p>
      <div class="mt-6 flex gap-4 flex-wrap">
        <a
          href={`/${lang}/products`}
          class="px-6 py-3 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition"
          >{t('compare.browseProducts') || 'Browse Products'}</a
        >
        <a
          href={`/${lang}/learn/pvc-vs-hypalon`}
          class="px-6 py-3 border border-gray-200 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition"
          >{t('compare.pvcVsHypalon.learnMore') || 'In-Depth Material Guide'}</a
        >
      </div>
    </section>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>
      {
        t('compare.pvcVsHypalon.aiBlock') ||
          'Comprehensive comparison between PVC and Hypalon CSM coated fabrics used in industrial textile applications. Covers cost, weight, UV resistance, chemical resistance, abrasion resistance, cold flexibility, lifespan, color retention, seam strength, repairability, and temperature tolerance. PVC offers 30-50% lower cost, lighter weight, RF-welded seams, easy repair, and 8-12 year lifespan. Hypalon offers superior UV/chemical resistance, cold flexibility to -20°C, 15-20+ year lifespan, but requires glued seams and 2-part adhesive for repairs.'
      }
    </p>
  </section>
</Layout>
