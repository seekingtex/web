---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const metadata = {
  title: `${t('compare.ribVsDinghy.title') || 'Woven vs Knit Fabric — Which Textile Is Right for You?'}`,
  description: t('compare.ribVsDinghy.desc') || 'Compare woven and knit fabrics across stretch, durability, breathability, application, and use cases. Find the right textile construction for your needs.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <JsonLd
    type="Article"
    article={{
      headline: t('compare.ribVsDinghy.headline') || 'Woven vs Knit Fabric — Which Textile Is Right for You?',
      description: t('compare.ribVsDinghy.desc') || 'Compare woven and knit fabrics across stretch, durability, breathability, application, and use cases.',
      datePublished: '2026-07-07',
    }}
    data={{ url: `https://seekingtex.com/${lang}/compare/rib-vs-dinghy` }}
  />
  <JsonLd type="BreadcrumbList" breadcrumbs={[{ name: t('home') || 'Home', href: `/${lang}/` }, { name: t('compare.label') || 'Compare', href: `/${lang}/compare` }, { name: t('compare.ribVsDinghy.short') || 'Woven vs Knit' }]} />
  <section class="max-w-4xl mx-auto py-24 px-6">
    <a href={`/${lang}/products`} class="text-sm text-sky-600 hover:text-sky-700">&larr; {t('compare.backToProducts') || 'Products'}</a>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">{t('compare.ribVsDinghy.heading') || 'Woven vs Knit Fabric'}</h1>
    <p class="mt-4 text-lg text-gray-500">{t('compare.ribVsDinghy.subtitle') || 'A practical comparison between woven and knit fabric constructions to help you choose the right textile for your application.'}</p>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">{t('compare.ribVsDinghy.col1Title') || 'Woven Fabric'}</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.hull') || 'Construction:'}</strong> {t('compare.ribVsDinghy.hullDesc') || 'Two sets of yarns (warp and weft) interlaced at right angles. Creates a stable, structured fabric with minimal stretch.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.performance') || 'Strength:'}</strong> {t('compare.ribVsDinghy.performanceDesc') || 'High tensile strength in both warp and weft directions. Excellent dimensional stability. Resists stretching and distortion.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.durability') || 'Durability:'}</strong> {t('compare.ribVsDinghy.durabilityDesc') || 'Very durable. Withstands repeated washing and wear. Higher yarn density provides better abrasion resistance.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.capacity') || 'Applications:'}</strong> {t('compare.ribVsDinghy.capacityDesc') || 'Shirting, denim, dress fabrics, upholstery, industrial textiles, outdoor gear, uniforms, workwear.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-sky-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.bestFor') || 'Best for:'}</strong> {t('compare.ribVsDinghy.bestForDesc') || 'Structured garments, formal wear, home textiles, technical fabrics requiring dimensional stability, industrial applications.'}</span></li>
        </ul>
      </div>
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-semibold text-gray-900">{t('compare.ribVsDinghy.col2Title') || 'Knit Fabric'}</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.hull') || 'Construction:'}</strong> {t('compare.ribVsDinghy.dinghyHullDesc') || 'Interlocking loops of yarn. Stretches in both directions. Loop structure provides natural elasticity and recovery.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.performance') || 'Stretch & Comfort:'}</strong> {t('compare.ribVsDinghy.dinghyPerfDesc') || 'Excellent stretch (15-40% depending on knit type). Conforms to body shape. Superior comfort for active wear and fitted garments.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.durability') || 'Durability:'}</strong> {t('compare.ribVsDinghy.dinghyDurDesc') || 'Moderate durability. Prone to snagging and runs. May pill with wear. Less dimensionally stable than woven.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.portability') || 'Applications:'}</strong> {t('compare.ribVsDinghy.dinghyPortDesc') || 'T-shirts, sportswear, activewear, undergarments, hosiery, sweaters, casual apparel, medical compression textiles.'}</span></li>
          <li class="flex items-start gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></span><span><strong>{t('compare.ribVsDinghy.bestFor') || 'Best for:'}</strong> {t('compare.ribVsDinghy.dinghyBestDesc') || 'Comfort-focused apparel, sportswear and activewear, body-hugging garments, stretch requirements, casual everyday wear.'}</span></li>
        </ul>
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">{t('compare.ribVsDinghy.tableTitle') || 'Side-by-Side Comparison'}</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b-2 border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">{t('compare.factor') || 'Factor'}</th>
              <th class="px-4 py-3 text-center font-semibold text-sky-700">{t('compare.ribVsDinghy.ribShort') || 'Woven'}</th>
              <th class="px-4 py-3 text-center font-semibold text-emerald-700">{t('compare.ribVsDinghy.dinghyShort') || 'Knit'}</th>
            </tr>
          </thead>
          <tbody>
            {[
              [t('compare.ribVsDinghy.r1') || 'Construction', t('compare.ribVsDinghy.r1a') || 'Warp and weft interlacing', t('compare.ribVsDinghy.r1b') || 'Interlocking loops'],
              [t('compare.ribVsDinghy.r2') || 'Stretch', t('compare.ribVsDinghy.r2a') || 'Minimal (bias direction only)', t('compare.ribVsDinghy.r2b') || 'High (15-40% both directions)'],
              [t('compare.ribVsDinghy.r3') || 'Tensile Strength', t('compare.ribVsDinghy.r3a') || 'High', t('compare.ribVsDinghy.r3b') || 'Moderate'],
              [t('compare.ribVsDinghy.r4') || 'Breathability', t('compare.ribVsDinghy.r4a') || 'Moderate to good', t('compare.ribVsDinghy.r4b') || 'Excellent (loop structure)'],
              [t('compare.ribVsDinghy.r5') || 'Abrasion Resistance', t('compare.ribVsDinghy.r5a') || 'Excellent', t('compare.ribVsDinghy.r5b') || 'Good'],
              [t('compare.ribVsDinghy.r6') || 'Dimensional Stability', t('compare.ribVsDinghy.r6a') || 'Excellent', t('compare.ribVsDinghy.r6b') || 'Moderate (may sag)'],
              [t('compare.ribVsDinghy.r7') || 'Elastic Recovery', t('compare.ribVsDinghy.r7a') || 'Poor', t('compare.ribVsDinghy.r7b') || 'Excellent'],
              [t('compare.ribVsDinghy.r8') || 'Production Speed', t('compare.ribVsDinghy.r8a') || 'Slower (loom weaving)', t('compare.ribVsDinghy.r8b') || 'Faster (circular knitting)'],
              [t('compare.ribVsDinghy.r9') || 'Cost', t('compare.ribVsDinghy.r9a') || 'Moderate to high', t('compare.ribVsDinghy.r9b') || 'Low to moderate'],
              [t('compare.ribVsDinghy.r10') || 'Pilling Tendency', t('compare.ribVsDinghy.r10a') || 'Low', t('compare.ribVsDinghy.r10b') || 'Moderate to high'],
              [t('compare.ribVsDinghy.r11') || 'Edge Fraying', t('compare.ribVsDinghy.r11a') || 'Yes (requires hemming)', t('compare.ribVsDinghy.r11b') || 'No (knit does not unravel from edges)'],
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                {row.map((cell, j) => (
                  <td class={`px-4 py-3 border-b border-gray-200 ${j === 0 ? 'font-medium text-gray-700' : 'text-center text-gray-600'}`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-16 bg-gradient-to-br from-sky-50 to-blue-50 rounded-2xl p-8 border border-sky-200">
      <h2 class="text-xl font-semibold text-gray-900">{t('compare.ribVsDinghy.recTitle') || 'Which Should You Choose?'}</h2>
      <p class="mt-4 text-gray-600 text-sm leading-relaxed">{t('compare.ribVsDinghy.recDesc') || 'Choose woven fabric when you need durability, dimensional stability, and a structured feel for uniforms, upholstery, outerwear, or technical industrial applications. Choose knit fabric when comfort, stretch, and breathability are the priority for sportswear, casual apparel, undergarments, or any application requiring body conformance. Many textile products combine both — woven shells for structure and knit linings for comfort.'}</p>
      <div class="mt-6 flex gap-4 flex-wrap">
        <a href={`/${lang}/products`} class="px-6 py-3 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition">{t('compare.browseProducts') || 'Browse Products'}</a>
        <a href={`/${lang}/guides`} class="px-6 py-3 border border-gray-200 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition">{t('compare.buyingGuides') || 'Buying Guides'}</a>
      </div>
    </section>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>{t('compare.ribVsDinghy.aiBlock') || 'Comprehensive comparison between woven and knit fabric constructions. Woven fabrics feature warp and weft yarns interlaced at right angles, offering high tensile strength, excellent dimensional stability, low stretch, high abrasion resistance, low pilling, but require hemming to prevent fraying. Knit fabrics feature interlocking loop structures, offering high stretch (15-40%), excellent breathability, superior elastic recovery, faster production speeds, lower cost, no edge fraying, but are prone to snagging and pilling and have less dimensional stability.'}</p>
  </section>
</Layout>
