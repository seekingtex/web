---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { getProducts } from '~/utils/products';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'size-guide') || {};
const hero = page.hero || {};
const categoriesText = page.categories || {};
const tableHeaders = page.table?.headers || {};
const howToChoose = page.how_to_choose || {};

const metadata = {
  title: `Size Guide —${SITE.name}`,
  description:
    'Find the right fabric specification for your needs. Compare GSM, composition, weight, width, and recommended uses.',
};

const products = await getProducts();

const getSpec = (p: (typeof products)[number], label: string) => {
  const s = p.specs?.find((s) => s.label.toLowerCase().includes(label.toLowerCase()));
  return s?.value || '-';
};
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto py-24 px-6">
    <h1 class="text-4xl font-semibold text-gray-900">{hero.title || 'Size & Specs Guide'}</h1>
    <p class="mt-4 text-lg text-gray-500">
      {hero.subtitle || 'Specifications, properties, and recommended uses for every Seekingtex fabric.'}
    </p>

    <div class="mt-12 space-y-16">
      {
        (['woven', 'knit', 'coated'] as const).map((cat) => {
          const catProducts = products.filter((p) => p.category === (cat as any));
          if (catProducts.length === 0) return null;
          const catLabel = catProducts[0]?.categoryLabel || cat;
          return (
            <section>
              <h2 class="text-2xl font-semibold text-gray-900 mb-2">{catLabel}</h2>
              <p class="text-gray-500 mb-6">{categoriesText[cat] || ''}</p>
              <div class="overflow-x-auto">
                <table class="w-full text-sm border-collapse">
                  <thead>
                    <tr class="bg-gray-50">
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.product || 'Product'}
                      </th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.length || 'Length'}
                      </th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.width || 'Width'}
                      </th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.weight || 'Weight'}
                      </th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.max_load || 'Max Load'}
                      </th>
                      <th class="px-4 py-3 text-left font-semibold text-gray-900 border-b border-gray-200">
                        {tableHeaders.best_for || 'Best For'}
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {catProducts.map((p, i) => (
                      <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
                        <td class="px-4 py-3 font-medium text-gray-900 border-b border-gray-200">
                          <a href={`/${lang}/products/${p.slug}`} class="hover:text-sky-600">
                            {p.title}
                          </a>
                        </td>
                        <td class="px-4 py-3 text-gray-600 border-b border-gray-200">{getSpec(p, 'length')}</td>
                        <td class="px-4 py-3 text-gray-600 border-b border-gray-200">{getSpec(p, 'width')}</td>
                        <td class="px-4 py-3 text-gray-600 border-b border-gray-200">{getSpec(p, 'weight')}</td>
                        <td class="px-4 py-3 text-gray-600 border-b border-gray-200">
                          {getSpec(p, 'load') || getSpec(p, 'capacity') || '-'}
                        </td>
                        <td class="px-4 py-3 text-gray-600 border-b border-gray-200">{p.summary || '-'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          );
        })
      }
    </div>

    <section class="mt-16 p-6 bg-sky-50 rounded-2xl border border-sky-100">
      <h2 class="text-xl font-semibold text-gray-900">{howToChoose.title || 'How to Choose the Right Fabric'}</h2>
      <div class="mt-4 grid md:grid-cols-3 gap-6">
        {
          (howToChoose.cards || []).map((card: any) => (
            <div>
              <h3 class="font-medium text-gray-900">{card.title}</h3>
              <p class="mt-2 text-sm text-gray-600">{card.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="sr-only" data-ai-block="definition" aria-hidden="true">
      <p>
        Seekingtex fabric specification guide comparing GSM, composition, width, weight, and recommended uses across
        woven, knit, and coated fabric categories.
      </p>
    </section>
  </section>
</Layout>
