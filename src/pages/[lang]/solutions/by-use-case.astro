---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { defaultLang, ui } from '~/i18n/config';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

const { lang = defaultLang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const metadata = {
  title: `${t('solutionsByUseCase.title')} | ${SITE.name}`,
  description: t('solutionsByUseCase.desc'),
  ignoreTitleTemplate: true,
};

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: t('solutionsByUseCase.title') },
];

const scenarios = [
  { scenario: t('solutionsByUseCase.scenario1'), icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z', answer: t('solutionsByUseCase.answer1'), cta: { text: t('solutionsByUseCase.cta1'), link: `/${lang}/tactical-military` } },
  { scenario: t('solutionsByUseCase.scenario2'), icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', answer: t('solutionsByUseCase.answer2'), cta: { text: t('solutionsByUseCase.cta2'), link: `/${lang}/products` } },
  { scenario: t('solutionsByUseCase.scenario3'), icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', answer: t('solutionsByUseCase.answer3'), cta: { text: t('solutionsByUseCase.cta3'), link: `/${lang}/oem-odm-manufacturer` } },
  { scenario: t('solutionsByUseCase.scenario4'), icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', answer: t('solutionsByUseCase.answer4'), cta: { text: t('solutionsByUseCase.cta4'), link: `/${lang}/oem-odm-manufacturer` } },
  { scenario: t('solutionsByUseCase.scenario5'), icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 12.5V17a2 2 0 01-2 2H6a2 2 0 01-2-2V9a2 2 0 012-2h3.5a2 2 0 012 2v.5', answer: t('solutionsByUseCase.answer5'), cta: { text: t('solutionsByUseCase.cta5'), link: `/${lang}/medical-healthcare` } },
  { scenario: t('solutionsByUseCase.scenario6'), icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', answer: t('solutionsByUseCase.answer6'), cta: { text: t('solutionsByUseCase.cta6'), link: `/${lang}/industrial-textiles` } },
  { scenario: t('solutionsByUseCase.scenario7'), icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', answer: t('solutionsByUseCase.answer7'), cta: { text: t('solutionsByUseCase.cta7'), link: `/${lang}/design-powerhouse` } },
  { scenario: t('solutionsByUseCase.scenario8'), icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', answer: t('solutionsByUseCase.answer8'), cta: { text: t('solutionsByUseCase.cta8'), link: `/${lang}/products` } },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="max-w-4xl mx-auto py-24 px-6">
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">{t('solutionsByUseCase.heading')}</h1>
    <p class="mt-4 text-lg text-gray-500">{t('solutionsByUseCase.subheading')}</p>

    <div class="mt-12 space-y-4">
      {scenarios.map((sc) => (
        <details class="group bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow">
          <summary class="flex items-center gap-4 p-6 cursor-pointer list-none">
            <div class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={sc.icon} /></svg>
            </div>
            <span class="flex-1 font-medium text-gray-900 text-sm leading-relaxed">{sc.scenario}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 pt-2 border-t border-gray-100">
            <p class="text-sm text-gray-600 leading-relaxed">{sc.answer}</p>
            <a href={sc.cta.link} class="mt-4 inline-flex px-5 py-2.5 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition">{sc.cta.text} →</a>
          </div>
        </details>
      ))}
    </div>

    <section class="mt-16 bg-gradient-to-br from-gray-50 to-sky-50 rounded-2xl p-8 border border-gray-200 text-center">
      <h2 class="text-xl font-semibold text-gray-900">{t('solutionsByUseCase.ctaTitle')}</h2>
      <p class="mt-2 text-sm text-gray-500">{t('solutionsByUseCase.ctaDesc')}</p>
      <a href={`/${lang}/contact`} class="mt-6 inline-flex px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">{t('solutionsByUseCase.ctaBtn')} →</a>
    </section>
  </section>

  <ExperienceLayer
    title={t('solutionsByUseCase.expTitle')}
    subtitle={t('solutionsByUseCase.expSub')}
    stories={[
      {
        quote: t('solutionsByUseCase.story1.quote'),
        narrative: t('solutionsByUseCase.story1.narrative'),
        context: t('solutionsByUseCase.story1.context'),
        source: t('solutionsByUseCase.story1.source')
      },
      {
        quote: t('solutionsByUseCase.story2.quote'),
        narrative: t('solutionsByUseCase.story2.narrative'),
        context: t('solutionsByUseCase.story2.context'),
        source: t('solutionsByUseCase.story2.source')
      },
    ]}
  />
  <RelatedPages
    title={t('solutionsByUseCase.relatedTitle')}
    subtitle={t('solutionsByUseCase.relatedSub')}
    links={[
      { title: t('solutionsByUseCase.rel1'), description: t('solutionsByUseCase.rel1desc'), href: `/${lang}/solutions/by-industry`, label: t('solutionsByUseCase.rel1label') },
      { title: t('solutionsByUseCase.rel2'), description: t('solutionsByUseCase.rel2desc'), href: `/${lang}/industrial-textiles`, label: t('solutionsByUseCase.rel2label') },
      { title: t('solutionsByUseCase.rel3'), description: t('solutionsByUseCase.rel3desc'), href: `/${lang}/oem-odm-manufacturer`, label: t('solutionsByUseCase.rel3label') },
      { title: t('solutionsByUseCase.rel4'), description: t('solutionsByUseCase.rel4desc'), href: `/${lang}/engineering-perfection`, label: t('solutionsByUseCase.rel4label') },
    ]}
  />

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>{t('solutionsByUseCase.aiBlock')}</p>
  </section>
</Layout>
