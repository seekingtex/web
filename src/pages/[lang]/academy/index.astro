---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'academy') || {};
const hero = page.hero || {};
const categories = page.categories || [];
const cta = page.cta || {};

const metadata = {
  title: 'Learning Center — Seekingtex Academy',
  description: 'Guides and tutorials for every skill level — from fabric basics to advanced textile technology. Learn at your own pace with Seekingtex Academy.',
};

const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'Academy' }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{hero.tagline}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">{hero.title}</h1>
    <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
  </section>

  {
    categories.map((cat) => (
      <section class="px-6 sm:px-6 pb-16 mx-auto max-w-6xl" data-ai-block="learning-category">
        <div class="flex items-center gap-4 mb-8">
          <div class={`h-10 w-10 rounded-lg bg-gradient-to-br ${cat.color} flex items-center justify-center text-white font-bold text-sm`}>
            {cat.level.charAt(0)}
          </div>
          <div>
            <span class={`text-xs font-semibold uppercase tracking-wider px-2 py-0.5 rounded ${cat.badge}`}>{cat.level}</span>
            <h2 class="mt-1 text-2xl font-bold text-gray-900">{cat.level} Guides</h2>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {cat.guides.map((g) => (
            <a
              href={`/${lang}/v2/${g.slug}`}
              class="group block bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-all hover:-translate-y-0.5"
            >
              <h3 class="font-semibold text-gray-900 group-hover:text-sky-600 transition-colors">{g.title}</h3>
              <p class="mt-2 text-sm text-gray-500 leading-relaxed">{g.desc}</p>
              <span class="mt-4 inline-flex text-sm font-medium text-sky-600 group-hover:text-sky-700">
                {page.read_guide}
              </span>
            </a>
          ))}
        </div>
      </section>
    ))
  }

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">{cta.title}</h2>
      <p class="mt-2 text-sm text-muted">{cta.desc}</p>
      <a href={`/${lang}${cta.link}`} class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90">
        {cta.label}
      </a>
    </div>
  </section>

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Seekingtex Academy — Learning Center',
    description: 'Guides and tutorials for every skill level from fabric basics to advanced textile technology.',
    url: `https://seekingtex.com/${lang}/academy`,
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: categories.flatMap((cat) =>
        cat.guides.map((g, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          item: {
            '@type': 'Article',
            headline: g.title,
            description: g.desc,
            url: `https://seekingtex.com/${lang}/v2/${g.slug}`,
          },
        }))
      ),
    },
  })} />
</Layout>
