---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import Timeline from '~/components/blog/Timeline.astro';

import { fetchPosts, blogPostsPerPage, blogCategoryRobots } from '~/utils/blog';
import type { Post } from '~/types';
import { languages } from '~/i18n/config';

export const prerender = true;

export const getStaticPaths = async () => {
  const posts = await fetchPosts();
  const pageSize = blogPostsPerPage;
  const paths: { params: { lang: string; category: string; page: string[] | undefined }; props: { paginatedPosts: Post[]; currentPage: number; totalPages: number; categoryTitle: string } }[] = [];
  for (const lang of Object.keys(languages)) {
    const categories = new Map<string, { slug: string; title: string; posts: Post[] }>();
    for (const post of posts) {
      if (post.category?.slug) {
        if (!categories.has(post.category.slug)) {
          categories.set(post.category.slug, { slug: post.category.slug, title: post.category.title, posts: [] });
        }
        categories.get(post.category.slug)!.posts.push(post);
      }
    }
    for (const { slug, title, posts: catPosts } of categories.values()) {
      const totalPages = Math.ceil(catPosts.length / pageSize);
      for (let i = 0; i < totalPages; i++) {
        const n = i + 1;
        paths.push({
          params: { lang, category: slug, page: n > 1 ? [String(n)] : undefined },
          props: {
            paginatedPosts: catPosts.slice(i * pageSize, (i + 1) * pageSize),
            currentPage: n,
            totalPages,
            categoryTitle: title,
          },
        });
      }
    }
  }
  return paths;
};

const params = Astro.params as { lang: string; category: string; page?: string[] };
const { lang, category } = params;
const { paginatedPosts, currentPage, totalPages, categoryTitle } = Astro.props;

const prevUrl =
  currentPage > 1
    ? currentPage === 2
      ? `/${lang}/news/category/${category}/`
      : `/${lang}/news/category/${category}/${currentPage - 1}/`
    : undefined;
const nextUrl = currentPage < totalPages ? `/${lang}/news/category/${category}/${currentPage + 1}/` : undefined;

const metadata = {
  title: `Category '${categoryTitle}'${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata}>
  <section class="section-premium mx-auto max-w-4xl px-6">
    <Headline>{categoryTitle}</Headline>
    <div class="mt-16">
      <Timeline posts={paginatedPosts} />
    </div>
    <div class="mt-16 text-center">
      <Pagination prevUrl={prevUrl} nextUrl={nextUrl} />
    </div>
  </section>
</Layout>
