---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'quality') || {};
const hero = page.hero || {};
const stats = page.stats || [];
const tests = page.tests || [];
const commitment = page.commitment || {};
const testingSection = page.testing_section || {};

const t = (s) => (typeof s === 'string' ? s.replace(/\{SITE\}/g, SITE.name) : s);

const metadata = {
  title: `Quality Testing & Assurance — Performance & Durability — ${SITE.name}`,
  description: `${SITE.name}'s quality testing program covers tensile strength, GSM, color fastness, UV resistance, abrasion, tear strength, and water repellency testing. Every fabric roll is certified before shipping.`,
};

const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: hero.tagline }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{hero.tagline}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">{hero.title}</h1>
    <p class="mt-3 text-lg text-muted max-w-3xl mx-auto">{hero.subtitle}</p>
  </section>

  <section class="px-6 sm:px-6 pb-8 mx-auto max-w-6xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {
        stats.map((s) => (
          <div class="text-center p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
            <span class="block text-3xl font-bold text-primary">{s.value}</span>
            <span class="text-sm text-muted mt-1">{s.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{testingSection.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{testingSection.title}</h2>
    </div>
    <div class="space-y-8">
      {
        tests.map((t, i) => (
          <div
            class={`grid md:grid-cols-2 gap-8 items-center ${i % 2 === 1 ? 'md:direction-rtl' : ''}`}
            style={i % 2 === 1 ? 'direction: rtl;' : ''}
          >
            <div class={i % 2 === 1 ? 'direction: ltr;' : ''}>
              <h3 class="text-xl font-bold">{t.title}</h3>
              <p class="mt-3 text-muted leading-relaxed">{t.description}</p>
            </div>
            <div class={i % 2 === 1 ? 'direction: ltr;' : ''}>
              <img src={t.image} alt={t.title} class="w-full h-64 object-cover rounded-xl" loading="lazy" />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-4xl">
    <div class="rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-8">
      <h2 class="text-2xl font-bold text-center">{commitment.title}</h2>
      <p class="mt-4 text-muted leading-relaxed text-center max-w-3xl mx-auto">{t(commitment.body)}</p>
      <div class="text-center mt-8">
        <a
          href={`/${lang}${commitment.cta_link}`}
          class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
        >
          {commitment.cta} →
        </a>
      </div>
    </div>
  </section>
</Layout>
