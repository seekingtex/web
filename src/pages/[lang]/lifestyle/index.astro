---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'lifestyle');

const hero = page.hero ?? {};
const values = page.values ?? [];
const ethos = page.ethos_section ?? {};
const community = page.community_section ?? {};
const ctaSection = page.cta_section ?? {};

const metadata = {
  title: `${hero.title.replace(/<br\s*\/?>/gi, ' ')} — ${SITE.name}`,
  description: `${SITE.name} lifestyle — ${hero.subtitle}`,
};
const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'Lifestyle' }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="relative min-h-[50vh] flex items-center justify-center text-center text-white overflow-hidden bg-gradient-to-br from-[#001830] via-[#002d4a] to-[#003355]">
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-sky-400">{SITE.name}</p>
      <h1 class="mt-4 text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]" set:html={hero.title} />
      <p class="mt-6 text-lg text-white/70 max-w-2xl mx-auto">
        {hero.subtitle}
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{ethos.tagline}</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">{ethos.title}</h2>
      <p class="mt-4 text-lg text-gray-500">{ethos.subtitle}</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {values.map((v) => (
        <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
          <span class="text-3xl">{v.icon}</span>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">{v.title}</h3>
          <p class="mt-3 text-sm text-gray-500 leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gray-50 dark:bg-slate-900/50 py-24 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{community.tagline}</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">{community.title}</h2>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">{community.subtitle}</p>
      <div class="mt-10 flex justify-center gap-4 flex-wrap">
        <a href="https://www.instagram.com/seekingtex" class="px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">{community.instagram || 'Follow on Instagram'}</a>
        <a href="https://www.youtube.com/@Seekingtex" class="px-8 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition">{community.youtube || 'Subscribe on YouTube'}</a>
        <a href="https://x.com/seekingtex" class="px-8 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition">{community.x || 'Follow on X'}</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6 text-center">
    <h2 class="text-3xl font-semibold text-gray-900">{ctaSection.title}</h2>
    <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">{ctaSection.subtitle}</p>
    <div class="mt-10 flex justify-center gap-4">
      <a href={`/${lang}${ctaSection.products_link || '/products'}`} class="px-10 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">{ctaSection.products_cta || 'Explore Products →'}</a>
      <a href={`/${lang}${ctaSection.about_link || '/about'}`} class="px-10 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition">{ctaSection.about_cta || 'About Us'}</a>
    </div>
  </section>
</Layout>
