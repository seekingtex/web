---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'custom') || {};
const hero = page.hero || {};
const stepsSection = page.steps_section || {};
const steps = stepsSection.steps || [];
const servicesSection = page.services_section || {};
const services = servicesSection.items || [];
const capabilitiesSection = page.capabilities_section || {};
const capabilities = capabilitiesSection.capabilities || [];
const whySection = page.why_section || {};
const points = whySection.points || [];
const contact = whySection.contact || {};

const metadata = {
  title: 'Custom Development — OEM/ODM Functional Fabric Manufacturer',
  description:
    'OEM/ODM functional fabric manufacturer. Custom designs, private label, bulk production. MOQ 500 meters, ISO certified, 30-day lead time. China factory direct.',
};

const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'Custom Lab' }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section
    class="relative min-h-[60vh] flex items-center justify-center text-center text-white overflow-hidden bg-gradient-to-br from-[#0f172a] via-[#1e293b] to-[#0f172a]"
  >
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-sky-400">{hero.tagline}</p>
      <h1 class="mt-4 text-5xl md:text-7xl font-bold tracking-tight leading-[1.1]" set:html={hero.title} />
      <p class="mt-6 text-lg text-white/70 max-w-2xl mx-auto">{hero.subtitle}</p>
      <div class="mt-10 flex justify-center gap-4 flex-wrap">
        <a
          href={`/${lang}${hero.footer_link}`}
          class="px-8 py-4 bg-white text-gray-900 rounded-full font-semibold hover:bg-gray-50 transition"
        >
          {hero.cta} →
        </a>
        <a
          href={`/${lang}/factory`}
          class="px-8 py-4 border border-white/30 text-white rounded-full font-medium hover:bg-white/10 transition"
        >
          Visit our factory
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{stepsSection.tagline}</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">{stepsSection.title}</h2>
      <p class="mt-4 text-lg text-gray-500">{stepsSection.subtitle}</p>
    </div>
    <div class="grid md:grid-cols-4 gap-6">
      {
        steps.map((s) => (
          <div class="relative bg-white border border-gray-200 rounded-2xl p-6 text-center hover:shadow-md transition-shadow">
            <span class="block text-4xl font-bold text-sky-600/20">{s.num}</span>
            <h3 class="mt-2 text-lg font-semibold text-gray-900">{s.title}</h3>
            <p class="mt-2 text-sm text-gray-500">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-gray-50 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{servicesSection.tagline}</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">{servicesSection.title}</h2>
        <p class="mt-4 text-lg text-gray-500">{servicesSection.subtitle}</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          services.map((svc) => (
            <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
              <span class="text-3xl">{svc.icon}</span>
              <h3 class="mt-4 font-semibold text-gray-900">{svc.title}</h3>
              <p class="mt-2 text-sm text-gray-500">{svc.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{capabilitiesSection.tagline}</span>
      <h2 class="mt-4 text-3xl font-semibold text-gray-900">{capabilitiesSection.title}</h2>
      <p class="mt-4 text-lg text-gray-500">{capabilitiesSection.subtitle}</p>
    </div>
    <div class="max-w-4xl mx-auto divide-y divide-gray-200 border border-gray-200 rounded-2xl overflow-hidden">
      {
        capabilities.map((c) => (
          <div class="flex items-center justify-between px-8 py-5 bg-white hover:bg-gray-50 transition-colors">
            <span class="font-medium text-gray-900 w-1/3">{c.label}</span>
            <span class="text-gray-600 text-sm w-2/3">{c.value}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">{whySection.tagline}</span>
        <h2 class="mt-4 text-3xl font-semibold text-gray-900">{whySection.title}</h2>
        <ul class="mt-8 space-y-4">
          {
            points.map((p) => (
              <li class="flex gap-3">
                <span class="text-sky-600 font-bold shrink-0">&mdash;</span>
                <span class="text-gray-600">
                  <strong class="text-gray-900">{p.highlight}</strong>
                  {p.text.slice((p.highlight || '').length)}
                </span>
              </li>
            ))
          }
        </ul>
        <a
          href={`/${lang}${whySection.cta_link}`}
          class="mt-8 inline-flex px-6 py-3 bg-gray-900 text-white rounded-xl font-semibold hover:bg-gray-800 transition text-sm"
        >
          {whySection.cta} →
        </a>
      </div>
      <div
        class="rounded-2xl overflow-hidden bg-gradient-to-br from-sky-50 to-blue-50 border border-sky-200 p-8 text-center"
      >
        <p class="text-lg font-semibold text-sky-900">{contact.title}</p>
        <p class="mt-2 text-sm text-sky-700">{contact.desc}</p>
        <a
          href={`/${lang}/contact`}
          class="mt-6 inline-flex px-8 py-3 bg-sky-600 text-white rounded-full font-semibold hover:bg-sky-700 transition"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>
</Layout>
