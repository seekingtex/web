---
import Layout from '~/layouts/PageLayout.astro';

export const prerender = true;

import { languages, defaultLang, ui } from '~/i18n/config';
import { SITE } from 'astrowind:config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key) => (ui)[lang]?.[key] || (ui)[defaultLang]?.[key] || key;
import { SITE } from 'astrowind:config';

const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: 'R&D Center', href: `/${lang}/randdcenter` }, { name: 'Fabric Testing Lab' }];

const metadata = {
  title: `Fabric Testing Lab — Material Testing for Functional Textiles | ${SITE.name}`,
  description: `Scientific material testing from fiber to finished fabric. Tensile strength, UV weathering, abrasion resistance, and dimensional stability for performance textiles. Contact our lab team for custom fabric specification.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 mx-auto max-w-5xl">
    <a href={`/${lang}/randdcenter`} class="text-sm text-gray-500 hover:underline">&larr; Back to R&D Center</a>
    <div class="mt-4 grid md:grid-cols-5 gap-10">
      <div class="md:col-span-3">
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">Lab 01</p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold">Fabric Testing Lab</h1>
        <p class="mt-3 text-lg text-muted">Scientific material testing — from fiber to finished fabric</p>
      </div>
      <div class="md:col-span-2">
        <img
          src="/images/seekingtex/labs/fabric-testing-lab.webp"
          alt="Seekingtex fabric material testing laboratory"
          class="w-full h-48 object-cover rounded-xl"
        />
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-12 mx-auto max-w-4xl prose prose-gray dark:prose-invert">
    <h2>The foundation of every functional textile</h2>
    <p>
      The fabric is the single most critical component of any textile product. It must withstand repeated laundering, abrasion, exposure to chemicals, and extreme temperature swings — all while maintaining its structural integrity for years. At Seekingtex, our Fabric Testing Lab is dedicated exclusively to the characterisation, validation, and continuous improvement of the fabrics we produce.
    </p>
    <p>
      We do not rely solely on supplier data sheets. Every batch of fabric that enters our workshop is independently tested in-house. This guarantees that the material specification we publish is the material performance you receive — lot after lot, year after year.
    </p>

    <h2>Standardised testing equipment</h2>
    <table>
      <thead><tr><th>Equipment</th><th>Parameters Measured</th><th>Standard</th></tr></thead>
      <tbody>
        <tr><td>Universal tensile tester (50 kN)</td><td>Breaking force, elongation at break, seam strength</td><td>ISO 13934 / ASTM D5034</td></tr>
        <tr><td>Xenon-arc weathering chamber</td><td>UV resistance (color change, strength retention after 2000 h)</td><td>ISO 105-B02 / ASTM G155</td></tr>
        <tr><td>Martindale abrasion tester</td><td>Abrasion resistance and pilling assessment</td><td>ISO 12947 / ASTM D4966</td></tr>
        <tr><td>Color spectrophotometer</td><td>Delta-E color measurement, shade consistency</td><td>ISO 105-A05</td></tr>
        <tr><td>Thickness gauge (digital)</td><td>Uniformity across roll width</td><td>ISO 5084</td></tr>
        <tr><td>Hydrostatic head tester</td><td>Water penetration resistance</td><td>ISO 811</td></tr>
      </tbody>
    </table>

    <h2>From data to decision: a typical test workflow</h2>
    <p>When a new fabric candidate arrives, it follows a standardised seven-step qualification process:</p>
    <ol>
      <li><strong>Receipt inspection</strong> — visual check for surface defects, shade variation, and dimensional compliance.</li>
      <li><strong>GSM verification</strong> — 5-point measurement across the roll; CV < 3% is required for acceptance.</li>
      <li><strong>Tensile testing</strong> — 5 specimens in warp and weft directions. Minimum values per specification.</li>
      <li><strong>Color fastness</strong> — wash, light, rubbing, and perspiration fastness per ISO 105.</li>
      <li><strong>Dimensional stability</strong> — shrinkage after laundering per AATCC 135.</li>
      <li><strong>Abrasion resistance</strong> — cycles to failure per Martindale method.</li>
      <li><strong>Approval sign-off</strong> — only after all seven gates are passed is the fabric released for production.</li>
    </ol>

    <h2>Our professional team</h2>
    <p>
      The lab is staffed by two full-time textile engineers, each holding a degree in textile engineering or polymer science with a minimum of six years of industry experience. They are supported by three technicians who perform day-to-day testing and data logging.
    </p>

    <h2>Solving your toughest material challenges</h2>
    <p>
      Every application is different. A healthcare uniform faces different demands than an industrial workwear garment. Our Fabric Lab helps you select — or develop — a fabric specification that is optimised for your requirements.
    </p>

    <h2>How we serve you</h2>
    <p>When you bring a material challenge to us, here is what you can expect:</p>
    <ol>
      <li><strong>Consultation</strong> — we discuss your requirements, performance targets, and budget.</li>
      <li><strong>Proposal</strong> — a test plan is drafted with clear pass/fail criteria and timeline.</li>
      <li><strong>Execution</strong> — our lab runs the tests and produces a detailed report with raw data and analysis.</li>
      <li><strong>Recommendation</strong> — we present a fabric specification with alternative options if multiple materials meet your requirements.</li>
      <li><strong>Follow-up</strong> — after delivery, we remain available to support any in-service material questions.</li>
    </ol>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">Need a custom fabric specification?</h2>
      <p class="mt-2 text-sm text-muted">Contact our material engineering team to discuss your requirements.</p>
      <a
        href={`/${lang}/contact`} 
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
        >Contact our lab team</a
      >
    </div>
  </section>
</Layout>
