---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const page = getPageContent(lang, 'randdcenter');

const { hero, intro, capabilities, rd_numbers, rd_services, labs_section } = page;

const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: hero.tagline }];

const metadata = {
  title: `R&D Center — ${SITE.name}`,
  description: `${SITE.name} Research & Development — textile testing, fabric engineering, weaving/knitting R&D, quality control for functional fabrics and performance textiles. Custom R&D services available.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{hero.tagline}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">{hero.title}</h1>
    <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-4xl">
    {intro.map((p, i) => (
      <p class={`text-muted leading-relaxed${i > 0 ? ' mt-6' : ''}`}>{p}</p>
    ))}
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{capabilities.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{capabilities.title}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">{capabilities.subtitle}</p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {capabilities.groups.map((cap) => (
        <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
          <h3 class="text-lg font-bold mb-3">{cap.title}</h3>
          <ul class="space-y-2">
            {cap.items.map((item) => (
              <li class="flex items-start gap-2 text-sm text-muted">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary shrink-0" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-4xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{rd_numbers.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{rd_numbers.title}</h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {rd_numbers.stats.map((stat) => (
        <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 text-center">
          <span class="block text-3xl font-bold text-primary">{stat.value}</span>
          <span class="text-sm text-muted mt-1">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-16 mx-auto max-w-4xl">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <div class="text-center mb-8">
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">{rd_services.tagline}</p>
        <h2 class="mt-2 text-2xl font-bold">{rd_services.title}</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 text-sm">
        {rd_services.services.map((svc) => (
          <div class="p-5 rounded-lg bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800">
            <h3 class="font-bold mb-2">{svc.title}</h3>
            <p class="text-muted">{svc.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href={`/${lang}${rd_services.cta_link}`} class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90">
          {rd_services.cta}
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{labs_section.tagline}</p>
      <h2 class="mt-2 text-3xl font-bold">{labs_section.title}</h2>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        labs_section.labs.map((lab) => (
          <a
            href={`/${lang}${lab.href}`}
            class="block rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 overflow-hidden shadow-sm hover:shadow-md transition-shadow hover:border-primary/50 group"
          >
            <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-900">
              <img
                src={lab.image}
                alt={lab.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-bold group-hover:text-primary transition-colors">{lab.title}</h3>
              <p class="mt-2 text-sm text-muted">{lab.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
