---
import Layout from '~/layouts/PageLayout.astro';

export const prerender = true;

import { languages } from '~/i18n/config';
import { SITE } from 'astrowind:config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: 'R&D Center', href: `/${lang}/randdcenter` },
  { name: 'Fabric Sample & Prototype Workshop' },
];

const metadata = {
  title: `Fabric Sample & Prototype Workshop — Custom Textile Development | ${SITE.name}`,
  description: `From specification to finished sample in 15-20 days. Our prototype workshop develops, tests, and validates custom fabrics for OEM/ODM partners. Start your fabric development project today.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 mx-auto max-w-5xl">
    <a href={`/${lang}/randdcenter`} class="text-sm text-gray-500 hover:underline">&larr; Back to R&D Center</a>
    <div class="mt-4 grid md:grid-cols-5 gap-10">
      <div class="md:col-span-3">
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">Lab 05</p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold">Fabric Sample & Prototype Workshop</h1>
        <p class="mt-3 text-lg text-muted">
          From specification to finished sample — developed, proven, and ready for production
        </p>
      </div>
      <div class="md:col-span-2">
        <img
          src="/images/seekingtex/labs/prototype-workshop.webp"
          alt="Seekingtex fabric prototype workshop"
          class="w-full h-48 object-cover rounded-xl"
        />
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-12 mx-auto max-w-4xl prose prose-gray dark:prose-invert">
    <h2>Where specification becomes reality</h2>
    <p>
      A fabric specification, no matter how detailed, cannot reveal how a textile will actually perform until it is
      produced. That is why our Fabric Sample & Prototype Workshop is designed to translate specifications into physical
      samples as quickly and accurately as possible. Every new Seekingtex fabric — and every significant custom
      development — passes through this workshop before production tooling is committed.
    </p>
    <p>
      The workshop is fully equipped for small-lot weaving, knitting, dyeing, and finishing. This integrated approach
      cuts prototype lead time to 15-20 working days from specification, compared to the industry norm of 30-45 days.
      When your application demands a specialised solution, we can move from concept to validated sample in under three
      weeks.
    </p>

    <h2>Workshop capabilities</h2>
    <table>
      <thead><tr><th>Workstation</th><th>Equipment</th><th>Purpose</th></tr></thead>
      <tbody>
        <tr
          ><td>Sample weaving</td><td>Mini rapier loom, sample dobby loom</td><td
            >Small-lot woven fabric samples for evaluation</td
          ></tr
        >
        <tr
          ><td>Sample knitting</td><td>Circular knitting machine, flatbed knitter</td><td
            >Knit fabric samples and structure development</td
          ></tr
        >
        <tr
          ><td>Dyeing & finishing</td><td>Laboratory dyeing machine, padder, stenter frame</td><td
            >Color development, finish application, fixation</td
          ></tr
        >
        <tr
          ><td>Testing station</td><td>Portable tensile tester, thickness gauge, balance</td><td
            >In-process quality verification</td
          ></tr
        >
      </tbody>
    </table>

    <h2>The prototype journey — step by step</h2>
    <ol>
      <li>
        <strong>Specification handover</strong> — The fabric specification (yarn type, construction, finish, target properties)
        is formally reviewed. Any manufacturing concerns are flagged and resolved before production begins.
      </li>
      <li>
        <strong>Sample production</strong> — Yarn is prepared and woven or knitted according to specification. Initial greige
        fabric is inspected for construction accuracy.
      </li>
      <li>
        <strong>Finishing & dyeing</strong> — Fabric is processed through required finishing steps: scouring, dyeing, drying,
        and chemical application.
      </li>
      <li>
        <strong>Quality testing</strong> — Sample undergoes tensile testing, GSM verification, color measurement, and dimensional
        stability check.
      </li>
      <li>
        <strong>Client review</strong> — Sample and test report are submitted for client approval. Feedback incorporated into
        final specification.
      </li>
      <li>
        <strong>Production release</strong> — Upon approval, the specification is formalized and released for bulk production.
      </li>
    </ol>

    <h2>Custom prototyping for unique applications</h2>
    <p>
      The Prototype Workshop is where we solve the problems that standard fabrics cannot address. Recent examples
      include:
    </p>
    <ul>
      <li>
        A custom antimicrobial finish for a hospital network requiring specific efficacy against hospital-acquired
        infections.
      </li>
      <li>A high-visibility fabric with integrated reflective properties for a safety equipment distributor.</li>
      <li>A sustainable fabric blend using recycled polyester and organic cotton for an eco-conscious brand.</li>
    </ul>

    <h2>Client involvement</h2>
    <p>
      We encourage our clients to review sample submissions at key milestones during development — particularly the
      initial strike-off and the finished sample. Your feedback during these stages is invaluable in fine-tuning the
      fabric before it enters production.
    </p>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">Start your fabric development project</h2>
      <p class="mt-2 text-sm text-muted">Tell us about the fabric you need and we will propose a development plan.</p>
      <a
        href={`/${lang}/contact`}
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
        >Contact our development team</a
      >
    </div>
  </section>
</Layout>
