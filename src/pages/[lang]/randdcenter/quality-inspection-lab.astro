---
import Layout from '~/layouts/PageLayout.astro';

export const prerender = true;

import { languages } from '~/i18n/config';
import { SITE } from 'astrowind:config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: 'R&D Center', href: `/${lang}/randdcenter` },
  { name: 'Quality & Inspection Lab' },
];

const metadata = {
  title: `Quality & Inspection Lab — ISO-Compliant Textile Testing & Certification | ${SITE.name}`,
  description: `Independent quality verification for functional textiles. Tensile testing, color fastness, dimensional stability, seam strength, and material certification. Contact our quality lab for testing services.`,
};
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 mx-auto max-w-5xl">
    <a href={`/${lang}/randdcenter`} class="text-sm text-gray-500 hover:underline">&larr; Back to R&D Center</a>
    <div class="mt-4 grid md:grid-cols-5 gap-10">
      <div class="md:col-span-3">
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">Lab 06</p>
        <h1 class="mt-2 text-3xl md:text-4xl font-bold">Quality & Inspection Lab</h1>
        <p class="mt-3 text-lg text-muted">Independent verification — every test passed before delivery</p>
      </div>
      <div class="md:col-span-2">
        <img
          src="/images/seekingtex/labs/quality-inspection-lab.webp"
          alt="Seekingtex quality inspection laboratory"
          class="w-full h-48 object-cover rounded-xl"
        />
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 pb-12 mx-auto max-w-4xl prose prose-gray dark:prose-invert">
    <h2>Trust, but verify</h2>
    <p>
      Every fabric batch that leaves our workshop carries certification that it has passed a defined set of quality inspections and material tests. Our Quality & Inspection Lab is an independent function within the organisation — it reports directly to the managing director, not to production — ensuring that no commercial pressure can compromise the inspection gate. If a material batch or completed fabric does not meet the published specification, the lab has the authority to halt shipment until the non-conformance is resolved.
    </p>
    <p>
      The lab operates under a quality management system aligned with ISO 9001 principles, and our test methods are based on ISO, ASTM, and EN standards. We maintain detailed records of every test performed, creating a complete traceability chain from raw material receipt to final fabric delivery.
    </p>

    <h2>Test equipment and capabilities</h2>
    <table>
      <thead><tr><th>Equipment</th><th>Tests Performed</th><th>Standard / Method</th></tr></thead>
      <tbody>
        <tr><td>Universal testing machine (50 kN)</td><td>Tensile strength (fabric), seam strength, tear propagation</td><td>ASTM D5034, ISO 13934</td></tr>
        <tr><td>Color spectrophotometer</td><td>Delta-E color measurement, shade matching</td><td>ISO 105-A05 / ASTM D2244</td></tr>
        <tr><td>Dimensional stability tester</td><td>Shrinkage after laundering and steaming</td><td>AATCC 135 / ISO 6330</td></tr>
        <tr><td>Hydrostatic head tester</td><td>Water penetration resistance</td><td>ISO 811</td></tr>
        <tr><td>Digital thickness gauge</td><td>Fabric thickness uniformity</td><td>ISO 5084</td></tr>
        <tr><td>Environmental chamber</td><td>Temperature conditioning (-40°C to +80°C)</td><td>ISO 188</td></tr>
        <tr><td>Martindale abrasion tester</td><td>Abrasion resistance and pilling</td><td>ISO 12947 / ASTM D4966</td></tr>
        <tr><td>Crockmeter</td><td>Color fastness to rubbing</td><td>AATCC 8 / ISO 105-X12</td></tr>
      </tbody>
    </table>

    <h2>Key quality metrics (2025 rolling average)</h2>
    <div class="not-prose my-8 grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-center">
        <span class="block text-2xl font-bold text-blue-600">99.7 %</span>
        <span class="text-xs text-gray-500">First-pass yield (fabric batch)</span>
      </div>
      <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-center">
        <span class="block text-2xl font-bold text-blue-600">&lt; 0.2 %</span>
        <span class="text-xs text-gray-500">Fabric defect rate (linear metre)</span>
      </div>
      <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-center">
        <span class="block text-2xl font-bold text-blue-600">100 %</span>
        <span class="text-xs text-gray-500">Batches tested before shipment</span>
      </div>
      <div class="p-4 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 text-center">
        <span class="block text-2xl font-bold text-blue-600">ISO 9001</span>
        <span class="text-xs text-gray-500">Quality system compliance</span>
      </div>
    </div>

    <h2>Our quality team</h2>
    <p>
      The lab is staffed by a quality manager (10 years in textile QA, ASQ Certified Quality Engineer), two quality inspectors (each with Level 2 NDT certification in visual testing), and a materials technician responsible for all physical testing. The team undergoes annual proficiency testing through an independent third-party provider.
    </p>

    <h2>Independent testing for clients</h2>
    <p>
      Our Quality & Inspection Lab is available for independent testing services. If you need to verify a fabric specification, validate a new finish, or obtain a third-party test report for a procurement qualification, we can perform the tests to the applicable standard and issue a certified test report.
    </p>
    <p>Examples of recent third-party testing work:</p>
    <ul>
      <li>Comparative abrasion testing of five competitive fabric finishes for a European institutional procurement programme.</li>
      <li>Accelerated ageing study (UV + thermal cycling) for a new pigment formulation, with interim measurements at 500 h intervals.</li>
      <li>Dimensional stability validation of 50 prototype fabric samples for a new uniform program.</li>
    </ul>

    <h2>Our commitment</h2>
    <p>
      When you receive Seekingtex fabric, you also receive its quality dossier — a compiled record of the test results that apply to your specific batch. Fabric batch certificate, test reports, and inspection records. Every number is traceable. Every inspector is identified.
    </p>
  </section>

  <section class="px-6 sm:px-6 pb-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">Need independent testing or quality verification?</h2>
      <p class="mt-2 text-sm text-muted">Our lab accepts third-party testing work — contact us with your requirements.</p>
      <a
        href={`/${lang}/contact`} 
        class="mt-4 inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
        >Contact the quality lab</a
      >
    </div>
  </section>
</Layout>
