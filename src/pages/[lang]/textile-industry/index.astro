---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import AiQuickAnswer from '~/components/common/AiQuickAnswer.astro';


import { languages } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const metadata = {
  title: 'Textile Industry Guide — Complete Resource on Fabrics, Materials, Selection & Standards',
  description: 'A comprehensive guide to functional fabrics covering types, construction methods, materials comparison, selection criteria, quality standards, and care.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <JsonLd type="Article" article={{
    headline: 'Textile Industry Guide — The Complete Resource',
    description: 'A comprehensive guide to functional fabrics covering types, construction methods, materials comparison, selection criteria, quality standards, and care.',
    datePublished: '2026-07-07',
  }} data={{ url: 'https://seekingtex.com/textile-industry/' }} />

  <JsonLd type="BreadcrumbList" breadcrumbs={[
    { name: 'Home', href: `/${lang}/` },
    { name: 'Textile Industry', href: `/${lang}/textile-industry` },
    { name: 'Textile Guide', href: `/${lang}/textile-industry/` },
  ]} />

  <AiQuickAnswer
    entityType="Guide"
    quickAnswer="A functional fabric is a textile engineered with specialized properties such as UV protection, water repellency, moisture wicking, antimicrobial finish, or enhanced durability. Modern functional fabrics include performance textiles, protective fabrics, and technical materials. They are built from polyester, nylon, cotton, or blended fibers using advanced weaving, knitting, and finishing technologies."
    facts={[
      { label: 'Global Market Size', value: '$220B (2026)' },
      { label: 'Primary Fibers', value: 'Polyester / Cotton / Nylon' },
      { label: 'Lifespan Range', value: '5-15+ years' },
      { label: 'OEKO-TEX Certification', value: 'Standard (Global)' },
    ]}
  />

  <section class="max-w-4xl mx-auto py-16 px-6">
    <h1 class="text-4xl font-semibold text-gray-900">Textile Industry Guide</h1>
    <p class="mt-4 text-lg text-gray-500">The definitive resource on functional fabrics — from performance textiles to industrial materials and specialty fabrics.</p>

    <nav class="mt-8 flex flex-wrap gap-2">
      {['Types', 'Construction', 'Materials', 'Selection', 'Safety', 'Care', 'Standards'].map((section) => (
        <a href={`#${section.toLowerCase()}`} class="px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-full text-sm font-medium text-gray-700 transition">{section}</a>
      ))}
    </nav>

    <section id="types" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Types of Functional Fabrics</h2>
      <div class="mt-8 grid gap-6">
        {[
          { title: 'Performance Fabrics', desc: 'High-performance textiles engineered for moisture management, breathability, and comfort in active wear and sportswear applications.', icon: '🏃' },
          { title: 'Protective Textiles', desc: 'Fabrics with specialized finishes for protection against UV, water, wind, flame, or chemicals. Used in workwear, outdoor gear, and safety apparel.', icon: '🛡️' },
          { title: 'Medical Textiles', desc: 'Antimicrobial, fluid-repellent fabrics designed for healthcare environments. Used for scrubs, uniforms, linens, and protective garments.', icon: '🏥' },
          { title: 'Industrial Fabrics', desc: 'Heavy-duty textiles for manufacturing, transportation, and industrial applications. High tensile strength, abrasion resistance, and durability.', icon: '🏭' },
          { title: 'Uniform & Corporate Fabrics', desc: 'Professional-grade fabrics for corporate attire, hospitality uniforms, and institutional apparel. Easy-care, wrinkle-resistant, and durable.', icon: '👔' },
          { title: 'Sustainable Textiles', desc: 'Eco-friendly fabrics made from recycled fibers, organic cotton, and sustainable materials. Meeting growing demand for environmentally responsible textiles.', icon: '🌱' },
        ].map((item) => (
          <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-200">
            <span class="text-2xl flex-shrink-0">{item.icon}</span>
            <div>
              <h3 class="font-semibold text-gray-900">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="construction" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Fabric Construction Methods</h2>
      <div class="mt-8 grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">Plain Weave</h3>
          <p class="mt-2 text-sm text-gray-600">The most basic and widely used weave pattern where each weft thread passes alternately over and under each warp thread. Creates strong, stable, and tightly constructed fabric. Common in shirting, workwear, and industrial textiles.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">Twill Weave</h3>
          <p class="mt-2 text-sm text-gray-600">Diagonal weave pattern where weft threads pass over two or more warp threads. Creates softer, more drapable fabric with higher thread count. Excellent for denim, uniforms, and performance apparel.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">Knit Construction</h3>
          <p class="mt-2 text-sm text-gray-600">Interlocking loops of yarn creates stretchy, comfortable fabrics. Includes jersey, rib, and interlock knits. Ideal for sportswear, activewear, and garments requiring stretch and recovery.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">Non-Woven & Engineered</h3>
          <p class="mt-2 text-sm text-gray-600">Fabrics created directly from fibers bonded through mechanical, chemical, or thermal processes. Used for medical textiles, filtration, protective gear, and specialized industrial applications.</p>
        </div>
      </div>
    </section>

    <section id="materials" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Fiber & Material Comparison</h2>
      <div class="mt-6 overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b-2 border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">Property</th>
              <th class="px-4 py-3 text-center font-semibold text-sky-700">Polyester</th>
              <th class="px-4 py-3 text-center font-semibold text-emerald-700">Nylon</th>
              <th class="px-4 py-3 text-center font-semibold text-amber-700">Cotton</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Relative Cost', '$ (budget)', '$$ (mid-range)', '$ (budget)'],
              ['Tensile Strength', 'High', 'Very High', 'Moderate'],
              ['Abrasion Resistance', 'Good', 'Excellent', 'Moderate'],
              ['Moisture Management', 'Wicking', 'Moderate wicking', 'Absorbent'],
              ['UV Resistance', 'Good', 'Moderate', 'Poor'],
              ['Comfort', 'Moderate', 'Good', 'Excellent'],
              ['Wrinkle Resistance', 'Excellent', 'Good', 'Poor'],
              ['Drying Speed', 'Fast', 'Moderate', 'Slow'],
            ].map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                {row.map((cell, j) => (
                  <td class={`px-4 py-3 border-b border-gray-200 ${j === 0 ? 'font-medium text-gray-700' : 'text-center text-gray-600'}`}>{cell}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm text-gray-500">Modern high-tenacity polyester offers excellent durability for most textile applications at an affordable price. Nylon provides superior strength for demanding applications, while cotton offers unmatched natural comfort and breathability.</p>
      <a href={`/${lang}/learn/polyester-vs-cotton`} class="mt-4 inline-block text-sky-600 hover:text-sky-700 text-sm font-medium">In-Depth Fiber Comparison Guide →</a>
    </section>

    <section id="selection" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">How to Choose a Functional Fabric</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        <div class="p-6 bg-sky-50 rounded-xl border border-sky-200">
          <h3 class="font-semibold text-gray-900">1. Define Your Application</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            <li>Apparel: Performance or casual</li>
            <li>Workwear: Durability + protection</li>
            <li>Medical: Hygiene + fluid barrier</li>
            <li>Industrial: Strength + chemical resistance</li>
            <li>Hospitality: Appearance + easy care</li>
          </ul>
        </div>
        <div class="p-6 bg-sky-50 rounded-xl border border-sky-200">
          <h3 class="font-semibold text-gray-900">2. Set Your Requirements</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            <li>GSM: 100-150 (lightweight)</li>
            <li>GSM: 150-250 (mid-weight)</li>
            <li>GSM: 250-350+ (heavy duty)</li>
            <li>Fiber: Polyester / Nylon / Cotton / Blend</li>
            <li>Finish: Antimicrobial / Water-repellent / UPF</li>
          </ul>
        </div>
        <div class="p-6 bg-sky-50 rounded-xl border border-sky-200">
          <h3 class="font-semibold text-gray-900">3. Consider Performance</h3>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            <li>UPF 50+: Excellent sun protection</li>
            <li>Hydrophilic: Moisture wicking</li>
            <li>Hydrophobic: Water repellent</li>
            <li>Tensile: ASTM D5034 verified</li>
            <li>Color fastness: AATCC rated</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="safety" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Quality Standards & Certifications</h2>
      <div class="mt-8 grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">OEKO-TEX Standard 100</h3>
          <p class="mt-2 text-sm text-gray-600">Global certification for textile products tested for harmful substances. Covers all processing stages from yarn to finished fabric. Seekingtex fabrics are OEKO-TEX certified for consumer safety.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">ISO 9001:2015</h3>
          <p class="mt-2 text-sm text-gray-600">International standard for quality management systems. Specifies requirements for consistent quality, continuous improvement, and customer satisfaction. Our facility is ISO 9001 certified.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">REACH Compliance</h3>
          <p class="mt-2 text-sm text-gray-600">EU regulation for Registration, Evaluation, Authorisation, and Restriction of Chemicals. All Seekingtex fabrics comply with REACH requirements for chemical safety throughout the supply chain.</p>
        </div>
        <div class="p-6 rounded-xl border border-gray-200">
          <h3 class="font-semibold text-gray-900">ASTM Testing Standards</h3>
          <p class="mt-2 text-sm text-gray-600">American Society for Testing and Materials standards for textile testing: tensile strength (ASTM D5034), tear strength (ASTM D2261), color fastness (AATCC 61), and dimensional stability (AATCC 135).</p>
        </div>
      </div>
    </section>

    <section id="care" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Fabric Care & Maintenance</h2>
      <div class="mt-8 space-y-4 text-sm text-gray-600">
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">1.</span><span>Follow care label instructions for washing temperature and drying method. Most performance fabrics machine wash cold.</span></div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">2.</span><span>Avoid fabric softeners which can reduce moisture-wicking and water-repellent performance over time.</span></div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">3.</span><span>Tumble dry low or line dry. High heat can damage elastic fibers and specialty finishes.</span></div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">4.</span><span>Clean with mild detergent. Avoid bleach, chlorine, and harsh chemicals that degrade fabric performance.</span></div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">5.</span><span>Iron on low heat if needed. Some performance fabrics require no ironing due to wrinkle-resistant finishes.</span></div>
        <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl"><span class="text-sky-600 font-bold flex-shrink-0">6.</span><span>Replace garments when fabric shows visible wear, fading, loss of stretch recovery, or diminished performance characteristics.</span></div>
      </div>
    </section>

    <section id="standards" class="mt-16">
      <h2 class="text-2xl font-semibold text-gray-900">Industry Applications</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-4">
        {[
          { title: 'Apparel & Fashion', desc: 'Performance fabrics for sportswear, casual wear, and fashion garments requiring comfort, durability, and style.' },
          { title: 'Healthcare & Medical', desc: 'Antimicrobial, fluid-repellent fabrics for medical uniforms, patient gowns, linens, and protective garments.' },
          { title: 'Industrial & Workwear', desc: 'High-durability fabrics for protective workwear, safety apparel, and industrial uniforms requiring strength and comfort.' },
          { title: 'Hospitality & Uniforms', desc: 'Professional fabrics for hotel staff, restaurant uniforms, and corporate apparel programs requiring professional appearance and easy care.' },
          { title: 'Outdoor & Sport', desc: 'Weather-resistant, moisture-wicking fabrics for outdoor gear, athletic wear, and performance sportswear.' },
          { title: 'OEM Manufacturing', desc: 'Custom private-label production for brands, retailers, and specialized organizations seeking unique specifications.' },
        ].map((app) => (
          <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
            <h3 class="font-semibold text-sm text-gray-900">{app.title}</h3>
            <p class="mt-1 text-xs text-gray-500">{app.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-16 bg-gradient-to-br from-sky-50 to-blue-50 rounded-2xl p-8 border border-sky-200">
      <h2 class="text-xl font-semibold text-gray-900">Explore Seekingtex Functional Fabrics</h2>
      <p class="mt-4 text-sm text-gray-600">Seekingtex manufactures OEKO-TEX certified functional fabrics, performance textiles, and custom fabric solutions for apparel, healthcare, hospitality, and industrial markets. All fabrics produced with premium yarns using advanced weaving, knitting, and finishing technologies.</p>
      <div class="mt-6 flex gap-4 flex-wrap">
        <a href={`/${lang}/products`} class="px-6 py-3 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition">View Products</a>
        <a href={`/${lang}/guides`} class="px-6 py-3 border border-gray-200 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition">Learning Center</a>
      </div>
    </section>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>Comprehensive textile industry guide covering types of functional fabrics (performance textiles, protective fabrics, medical textiles, industrial fabrics, uniform fabrics, sustainable textiles), construction methods (plain weave, twill weave, knit construction, non-woven), materials comparison (polyester, nylon, cotton), selection criteria (application, requirements, performance), safety standards (OEKO-TEX, ISO 9001, REACH, ASTM), care and maintenance, and industry applications (apparel, healthcare, industrial, hospitality, outdoor, OEM).</p>
  </section>
</Layout>
