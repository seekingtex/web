---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';
import { products, type ProductRecord } from '~/data/products';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const title = t('techspecs.title');
const metadata = {
  title: `${title} | ${SITE.name}`,
  description: t('techspecs.subtitle'),
  ignoreTitleTemplate: true,
};

const categories: { key: ProductRecord['category']; label: string; desc: string }[] = [
  { key: 'RIB', label: t('techspecs.rib'), desc: t('techspecs.ribDesc') },
  { key: 'INFLATABLE', label: t('techspecs.inflatable'), desc: t('techspecs.inflatableDesc') },
  { key: 'SUP', label: t('techspecs.sup'), desc: t('techspecs.supDesc') },
  { key: 'ACCESSORY', label: t('techspecs.accessories'), desc: t('techspecs.accessoriesDesc') },
];

const catProducts = categories.map((cat) => ({
  ...cat,
  items: products.filter((p) => p.category === cat.key),
}));
---

<Layout metadata={metadata}>
  <JsonLd type="Article" article={{
    headline: title,
    description: metadata.description,
    datePublished: '2025-01-15',
    dateModified: new Date().toISOString().split('T')[0],
  }} />

  <div class="max-w-7xl mx-auto px-4 py-12">
    <section class="text-center mb-14">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-slate-100">{title}</h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-slate-400 max-w-3xl mx-auto">{t('techspecs.desc')}</p>
    </section>

    {catProducts.filter((c) => c.items.length > 0).map((cat) => (
      <section class="mb-14">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-2">{cat.label}</h2>
        <p class="text-gray-500 dark:text-slate-400 mb-5 text-sm">{cat.desc}</p>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-slate-800 text-left text-gray-600 dark:text-slate-300">
              <tr>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramLength')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramBeam')}</th>
                {cat.key === 'RIB' && <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramTubeDiam')}</th>}
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramWeight')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramMaxLoad')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramCapacity')}</th>
                {cat.key !== 'SUP' && <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramMaxEngine')}</th>}
                {(cat.key === 'RIB' || cat.key === 'INFLATABLE') && <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramMaterial')}</th>}
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.paramWarranty')}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
              {cat.items.map((p) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-slate-800/50">
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-slate-100">{p.ai_specs.length || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.beam || p.ai_specs.width || '—'}</td>
                  {cat.key === 'RIB' && <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.tube_diameter || '—'}</td>}
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.weight || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.max_load || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.capacity || '—'}</td>
                  {cat.key !== 'SUP' && <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.max_engine || '—'}</td>}
                  {(cat.key === 'RIB' || cat.key === 'INFLATABLE') && <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.hull || p.ai_specs.tubes || p.ai_specs.material || '—'}</td>}
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.warranty || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}

    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-2">{t('techspecs.materialsTitle')}</h2>
      <p class="text-gray-500 dark:text-slate-400 mb-5 text-sm">{t('techspecs.materialsDesc')}</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { key: 'materialPvc', icon: '\u{1F9F5}', specs: '0.9-1.2 mm, UV stabilized, 2000+ h, -30°C to +70°C' },
          { key: 'materialHypalon', icon: '\u{1F9F5}', specs: '1.2 mm CSM rubber, ozone resistant, 10+ yr life' },
          { key: 'materialDropstitch', icon: '\u{1F6E1}\u{FE0F}', specs: '12-15 PSI, 10 cm core, 500+ denier, 1500 N' },
          { key: 'materialAluminum', icon: '\u{1F3CA}', specs: '5083 alloy, 3 mm plate, welded, anodized' },
          { key: 'materialFiberglass', icon: '\u{1F680}', specs: 'Hand-laid fiberglass, gelcoat, deep-V, foam' },
        ].map((mat) => (
          <div class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <div class="text-2xl mb-2">{mat.icon}</div>
            <h3 class="font-semibold text-gray-900 dark:text-slate-100">{t('techspecs.' + mat.key)}</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">{t('techspecs.' + mat.key + 'Desc')}</p>
            <div class="mt-3 text-xs font-mono bg-gray-100 dark:bg-slate-700 p-2 rounded text-gray-600 dark:text-slate-300">{mat.specs}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
