---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';
import { products, type ProductRecord } from '~/data/products';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const title = t('techspecs.title');
const metadata = {
  title: `${title} | ${SITE.name}`,
  description: t('techspecs.subtitle'),
  ignoreTitleTemplate: true,
};

const categories: { key: string; label: string; desc: string }[] = [
  { key: 'SUN_PROTECTION', label: t('techspecs.sunProtection'), desc: t('techspecs.sunProtectionDesc') },
  { key: 'WATERPROOF', label: t('techspecs.waterproof'), desc: t('techspecs.waterproofDesc') },
  { key: 'QUICK_DRY', label: t('techspecs.quickDry'), desc: t('techspecs.quickDryDesc') },
  { key: 'ANTIBACTERIAL', label: t('techspecs.antibacterial'), desc: t('techspecs.antibacterialDesc') },
  { key: 'STRETCH', label: t('techspecs.stretch'), desc: t('techspecs.stretchDesc') },
  { key: 'BREATHABLE', label: t('techspecs.breathable'), desc: t('techspecs.breathableDesc') },
  { key: 'ECO_FRIENDLY', label: t('techspecs.ecoFriendly'), desc: t('techspecs.ecoFriendlyDesc') },
];

const catProducts = categories.map((cat) => ({
  ...cat,
  items: products.filter((p) => p.category === cat.key),
}));
---

<Layout metadata={metadata}>
  <JsonLd type="Article" article={{
    headline: title,
    description: metadata.description,
    datePublished: '2025-01-15',
    dateModified: new Date().toISOString().split('T')[0],
  }} />

  <div class="max-w-7xl mx-auto px-4 py-12">
    <section class="text-center mb-14">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-slate-100">{title}</h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-slate-400 max-w-3xl mx-auto">{t('techspecs.desc')}</p>
    </section>

    {catProducts.filter((c) => c.items.length > 0).map((cat) => (
      <section class="mb-14">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-2">{cat.label}</h2>
        <p class="text-gray-500 dark:text-slate-400 mb-5 text-sm">{cat.desc}</p>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 dark:bg-slate-800 text-left text-gray-600 dark:text-slate-300">
              <tr>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.productName')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.weight')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.width')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.composition')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.construction')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.finish')}</th>
                <th class="px-4 py-3 font-semibold whitespace-nowrap">{t('techspecs.certification')}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-slate-700">
              {cat.items.map((p) => (
                <tr class="hover:bg-gray-50 dark:hover:bg-slate-800/50">
                  <td class="px-4 py-3 font-medium text-gray-900 dark:text-slate-100">{p.name}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.weight || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.width || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.composition || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.construction || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.finish || '—'}</td>
                  <td class="px-4 py-3 text-gray-500 dark:text-slate-400">{p.ai_specs.certification || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}

    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-2">{t('techspecs.materialsTitle')}</h2>
      <p class="text-gray-500 dark:text-slate-400 mb-5 text-sm">{t('techspecs.materialsDesc')}</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { key: 'materialPolyester', specs: '100% polyester filament, 30D-600D, various weaves, moisture-wicking, UV-stabilized' },
          { key: 'materialNylon', specs: '100% nylon 6.6 filament, 20D-840D, ripstop and plain weaves, abrasion-resistant' },
          { key: 'materialCottonBlend', specs: 'Cotton-polyester blends (65/35, 50/50), twill and poplin weaves, breathable' },
          { key: 'materialRecycledPolyester', specs: '100% recycled polyester (GRS-certified), 75D-300D, eco-friendly production' },
          { key: 'materialTencel', specs: 'Tencel/cotton blends, biodegradable, mechanical stretch, soft hand feel' },
          { key: 'materialCoated', specs: 'PU/TPU coated polyester or nylon, 5000-30000mm hydrostatic head, breathable laminates' },
        ].map((mat) => (
          <div class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <h3 class="font-semibold text-gray-900 dark:text-slate-100">{t('techspecs.' + mat.key)}</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-slate-400">{t('techspecs.' + mat.key + 'Desc')}</p>
            <div class="mt-3 text-xs font-mono bg-gray-100 dark:bg-slate-700 p-2 rounded text-gray-600 dark:text-slate-300">{mat.specs}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>
