---
export const prerender = true;

import type { InferGetStaticPropsType } from 'astro';
import type { ImageMetadata } from 'astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import merge from 'lodash.merge';
import ProductLayout from '~/layouts/ProductLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import Tldr from '~/components/common/Tldr.astro';
import TrustBadges from '~/components/common/TrustBadges.astro';

import { findRelatedProducts, getStaticPathsProduct, CATEGORY_SLUG_TO_URL } from '~/utils/products';
import { findImage } from '~/utils/images';
import { SITE } from 'astrowind:config';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';
import { products as productRecords } from '~/data/products';
import { localizeProduct } from '~/utils/product-i18n';
import { guides } from '~/data/guides';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  const paths: { params: { lang: string; slug: string }; props: any }[] = [];
  const allProducts = await getStaticPathsProduct();
  for (const lang of Object.keys(languages)) {
    for (const p of allProducts) {
      paths.push({ params: { lang, slug: p.params.slug }, props: p.props });
    }
  }
  return paths;
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { product } = Astro.props as Props;
const recRaw = productRecords.find((p) => p.id === product.slug);
const rec = recRaw ? localizeProduct(recRaw, lang) : undefined;
const url = getCanonical(getPermalink(product.permalink, 'product'));
const image = await findImage(product.image);
const gallery = await Promise.all(
  (product.gallery ?? []).map(async (g) => ({
    raw: await findImage(g.url),
    alt: g.alt || product.title,
  }))
);
const related = await findRelatedProducts(product, 3);
const relatedGuides = rec ? guides.filter((g) => g.relatedProducts.includes(rec.id)).slice(0, 3) : [];

const defaultTitle = product.categoryLabel
  ? `${product.title} — ${product.categoryLabel} | ${SITE.name}`
  : `${product.title} | ${SITE.name}`;
const defaultDesc =
  (product.summary ?? product.description)
    ? `${product.summary ?? product.description} — ${t('cta.requestQuote')}`
    : `Explore the ${product.title} from ${SITE.name}. ${t('cta.requestQuote')}`;

const metadata = merge(
  {
    title: defaultTitle,
    description: defaultDesc,
    canonical: url,
    robots: { index: !product.draft, follow: true },
    openGraph: {
      type: 'website',
      ...(image ? { images: [{ url: image, width: 1200, height: 630 }] } : {}),
    },
  },
  product.metadata ? { ...product.metadata, canonical: product.metadata.canonical || url } : {}
) as MetaData;

const productCrumbs = [
  { name: t('nav.home'), href: `/${lang}/` },
  { name: t('nav.products'), href: `/${lang}/products` },
  ...(product.categoryLabel ? [{ name: product.categoryLabel, href: `/${lang}/${CATEGORY_SLUG_TO_URL[product.category || ''] || 'products'}` }] : []),
  { name: product.title },
];

const specRows = product.specs ?? [];
---

<ProductLayout metadata={metadata} breadcrumbs={productCrumbs}>
  <JsonLd
    type="Product"
    product={{
      name: product.title,
      description: product.summary ?? product.description ?? '',
      sku: product.sku,
      image: image ? String(image) : undefined,
      url: String(url || ''),
      category: product.categoryLabel,
      brandName: SITE.name,
      ...(product.price
        ? { price: { amount: product.price.amount, currency: product.price.currency }, inStock: product.inStock }
        : {}),
    }}
  />
  <JsonLd type="BreadcrumbList" breadcrumbs={productCrumbs.map((c) => ({ name: c.name, href: c.href }))} />

  {/* Product Hero: Image Gallery + Info */}
  <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 md:py-10">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12">
        <!-- Left: Image Gallery -->
        <div class="space-y-4">
          <div class="relative aspect-[4/3] bg-gray-100 dark:bg-slate-800 rounded-2xl overflow-hidden">
            {
              gallery.length > 0 ? (
                gallery[0].raw ? (
                  (() => {
                    const img0 = gallery[0];
                    return typeof img0.raw === 'string' ? (
                      <img id="gallery-main" src={img0.raw} alt={img0.alt || product.title}
                        class="w-full h-full object-contain p-2" loading="eager" decoding="async" />
                    ) : (
                      <Image id="gallery-main" src={img0.raw as ImageMetadata} alt={img0.alt || product.title}
                        class="w-full h-full object-contain p-2" widths={[480, 768, 1024]} width={768} height={576}
                        format="webp" loading="eager" decoding="async" />
                    );
                  })()
                ) : image ? (
                  typeof image === 'string' ? (
                    <img id="gallery-main" src={image} alt={product.title}
                      class="w-full h-full object-contain p-2" loading="eager" decoding="async" />
                  ) : (
                    <Image id="gallery-main" src={image as ImageMetadata} alt={product.title}
                      class="w-full h-full object-contain p-2" widths={[480, 768, 1024]} width={768} height={576}
                      format="webp" loading="eager" decoding="async" />
                  )
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-slate-600 text-sm">
                    No image available
                  </div>
                )
              ) : image ? (
                typeof image === 'string' ? (
                  <img id="gallery-main" src={image} alt={product.title}
                    class="w-full h-full object-contain p-2" loading="eager" decoding="async" />
                ) : (
                  <Image id="gallery-main" src={image as ImageMetadata} alt={product.title}
                    class="w-full h-full object-contain p-2" widths={[480, 768, 1024]} width={768} height={576}
                    format="webp" loading="eager" decoding="async" />
                )
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-300 dark:text-slate-600 text-sm">
                  No image available
                </div>
              )
            }
          </div>
          {
            gallery.length > 1 && (
              <div class="flex gap-3 overflow-x-auto pb-2">
                {gallery.map((g, i) => (
                  <button
                    data-gallery-thumb={typeof g.raw === 'string' ? g.raw : String(g.raw?.src || '')}
                    data-gallery-alt={g.alt || `Image ${i + 1}`}
                    class={`flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden border-2 transition-colors bg-gray-100 dark:bg-slate-800 ${i === 0 ? 'border-sky-500' : 'border-transparent hover:border-sky-400'}`}
                    aria-label={`View ${g.alt || `image ${i + 1}`}`}
                  >
                    {typeof g.raw === 'string' ? (
                      <img src={g.raw} alt={g.alt || `Image ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
                    ) : g.raw ? (
                      <Image src={g.raw as ImageMetadata} alt={g.alt || `Image ${i + 1}`}
                        class="w-full h-full object-cover" widths={[80]} width={80} height={80}
                        format="webp" loading="lazy" />
                    ) : null}
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <!-- Right: Product Info -->
        <div class="flex flex-col gap-6">
          <div>
            <div class="flex items-center gap-3 text-sm text-gray-400 dark:text-slate-500 mb-3">
              {product.categoryLabel && <span class="font-medium uppercase tracking-wider">{product.categoryLabel}</span>}
              {product.sku && <><span aria-hidden="true">·</span><span class="font-mono text-xs">{product.sku}</span></>}
            </div>
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-slate-100 leading-[1.15]">{product.title}</h1>
            {product.summary && <p class="mt-3 text-base text-gray-600 dark:text-slate-400 leading-relaxed">{product.summary}</p>}
            {
              product.price && (
                <div class="mt-5 flex items-baseline gap-2">
                  <span class="text-3xl font-bold text-gray-900 dark:text-slate-100">${product.price.amount}</span>
                  <span class="text-sm text-gray-400 dark:text-slate-500">{product.price.currency || 'USD'}</span>
                  {product.price.note && <p class="text-xs text-gray-400 dark:text-slate-500 mt-1 w-full">{product.price.note}</p>}
                </div>
              )
            }
          </div>

          {/* Environment & Water Condition Tags -> to use t('product.environment') */}
          {
            (product.environment && product.environment.length > 0) || (product.water_condition && product.water_condition.length > 0) ? (
              <div class="flex flex-wrap gap-2">
                {product.environment?.map((e: string) => (
                  <span class="px-3 py-1.5 bg-sky-50 dark:bg-sky-900/30 text-sky-700 dark:text-sky-300 text-xs font-medium rounded-full">{e}</span>
                ))}
                {product.water_condition?.map((w: string) => (
                  <span class="px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 text-xs font-medium rounded-full">{w}</span>
                ))}
              </div>
            ) : null
          }

          {/* Tags */}
          {
            product.tags && product.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {product.tags.map((tag) => (
                  <span class="px-2.5 py-1 bg-gray-100 dark:bg-slate-800 text-gray-500 dark:text-slate-400 text-xs rounded-md">{tag}</span>
                ))}
              </div>
            )
          }

          {/* Key Specs Grid */}
          {
            specRows.length > 0 && (
              <div class="grid grid-cols-2 gap-2">
                {specRows.slice(0, 6).map((s) => (
                  <div class="flex flex-col gap-0.5 p-3 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
                    <span class="text-[10px] font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500">{s.label}</span>
                    <span class="text-sm font-medium text-gray-800 dark:text-slate-200">{s.value}</span>
                  </div>
                ))}
              </div>
            )
          }

          {/* Full Specs Toggle */}
          {
            specRows.length > 6 && (
              <details class="group">
                <summary class="text-sm font-semibold text-gray-500 dark:text-slate-400 cursor-pointer hover:text-gray-700 dark:hover:text-slate-200 transition-colors list-none flex items-center gap-2">
                  {t('product.specifications')}
                  <span class="text-[10px] group-open:rotate-180 transition-transform">&#9660;</span>
                </summary>
                <div class="mt-3 grid grid-cols-2 gap-2">
                  {specRows.slice(6).map((s) => (
                    <div class="flex items-center justify-between p-2.5 rounded-lg bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
                      <span class="text-xs font-medium text-gray-600 dark:text-slate-400 capitalize">{s.label}</span>
                      <span class="text-xs text-gray-500 dark:text-slate-500 ml-2 text-right">{s.value}</span>
                    </div>
                  ))}
                </div>
              </details>
            )
          }

          {/* CTA Buttons */}
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={`/${lang}/contact?product=${encodeURIComponent(product.title)}`}
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gray-900 dark:bg-slate-700 text-white font-semibold rounded-full hover:bg-gray-800 dark:hover:bg-slate-600 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 text-sm">
              <Icon name="tabler:message-circle" class="w-5 h-5" />
              {t('product.oemQuote')}
            </a>
            <a href={`/${lang}/contact?product=${encodeURIComponent(product.title)}&sample=1`}
              class="inline-flex items-center justify-center gap-2 px-8 py-3.5 border-2 border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 font-medium rounded-full hover:border-gray-300 dark:hover:border-slate-500 hover:bg-gray-50 dark:hover:bg-slate-800 transition-all text-sm">
              {t('product.customSample')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* TLDR (AI-crawlable) */}
  {
    rec && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 -mt-1 relative z-10">
        <Tldr
          summary={rec.definition}
          points={[`${rec.audience}`, `Use cases: ${rec.ai_use_cases.slice(0, 3).join(', ')}`]}
        />
      </section>
    )
  }

  {/* Content (MDX) */}
  {
    product.Content && (
      <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-16">
          <div class="prose prose-gray dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3 prose-p:text-gray-600 dark:prose-p:text-slate-400 prose-p:leading-relaxed prose-li:text-gray-600 dark:prose-li:text-slate-400 prose-strong:text-gray-900 dark:prose-strong:text-slate-200 prose-ul:space-y-2 max-w-none">
            <product.Content />
          </div>
        </div>
      </section>
    )
  }

  {/* Why This Exists (Problem) */}
  {
    rec && rec.problem && (
      <section class="bg-gray-50/50 dark:bg-slate-900/50 border-b border-gray-100 dark:border-slate-800" data-ai-block="problem">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <div class="bg-blue-50/80 dark:bg-blue-900/30 border-l-4 border-blue-500 rounded-r-xl px-6 py-5">
            <div class="flex items-start gap-3">
              <span class="text-blue-600 dark:text-blue-400 text-xs font-semibold uppercase tracking-wider flex-shrink-0 mt-0.5">{t('v2.problem')}</span>
              <div class="space-y-2 text-sm text-gray-700 dark:text-slate-300 leading-relaxed">
                <p>{rec.problem}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  {/* Overview + Use Cases */}
  {
    rec && rec.ai_use_cases.length > 0 && (
      <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800" data-ai-block="use-case">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-6">{t('product.useCases')}</h2>
          <div class="grid md:grid-cols-2 gap-3">
            {rec.ai_use_cases.map((uc) => (
              <div class="flex items-start gap-3 p-4 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
                <span class="w-2 h-2 mt-2 rounded-full bg-sky-500 flex-shrink-0" />
                <p class="text-sm text-gray-700 dark:text-slate-300">{uc}</p>
              </div>
            ))}
            <div class="flex items-start gap-3 p-4 rounded-xl bg-sky-50 dark:bg-sky-900/30 border border-sky-100 dark:border-sky-800">
              <span class="w-2 h-2 mt-2 rounded-full bg-sky-500 flex-shrink-0" />
              <div>
                <p class="text-sm font-semibold text-sky-800 dark:text-sky-300">{t('product.skillLevel')}</p>
                <p class="text-sm text-sky-700 dark:text-sky-400 capitalize">{rec.skill}</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  {/* Comparison */}
  {
    rec && rec.ai_comparison && (
      <section class="bg-gray-50/50 dark:bg-slate-900/50 border-b border-gray-100 dark:border-slate-800" data-ai-block="comparison">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <span class="text-xs font-semibold uppercase tracking-wider text-sky-600 dark:text-sky-400 mb-2 block">{t('product.comparison')}</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-4">{t('product.howCompares')}</h2>
          <p class="text-base text-gray-600 dark:text-slate-400 leading-relaxed">{rec.ai_comparison}</p>
        </div>
      </section>
    )
  }

  {/* FAQ Section */}
  {
    rec && rec.ai_faq.length > 0 && (
      <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-8">{t('product.faq')}</h2>
          <div class="space-y-3">
            {rec.ai_faq.map((f) => (
              <details class="group rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 open:shadow-sm transition-shadow">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-sm font-semibold text-gray-900 dark:text-slate-200 list-none">
                  {f.q}
                  <span class="shrink-0 ml-2 text-gray-300 dark:text-slate-600 group-open:rotate-180 transition-transform text-xs">&#9660;</span>
                </summary>
                <div class="px-5 pb-4 text-sm text-gray-600 dark:text-slate-400 leading-relaxed border-t border-gray-100 dark:border-slate-700 pt-3 mt-0">
                  {f.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <JsonLd type="FAQPage" faqs={rec?.ai_faq || []} />

  {/* Full Technical Specifications */}
  {
    specRows.length > 0 && (
      <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <span class="text-xs font-semibold uppercase tracking-wider text-sky-600 dark:text-sky-400 mb-2 block">{t('product.specifications')}</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-8">{t('product.specifications')}</h2>
          <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
            <table class="w-full text-sm">
              <tbody>
                {specRows.map((s, i) => (
                  <tr class={i % 2 === 0 ? 'bg-gray-50 dark:bg-slate-800/50' : 'bg-white dark:bg-slate-950'}>
                    <td class="px-5 py-3.5 font-semibold text-gray-700 dark:text-slate-300 w-1/3 border-b border-gray-100 dark:border-slate-800">{s.label}</td>
                    <td class="px-5 py-3.5 text-gray-600 dark:text-slate-400 border-b border-gray-100 dark:border-slate-800">{s.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )
  }

  {/* Materials & Construction */}
  {
    rec && rec.ai_specs && (
      <section class="bg-gray-50/50 dark:bg-slate-900/50 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <span class="text-xs font-semibold uppercase tracking-wider text-sky-600 dark:text-sky-400 mb-2 block">{t('product.specifications')}</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-6">{t('product.specifications')}</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {Object.entries(rec.ai_specs).filter(([k]) => !['length', 'width', 'height', 'weight', 'max_load', 'pressure', 'warranty'].includes(k)).slice(0, 6).map(([k, v]) => (
              <div class="bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 mb-1">{k.replace(/_/g, ' ')}</div>
                <div class="text-sm font-medium text-gray-900 dark:text-slate-200">{v}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* Trust Badges */}
  <section class="bg-gray-50/50 dark:bg-slate-900/50 border-b border-gray-100 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
      <TrustBadges layout="row" />
    </div>
  </section>

  {/* Related Products */}
  {
    related.length > 0 && (
      <section class="bg-white dark:bg-slate-950 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <h2 class="text-xl md:text-2xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-6">
            {t('product.comparedWith')} {product.categoryLabel || t('product.pageTitle')}
          </h2>
          <div class="grid md:grid-cols-3 gap-4">
            {related.map((p) => (
              <ProductCard product={p} showMeta={false} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* Related Guides */}
  {
    relatedGuides.length > 0 && (
      <section class="bg-gray-50/50 dark:bg-slate-900/50 border-b border-gray-100 dark:border-slate-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-14">
          <h2 class="text-xl md:text-2xl font-bold tracking-tight text-gray-900 dark:text-slate-100 mb-6">{t('product.relatedGuides')}</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {relatedGuides.map((g) => (
              <a href={`/${lang}/guides/${g.slug}`}
                class="block p-5 bg-white dark:bg-slate-800 rounded-xl border border-gray-200 dark:border-slate-700 hover:shadow-md transition-shadow">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-slate-200">{g.title}</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-slate-400 line-clamp-2">{g.description}</p>
                <span class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-sky-600 dark:text-sky-400">
                  {t('product.readGuide')}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* Final CTA */}
  <section class="bg-gray-900 dark:bg-slate-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-14 md:py-18 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-white mb-4">Interested in {product.title}?</h2>
      <p class="text-lg text-white/70 mb-8 max-w-xl mx-auto">
        {t('cta.requestQuote')}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href={`/${lang}/contact?product=${encodeURIComponent(product.title)}`}
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-gray-900 font-semibold rounded-full hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl hover:-translate-y-0.5">
          {t('product.oemQuote')}
        </a>
        <a href={`/${lang}/contact?product=${encodeURIComponent(product.title)}&sample=1`}
          class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-medium rounded-full hover:bg-white/10 transition-all">
          {t('product.customSample')}
        </a>
      </div>
    </div>
  </section>

  {/* Image Gallery Script */}
  {
    gallery.length > 1 && (
      <script>
        const thumbnails = document.querySelectorAll<HTMLElement>('[data-gallery-thumb]');
        const mainImage = document.getElementById('gallery-main');
        if (thumbnails && mainImage) {
          thumbnails.forEach((thumb) => {
            thumb.addEventListener('click', () => {
              const url = thumb.dataset.galleryThumb;
              const alt = thumb.dataset.galleryAlt || '';
              if (url) {
                mainImage.setAttribute('src', url);
                mainImage.setAttribute('alt', alt);
                thumbnails.forEach((t) => t.classList.remove('border-sky-500'));
                thumb.classList.add('border-sky-500');
              }
            });
          });
        }
      </script>
    )
  }

  {/* Hidden AI data blocks (machine-readable) */}
  {
    rec && (
      <section class="sr-only" aria-hidden="true">
        <div data-ai-block="definition">
          <p>{rec.definition}</p>
          <p>Problem it solves: {rec.problem}</p>
          <p>How it works: {rec.howItWorks}</p>
          <p>Target audience: {rec.audience}</p>
        </div>
        <div data-ai-block="use-case">
          <p>Use cases: {rec.ai_use_cases.join('; ')}</p>
          <p>Environments: {rec.environment.join(', ')}</p>
          <p>Water conditions: {rec.water_condition.join(', ')}</p>
          <p>Skill level: {rec.skill}</p>
        </div>
        <div data-ai-block="specification">
          {Object.entries(rec.ai_specs).map(([k, v]) => (
            <p data-spec={k}>{k}: {v}</p>
          ))}
        </div>
        <div data-ai-block="comparison"><p>{rec.ai_comparison}</p></div>
        <div data-ai-block="faq">
          {rec.ai_faq.map((f) => (
            <p><strong>Q:</strong> {f.q} <strong>A:</strong> {f.a}</p>
          ))}
        </div>
        <div data-ai-block="constraint">
          <p>Safety rules: {rec.safety_rules.join('; ')}</p>
          <p>Safety level: {rec.safety_level}</p>
          <p>Regions: {rec.region.join(', ')}</p>
        </div>
      </section>
    )
  }

  <ToBlogLink />
</ProductLayout>
