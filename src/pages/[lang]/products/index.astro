---
export const prerender = true;

import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import QuickViewModal from '~/components/widgets/QuickViewModal.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';

import { SITE } from 'astrowind:config';
import { getProducts, getProductCategories, isProductsEnabled, isProductsListEnabled, CATEGORY_SLUG_TO_URL } from '~/utils/products';
import { PRODUCT_LIST, getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const products = await getProducts();
const categories = await getProductCategories();
const rawCategory = (Astro.url?.searchParams?.get('category') ?? '') as
  'rib' | 'inflatable' | 'accessory' | 'sup' | '';
const activeCategory =
  rawCategory === 'rib' || rawCategory === 'inflatable' || rawCategory === 'accessory' || rawCategory === 'sup'
    ? rawCategory
    : null;
const filteredProducts = activeCategory ? products.filter((p) => p.category === activeCategory) : products;
const totalCount = products.length;
const hidden = !isProductsEnabled() || !isProductsListEnabled();

const metadata = merge(
  {
    title: `Fabric & Textile Products — OEM Manufacturer | ${SITE.name}`,
    description: `Browse the full ${SITE.name} product catalog — performance fabrics, functional textiles, and technical materials. OEM/ODM available for bulk wholesale orders. Factory-direct pricing.`,
    canonical: getCanonical(getPermalink(PRODUCT_LIST)),
    robots: { index: !hidden, follow: true },
    openGraph: { type: 'website' },
  },
  {}
) as MetaData;
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mb-12 text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-2">{t('product.catalog')}</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">{t('product.pageTitle')}</h1>
      <p class="mt-3 md:mt-4 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium">{t('product.pageDesc')}</p>
    </header>

    {
      categories.length > 0 && (
        <WidgetWrapper containerClass="mb-10">
          <div class="flex flex-wrap items-center justify-center gap-2">
            <a
              href={`/${lang}/products`}
              class:list={[
                'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors',
                !activeCategory
                  ? 'bg-primary text-white border-primary dark:bg-blue-500 dark:border-blue-500'
                  : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 text-default dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-700',
              ]}
            >
              <Icon name="tabler:layout-grid" class="w-4 h-4" />
              {t('product.viewAll')} ({totalCount})
            </a>
            {categories.map((c) => (
              <a
                href={`/${lang}/${CATEGORY_SLUG_TO_URL[c.slug]}`}
                class:list={[
                  'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors',
                  activeCategory === c.slug
                    ? 'bg-primary text-white border-primary dark:bg-blue-500 dark:border-blue-500'
                    : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 text-default dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-700',
                ]}
              >
                {c.title} ({c.count})
              </a>
            ))}
          </div>
        </WidgetWrapper>
      )
    }

    {
      filteredProducts.length === 0 ? (
        <div class="text-center py-16 text-muted dark:text-slate-400">
          <Icon name="tabler:package-off" class="w-12 h-12 mx-auto mb-4" />
          <p class="text-lg">{t('product.noResults')}</p>
          <a
            class="text-primary dark:text-blue-400 hover:underline mt-2 inline-block"
            href={`/${lang}/products`}
          >
            {t('product.viewAll')}
          </a>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {filteredProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      )
    }
  </section>
</Layout>
