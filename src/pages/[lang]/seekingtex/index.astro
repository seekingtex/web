---
import Layout from '~/layouts/PageLayout.astro';
import { BRAND } from '~/lib/seo/brand-os';
import { products } from '~/data/products';

export const prerender = true;

import { languages } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const metadata = {
  title: 'Seekingtex — Functional Fabric Manufacturer & OEM/ODM Factory',
  description: 'China-based manufacturer of OEKO-TEX certified functional fabrics, performance textiles, and custom fabric solutions. OEM/ODM services, 12,000 m² factory, ISO certified. Serving B2B clients in 50+ countries since 2012.',
  ignoreTitleTemplate: true,
};

const coreProducts = products.filter((p) =>
  ['sun-polyester-upf50', 'wp-pu-coated', 'qd-moisture-wicking-poly'].includes(p.id)
);

const guideLinks = [
  {
    href: `/${lang}/factory`,
    title: 'Factory & Manufacturing',
    desc: '12,000 m² facility with end-to-end textile production capabilities.',
  },
  {
    href: `/${lang}/custom`,
    title: 'OEM/ODM Services',
    desc: 'Custom development, private label, and bulk production for global brands.',
  },
  {
    href: `/${lang}/factory/equipment`,
    title: 'Equipment & Technology',
    desc: 'Weaving, knitting, dyeing, finishing, and quality testing lab.',
  },
];
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="brand-overview,manufacturer,functional-fabrics,OEM-ODM,textile-manufacturing" />
  <meta name="last-modified" content="2026-06-24" />
  <meta name="X-Robots-Tag" content="index, follow" />

  <!-- HERO: Brand Identity -->
  <section
    class="relative min-h-[80vh] flex items-center justify-center text-center text-white overflow-hidden bg-gradient-to-br from-[#001830] via-[#002d4a] to-[#003355]"
  >
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(14,165,233,0.08)_0%,transparent_60%)]">
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 py-24">
      <span class="text-xs font-medium tracking-[0.2em] uppercase text-white/60">Since {BRAND.foundingYear}</span>
      <h1 class="mt-8 text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] text-balance">{BRAND.name}</h1>
      <p class="mt-4 text-xl md:text-2xl text-white/90 font-light">{BRAND.tagline}</p>
      <p class="mt-4 text-base text-white/70 max-w-2xl mx-auto">{BRAND.description}</p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href={`/${lang}/factory`} 
          class="group px-8 py-4 bg-white text-gray-900 rounded-full font-semibold hover:bg-gray-50 transition-all shadow-xl hover:shadow-2xl"
        >
          Our Manufacturing Facility
          <span class="inline-block ml-2 transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href={`/${lang}/custom`} 
          class="px-8 py-4 border border-white/30 text-white rounded-full font-medium hover:bg-white/10 transition-all backdrop-blur-sm"
        >
          OEM/ODM Services
        </a>
      </div>
    </div>
  </section>

  <!-- BRAND POSITION -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center max-w-3xl mx-auto">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Brand Position</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900">Your OEM/ODM Partner for Functional Fabrics</h2>
      <p class="mt-4 text-lg text-gray-500 leading-relaxed">
        {BRAND.name} manufactures OEKO-TEX certified performance fabrics, functional textiles, and custom fabric solutions
        in our 12,000 m² facility. Every fabric is woven, finished, tested, and shipped from our factory in Qingdao, China.
      </p>
    </div>
    <div class="mt-16 grid md:grid-cols-3 gap-8">
      {
        BRAND.ethos.map((e) => {
          const [title, ...rest] = e.split(' —');
          return (
            <div class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
              <h3 class="text-lg font-semibold text-gray-900">{title}</h3>
              <p class="mt-3 text-sm text-gray-500 leading-relaxed">{rest.join(' —')}</p>
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- CORE PRODUCTS -->
  <section class="bg-gray-50 py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Core Products</span>
        <h2 class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900">Performance · Functional · Technical · Uniform</h2>
        <p class="mt-4 text-lg text-gray-500">OEKO-TEX certified fabric lines manufactured in-house for global B2B partners.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          coreProducts.map((p) => (
            <a
              href={`/products/${p.id}`}
              class="group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow"
            >
              <div class="h-48 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center text-gray-400 text-sm">
                {p.category}
              </div>
              <div class="p-5">
                <h3 class="font-semibold text-gray-900 group-hover:text-sky-600 transition-colors">{p.name}</h3>
                <p class="text-sm text-gray-500 mt-1 line-clamp-2">{p.desc}</p>
                <div class="mt-3 flex gap-2 text-xs">
                  <span class="px-2 py-1 bg-sky-50 text-sky-700 rounded-full">{p.skill}</span>
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full">{p.safety_level}</span>
                </div>
              </div>
            </a>
          ))
        }
        <a
          href={`/${lang}/products`} 
          class="group block bg-gradient-to-br from-sky-50 to-blue-50 rounded-2xl border border-sky-200 p-6 flex flex-col items-center justify-center text-center hover:shadow-lg transition-shadow"
        >
          <span class="text-3xl text-sky-400">+</span>
          <span class="mt-2 font-semibold text-sky-700 group-hover:text-sky-800">All Products →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- MANUFACTURING CAPABILITIES -->
  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Manufacturing</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-semibold text-gray-900">End-to-End Production Under One Roof</h2>
      <p class="mt-4 text-lg text-gray-500">
        From raw yarn and fiber to finished, performance-tested fabric — all in our Qingdao facility.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        guideLinks.map((g) => (
          <a
            href={g.href}
            class="group block bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg transition-all hover:-translate-y-0.5"
          >
            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-sky-600 transition-colors">{g.title}</h3>
            <p class="mt-3 text-sm text-gray-500">{g.desc}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 group-hover:text-sky-700">
              Learn more →
            </span>
          </a>
        ))
      }
    </div>
    <div class="mt-8 text-center">
      <a href={`/${lang}/oem-process`} class="text-sm font-medium text-sky-600 hover:text-sky-700">View production process →</a>
    </div>
  </section>

  <!-- GLOBAL TRUST SIGNAL -->
  <section class="bg-gray-900 text-white py-24 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <span class="text-xs font-medium tracking-[0.2em] uppercase text-white/50">Global Reach</span>
      <h2 class="mt-4 text-3xl md:text-4xl font-semibold">Trusted by B2B Partners Worldwide</h2>
      <p class="mt-4 text-lg text-white/70 max-w-2xl mx-auto">
        OEKO-TEX certified fabrics supplied to apparel brands, healthcare institutions, uniform programs, and industrial partners across {BRAND.regions.length} regions globally.
      </p>
      <div class="mt-12 flex flex-wrap items-center justify-center gap-6">
        {
          BRAND.regions.map((r) => (
            <div class="flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm">
              <span>{r.flag}</span>
              <span>{r.name}</span>
              <span class="text-white/50 text-xs">({r.locale})</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 text-center bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-semibold text-gray-900">Ready to start your project?</h2>
      <p class="mt-4 text-lg text-gray-500">
        OEM/ODM, private label, or bulk fabric supply — our team responds within 24 hours with a preliminary quote.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <a
          href={`/${lang}/contact`} 
          class="px-10 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          Request a Quote →
        </a>
        <a
          href={`/${lang}/custom`} 
          class="px-10 py-4 border-2 border-gray-200 text-gray-700 rounded-full font-semibold hover:border-gray-400 transition-all"
        >
          Custom Development
        </a>
      </div>
    </div>
  </section>
</Layout>
