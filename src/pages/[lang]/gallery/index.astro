---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { languages } from '~/i18n/config';
import { getPageContent } from '~/i18n/page-content';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const page = getPageContent(lang, 'gallery');

const hero = page.hero ?? {};
const albums = page.albums ?? [];
const cta = page.cta ?? {};

const metadata = {
  title: `${hero.title} — ${SITE.name}`,
  description: `Browse the ${SITE.name} gallery — ${hero.subtitle}`,
};
const crumbs = [{ name: 'Home', href: `/${lang}/` }, { name: hero.title }];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <JsonLd type="BreadcrumbList" breadcrumbs={crumbs} />
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">{SITE.name}</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">{hero.title}</h1>
    <p class="mt-3 text-lg text-muted">{hero.subtitle}</p>
  </section>

  {
    albums.map((album) => (
      <section class="px-6 sm:px-6 pb-16 mx-auto max-w-6xl">
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-gray-900">{album.title}</h2>
          <p class="mt-1 text-sm text-muted">{album.desc}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {album.images.map((src) => (
            <div class="rounded-xl overflow-hidden bg-gray-100 aspect-[4/3]">
              <img
                src={src}
                alt={`${album.title} — ${SITE.name}`}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </section>
    ))
  }

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-4xl text-center">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 p-8">
      <h2 class="text-xl font-bold">{cta.title}</h2>
      <p class="mt-2 text-sm text-muted">{cta.desc}</p>
      <div class="mt-6 flex justify-center gap-4">
        <a
          href="https://www.instagram.com/seekingtex"
          class="px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
          >{cta.instagram || 'Instagram'}</a
        >
        <a
          href="https://www.youtube.com/@Seekingtex"
          class="px-6 py-3 border border-gray-300 rounded-md font-semibold hover:bg-gray-50 transition"
          >{cta.youtube || 'YouTube'}</a
        >
      </div>
    </div>
  </section>
</Layout>
