---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const _ = (key: string, fallback: string) => {
  const v = t(key);
  return v === key ? fallback : v;
};

const metadata = {
  title: `${_('designPowerhouse.title', 'Design & Innovation — R&D Powerhouse for Textile Manufacturing')} | ${SITE.name}`,
  description: _('designPowerhouse.desc', `${SITE.name} is more than a factory — we are a design-driven manufacturer. In-house R&D, textile simulation, custom ODM solutions, and advanced material engineering for global B2B partners.`),
};

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: _('designPowerhouse.nav', 'Design & Innovation') },
];

const stats = [
  { value: '14+', label: _('designPowerhouse.stat1', 'In-House Engineers') },
  { value: '8+', label: _('designPowerhouse.stat2', 'Registered Patents') },
  { value: '6', label: _('designPowerhouse.stat3', 'Specialized Labs') },
  { value: '50+', label: _('designPowerhouse.stat4', 'Countries Exported') },
];

const capabilities = [
  { title: _('designPowerhouse.cap1', 'Fabric Structure Simulation'), desc: _('designPowerhouse.cap1desc', 'Advanced simulation and CAD for weave optimization, tensile strength, and performance characteristics.') },
  { title: _('designPowerhouse.cap2', 'Ergonomic Engineering'), desc: _('designPowerhouse.cap2desc', 'Precision fabric engineering for comfort, durability, and performance in every application.') },
  { title: _('designPowerhouse.cap3', 'Advanced Material Science'), desc: _('designPowerhouse.cap3desc', 'High-performance polyester, nylon, cotton blends, and specialized coatings tested for extreme conditions.') },
  { title: _('designPowerhouse.cap4', 'Custom Development & Sampling'), desc: _('designPowerhouse.cap4desc', 'Custom fabric development for specific end-uses. Prototype samples in 15-20 working days.') },
  { title: _('designPowerhouse.cap5', 'Trend-Driven Design'), desc: _('designPowerhouse.cap5desc', 'Color trend analysis, brand identity integration, and bespoke aesthetic development for global markets.') },
  { title: _('designPowerhouse.cap6', 'Complete OEM Solutions'), desc: _('designPowerhouse.cap6desc', 'Full OEM packages — labels, packaging, care instructions — engineered to match your product line.') },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="relative px-6 sm:px-6 py-20 sm:py-28 lg:py-32 mx-auto max-w-6xl text-center" style="background: linear-gradient(135deg, #0c4a6e, #0891b2);">
    <div class="relative z-10 max-w-4xl mx-auto">
      <p class="text-sm font-semibold text-cyan-200 uppercase tracking-wider">{_('designPowerhouse.badge', 'R&D & Design Powerhouse')}</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-bold text-white">{_('designPowerhouse.heading', 'Beyond Manufacturing: Your Strategic Design Partner')}</h1>
      <p class="mt-6 text-lg md:text-xl text-cyan-100 max-w-3xl mx-auto">
        {_('designPowerhouse.subtitle', "We don't just manufacture fabrics — we engineer experiences. Partner with Seekingtex for proprietary R&D, advanced textile design, and turnkey ODM solutions that set your brand apart.")}
      </p>
      <div class="mt-10 flex items-center gap-4 flex-wrap justify-center">
        <a href={`/${lang}/contact`} class="inline-flex items-center gap-2 px-8 py-4 bg-[#fb923c] hover:bg-orange-600 text-white font-semibold rounded-full shadow-lg hover:shadow-xl transition-all">
          {_('designPowerhouse.cta', 'Start Your ODM Project')}
        </a>
        <a href={`/${lang}/oem-odm-manufacturer`} class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-medium rounded-full hover:bg-white/10 transition-all">
          {_('designPowerhouse.cta2', 'Explore OEM Capabilities')}
        </a>
      </div>
    </div>
  </section>

  <section class="border-y border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((s) => (
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-cyan-700">{s.value}</div>
          <div class="mt-1 text-sm text-gray-500">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">{_('designPowerhouse.s1badge', 'Proprietary R&D & Engineering')}</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold">{_('designPowerhouse.s1title', 'Engineered by Experts, Proven by Performance')}</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">
          {_('designPowerhouse.s1p1', "At Seekingtex, we don't just manufacture textiles; we engineer fabric solutions. Our in-house R&D team consists of veteran textile engineers, industrial designers, and material scientists. We leverage advanced weave simulation and computer-aided design (CAD) to optimize fabric structure, ensuring every performance textile delivers durability, comfort, and functionality that meet rigorous industry standards.")}
        </p>
        <p class="mt-4 text-gray-600 leading-relaxed">
          {_('designPowerhouse.s1p2', 'Every curve, seam, and attachment point is meticulously planned and analyzed before a single panel is cut. Our digital prototyping workflow reduces development time by 40% while improving first-pass yield rates.')}
        </p>
      </div>
      <div class="bg-gradient-to-br from-cyan-50 to-sky-100 rounded-2xl p-8">
        <img src="/images/seekingtex/hero/tech-meeting.webp" alt="Textile engineering design session" class="w-full rounded-xl shadow-lg" />
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl bg-gray-50 dark:bg-gray-900">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1 bg-gradient-to-br from-cyan-50 to-sky-100 rounded-2xl p-8">
        <img src="/images/seekingtex/fabrics/performance-textile-sample.webp" alt="Performance textile sample" class="w-full rounded-xl shadow-lg" />
      </div>
      <div class="order-1 md:order-2">
        <p class="text-sm font-semibold text-primary uppercase tracking-wider">{_('designPowerhouse.s2badge', 'Ergonomics & Material Integration')}</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold">{_('designPowerhouse.s2title', 'Design That Performs')}</h2>
        <p class="mt-4 text-gray-600 leading-relaxed">
          {_('designPowerhouse.s2p1', 'Design is nothing without performance. Our design philosophy centers around fabric functionality — from precise yarn selection to engineered weave architecture. We continuously innovate with high-tenacity polyester, reinforced weave structures, and performance finishes to push the boundaries of what functional textiles can achieve.')}
        </p>
        <p class="mt-4 text-gray-600 leading-relaxed">
          {_('designPowerhouse.s2p2', 'Our material science team works alongside designers to select the optimal yarn, weave, and finish combination for every product category — whether healthcare uniforms, hospitality textiles, or industrial workwear.')}
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">{_('designPowerhouse.capBadge', 'Core Capabilities')}</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold">{_('designPowerhouse.capTitle', 'What We Engineer')}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {capabilities.map((c) => (
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow">
          <h3 class="text-lg font-bold">{c.title}</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-6xl" style="background: linear-gradient(135deg, #0f172a, #1e293b);">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sm font-semibold text-cyan-300 uppercase tracking-wider">{_('designPowerhouse.odmBadge', 'Turnkey ODM & White-Label Solutions')}</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-white">{_('designPowerhouse.odmTitle', 'From Sketch to Shelf')}</h2>
      <p class="mt-4 text-lg text-gray-300 leading-relaxed max-w-3xl mx-auto">
        {_('designPowerhouse.odmDesc', 'Whether you come with a rough specification or a fully-fledged brand concept, our design team brings it to life. We offer comprehensive ODM services, including customized fabric development, localized trend-driven designs, branding placement, and bespoke packaging solutions. We empower global brands to stand out in a crowded market with signature textile products.')}
      </p>
      <div class="mt-8 grid sm:grid-cols-3 gap-4 text-left">
        <div class="bg-white/10 rounded-xl p-5 backdrop-blur-sm">
          <div class="text-cyan-300 text-xl font-bold">01</div>
          <h3 class="mt-2 text-white font-semibold">{_('designPowerhouse.odmStep1', 'Concept & Design')}</h3>
          <p class="mt-1 text-sm text-gray-400">{_('designPowerhouse.odmStep1desc', 'From sketch to 3D model — we refine your vision with engineering rigor.')}</p>
        </div>
        <div class="bg-white/10 rounded-xl p-5 backdrop-blur-sm">
          <div class="text-cyan-300 text-xl font-bold">02</div>
          <h3 class="mt-2 text-white font-semibold">{_('designPowerhouse.odmStep2', 'Prototype & Validate')}</h3>
          <p class="mt-1 text-sm text-gray-400">{_('designPowerhouse.odmStep2desc', 'CNC molds, sample production, and performance testing before production.')}</p>
        </div>
        <div class="bg-white/10 rounded-xl p-5 backdrop-blur-sm">
          <div class="text-cyan-300 text-xl font-bold">03</div>
          <h3 class="mt-2 text-white font-semibold">{_('designPowerhouse.odmStep3', 'Brand & Scale')}</h3>
          <p class="mt-1 text-sm text-gray-400">{_('designPowerhouse.odmStep3desc', 'Your branding, your packaging — manufactured at scale with OEKO-TEX and ISO compliance.')}</p>
        </div>
      </div>
      <div class="mt-10">
        <a href={`/${lang}/oem-odm-manufacturer`} class="inline-flex items-center gap-2 px-8 py-4 bg-[#fb923c] hover:bg-orange-600 text-white font-semibold rounded-full shadow-lg transition-all">
          {_('designPowerhouse.odmCta', 'Explore Our ODM Process')}
        </a>
      </div>
    </div>
  </section>

  <section class="px-6 sm:px-6 py-20 mx-auto max-w-5xl text-center">
    <h2 class="text-3xl md:text-4xl font-bold">{_('designPowerhouse.ctaTitle', 'Ready to Engineer Your Next Product Line?')}</h2>
    <p class="mt-4 text-lg text-muted max-w-2xl mx-auto">
      {_('designPowerhouse.ctaSub', "Partner with Seekingtex's design and R&D team. From concept to container, we deliver innovation at scale.")}
    </p>
    <div class="mt-8 flex items-center gap-4 flex-wrap justify-center">
      <a href={`/${lang}/contact`} class="inline-flex items-center gap-2 px-8 py-4 bg-[#fb923c] hover:bg-orange-600 text-white font-semibold rounded-full shadow-lg transition-all">
        {_('designPowerhouse.ctaBtn', 'Contact Our Design Team')}
      </a>
      <a href={`/${lang}/randdcenter`} class="inline-flex items-center gap-2 px-8 py-4 border-2 border-gray-300 text-gray-700 font-medium rounded-full hover:bg-gray-50 transition-all">
        {_('designPowerhouse.ctaBtn2', 'Visit R&D Center')}
      </a>
    </div>
  </section>
  <ExperienceLayer
    title={_('designPowerhouse.expTitle', 'Design Stories from the Studio')}
    subtitle={_('designPowerhouse.expSub', 'How our design team turns concepts into production-ready functional textiles.')}
    stories={[
      {
        quote: "The client wanted a fabric with 50+ industrial launderings without visible wear — beyond what anyone in the industry thought possible for a polyester blend. Our team spent 6 months on yarn selection and developed a new high-tenacity weave construction that made it work.",
        narrative: "A premium hospitality brand requested a fabric capable of withstanding 50+ industrial launderings while retaining color and dimensional stability. Seekingtex's R&D team tested 14 yarn combinations, developed a new high-density weave construction with reinforced seams, and created a custom finish formulation. The final product exceeded the client's performance targets and became their standard uniform fabric.",
        context: "High-durability fabric development, 2024",
        source: "Lead R&D Engineer"
      },
      {
        quote: "We reduced the client's manufacturing waste by 40% simply by redesigning the fabric width and pattern layout. Small changes in the design phase create massive savings in production.",
        narrative: "An existing OEM client wanted to reduce production costs without changing the fabric's performance characteristics. Seekingtex's design team analyzed the entire manufacturing workflow and identified opportunities: optimizing the fabric width for better pattern yield, redesigning the weave structure to reduce material waste, and streamlining the dyeing process. The cumulative changes reduced per-unit production waste by 40% while maintaining the same performance specifications.",
        context: "Manufacturing optimization project, 2024",
        source: "Senior Industrial Designer"
      },
    ]}
  />
  <RelatedPages
    title={_('designPowerhouse.relatedTitle', 'Explore Design & Engineering')}
    subtitle={_('designPowerhouse.relatedSub', "More resources from Seekingtex's innovation ecosystem")}
    links={[
      { title: _('designPowerhouse.rel1', 'R&D Center'), description: _('designPowerhouse.rel1desc', 'Six specialized labs including Textile Testing Lab, Materials Analysis Lab, and Prototype Workshop.'), href: `/${lang}/randdcenter`, label: 'R&D' },
      { title: _('designPowerhouse.rel2', 'OEM/ODM Manufacturing'), description: _('designPowerhouse.rel2desc', 'Full-service OEM/ODM: private label, custom design, and contract manufacturing.'), href: `/${lang}/oem-odm-manufacturer`, label: 'Service' },
      { title: _('designPowerhouse.rel3', 'Engineering Perfection'), description: _('designPowerhouse.rel3desc', 'Our engineering philosophy covering material selection, design, and quality control.'), href: `/${lang}/engineering-perfection`, label: 'Philosophy' },
      { title: _('designPowerhouse.rel4', 'Technology Overview'), description: _('designPowerhouse.rel4desc', 'Deep dive into textile manufacturing technology and materials.'), href: `/${lang}/learn/textile-technology`, label: 'Technology' },
    ]}
  />
</Layout>
