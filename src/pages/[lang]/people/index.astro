---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;
const p = (path: string) => (lang === 'en' ? path : `/${lang}${path}`);

const title = t('people.title');
const metadata = {
  title: `${title} | ${SITE.name}`,
  description: t('people.subtitle'),
  ignoreTitleTemplate: true,
};

const depts = [
  { key: 'engineering', icon: '\u{2699}\u{FE0F}', link: 'engineering-team' },
  { key: 'quality', icon: '\u{2705}', link: 'quality' },
  { key: 'design', icon: '\u{1F3A8}', link: 'design-powerhouse' },
  { key: 'sales', icon: '\u{1F4AC}', link: 'contact' },
  { key: 'management', icon: '\u{1F3E2}', link: 'about' },
];
---

<Layout metadata={metadata}>
  <JsonLd
    data={{
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      headline: title,
      description: metadata.description,
      author: { '@type': 'Organization', name: SITE.name },
    }}
  />

  <div class="max-w-6xl mx-auto px-4 py-12">
    <section class="text-center mb-14">
      <span class="text-sm font-semibold text-sky-600 tracking-wide uppercase">{t('home.resources.team')}</span>
      <h1 class="mt-3 text-4xl font-extrabold text-gray-900 dark:text-slate-100">{title}</h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-slate-400 max-w-2xl mx-auto">{t('people.heroDesc')}</p>
    </section>

    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14 max-w-3xl mx-auto">
      <div class="text-center p-5 rounded-xl bg-sky-50 dark:bg-sky-900/20">
        <div class="text-3xl font-extrabold text-sky-600">200+</div>
        <div class="text-sm text-gray-500 dark:text-slate-400 mt-1">Staff</div>
      </div>
      <div class="text-center p-5 rounded-xl bg-emerald-50 dark:bg-emerald-900/20">
        <div class="text-3xl font-extrabold text-emerald-600">25+</div>
        <div class="text-sm text-gray-500 dark:text-slate-400 mt-1">Engineers</div>
      </div>
      <div class="text-center p-5 rounded-xl bg-amber-50 dark:bg-amber-900/20">
        <div class="text-3xl font-extrabold text-amber-600">8+</div>
        <div class="text-sm text-gray-500 dark:text-slate-400 mt-1">Avg Yrs</div>
      </div>
      <div class="text-center p-5 rounded-xl bg-purple-50 dark:bg-purple-900/20">
        <div class="text-3xl font-extrabold text-purple-600">50+</div>
        <div class="text-sm text-gray-500 dark:text-slate-400 mt-1">Countries</div>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-6 text-center">{t('people.subtitle')}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          depts.map((dept) => (
            <a
              href={p('/' + dept.link)}
              class="block p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:shadow-md transition-shadow"
            >
              <div class="text-3xl mb-3">{dept.icon}</div>
              <h3 class="font-semibold text-lg text-gray-900 dark:text-slate-100">{t('people.' + dept.key)}</h3>
              <p class="mt-2 text-sm text-gray-500 dark:text-slate-400 leading-relaxed">
                {t('people.' + dept.key + 'Desc')}
              </p>
              <span class="mt-3 inline-block text-sky-600 text-sm font-medium">
                {t('people.engineeringCta')} &rarr;
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="text-center p-10 rounded-2xl bg-gradient-to-r from-sky-600 to-blue-700 text-white">
      <h2 class="text-2xl font-bold">{t('people.joinTitle')}</h2>
      <p class="mt-2 text-white/80 max-w-lg mx-auto">{t('people.joinDesc')}</p>
      <a
        href={p('/contact')}
        class="mt-5 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white text-sky-700 font-semibold hover:bg-sky-50 transition-colors"
      >
        {t('people.joinCta')} &rarr;
      </a>
    </section>
  </div>
</Layout>
