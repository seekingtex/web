---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { languages, defaultLang, ui } from '~/i18n/config';
import ExperienceLayer from '~/components/content/ExperienceLayer.astro';
import RelatedPages from '~/components/content/RelatedPages.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = (key: string) => (ui as any)[lang]?.[key] || (ui as any)[defaultLang]?.[key] || key;

const metadata = {
  title: `${t('engineeringPerfection.title') || 'Engineering Perfection — Textile Manufacturing Excellence'} | ${SITE.name}`,
  description:
    t('engineeringPerfection.desc') ||
    `${SITE.name}'s engineering philosophy: precision manufacturing, premium material selection, rigorous quality control, and segment-specific design for performance, industrial, medical, and recreational fabrics.`,
};

const crumbs = [
  { name: 'Home', href: `/${lang}/` },
  { name: t('engineeringPerfection.nav') || 'Engineering Perfection' },
];

const pillars = [
  {
    title: t('engineeringPerfection.p1') || 'Superior Material Sourcing',
    content:
      t('engineeringPerfection.p1desc') ||
      'We invest considerable resources in identifying, testing, and procuring the finest yarns, fibers, and finishes available globally. We do not compromise on material specifications for cost savings. Our sourcing protocol includes batch testing for tensile strength, tear resistance, color fastness, and UV stability.',
  },
  {
    title: t('engineeringPerfection.p2') || 'Precision Engineering & Design',
    content:
      t('engineeringPerfection.p2desc') ||
      'Our design team comprises experienced textile engineers who leverage advanced CAD software and real-world testing to create fabrics that are performance-optimized, exceptionally durable, and robust. Every weave, finish, and construction detail is meticulously planned and analyzed.',
  },
  {
    title: t('engineeringPerfection.p3') || 'Craftsmanship & Manufacturing Excellence',
    content:
      t('engineeringPerfection.p3desc') ||
      'Seekingtex employs highly skilled technicians who are masters of their craft. Our production facility is equipped with state-of-the-art weaving machines and finishing equipment. We foster a culture of meticulousness, where attention to detail is paramount at every stage of production.',
  },
  {
    title: t('engineeringPerfection.p4') || 'Rigorous Quality Control & Testing',
    content:
      t('engineeringPerfection.p4desc') ||
      'Quality is built in from the very beginning. We implement a multi-layered QC system with stringent checks at each critical step, culminating in comprehensive final testing including GSM verification, tensile strength testing, color fastness assessment, dimensional stability checks, and functional performance tests.',
  },
];

const segments = [
  {
    name: t('engineeringPerfection.s1') || 'Performance Fabrics',
    desc:
      t('engineeringPerfection.s1desc') ||
      'High-tenacity polyester and nylon blends with advanced finishes for maximum durability and comfort in active use.',
  },
  {
    name: t('engineeringPerfection.s2') || 'Industrial Textiles',
    desc:
      t('engineeringPerfection.s2desc') ||
      'Exceptional durability and chemical resistance. Features include reinforced construction, heavy-duty finishes, and specialized coatings for demanding environments.',
  },
  {
    name: t('engineeringPerfection.s3') || 'Medical & Healthcare',
    desc:
      t('engineeringPerfection.s3desc') ||
      'Antimicrobial, fluid-repellent fabrics designed for healthcare environments with easy-care properties and industrial launderability.',
  },
  {
    name: t('engineeringPerfection.s4') || 'Uniform & Corporate',
    desc:
      t('engineeringPerfection.s4desc') ||
      'Versatile fabrics for professional attire with high priority on appearance retention, comfort, wrinkle resistance, and ease of care.',
  },
];
---

<Layout metadata={metadata} breadcrumbs={crumbs}>
  <section class="px-6 sm:px-6 py-16 sm:py-20 lg:py-24 mx-auto max-w-5xl text-center">
    <p class="text-sm font-semibold text-primary uppercase tracking-wider">
      {t('engineeringPerfection.badge') || 'Manufacturing Philosophy'}
    </p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold">
      {t('engineeringPerfection.heading') || 'Engineering Perfection'}
    </h1>
    <p class="mt-3 text-lg text-muted max-w-3xl mx-auto">
      {
        t('engineeringPerfection.subtitle') ||
          'Seekingtex was founded on a simple yet profound principle: to produce perfect products. This is not a marketing slogan — it is the bedrock of our operational philosophy, driving every material selection, design decision, and quality control protocol.'
      }
    </p>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-4xl space-y-12">
    {
      pillars.map((p, i) => (
        <div class={`grid md:grid-cols-2 gap-8 items-center ${i % 2 === 1 ? 'md:order-2' : ''}`}>
          <div class={i % 2 === 1 ? 'md:order-2' : ''}>
            <h2 class="text-xl font-bold">{p.title}</h2>
            <p class="mt-3 text-muted leading-relaxed">{p.content}</p>
          </div>
          <div
            class={`bg-gray-50 dark:bg-gray-900 rounded-xl p-8 border border-gray-200 dark:border-gray-800 ${i % 2 === 1 ? 'md:order-1' : ''}`}
          >
            <span class="text-4xl font-bold text-primary">0{i + 1}</span>
          </div>
        </div>
      ))
    }
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-6xl bg-gray-50 dark:bg-gray-900">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">
        {t('engineeringPerfection.segBadge') || 'Specialized Segments'}
      </p>
      <h2 class="mt-2 text-3xl font-bold">{t('engineeringPerfection.segTitle') || 'Tailored for Performance'}</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      {
        segments.map((s) => (
          <div class="p-6 rounded-xl bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
            <h3 class="text-lg font-bold">{s.name}</h3>
            <p class="mt-2 text-muted text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="px-6 sm:px-6 py-16 mx-auto max-w-4xl">
    <div class="rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-8">
      <h2 class="text-2xl font-bold text-center">
        {t('engineeringPerfection.artTitle') || 'The Art & Science of Manufacturing'}
      </h2>
      <p class="mt-4 text-muted leading-relaxed text-center max-w-3xl mx-auto">
        {
          t('engineeringPerfection.artDesc') ||
            'From precision yarn selection and advanced weaving/knitting technology to controlled-environment finishing and exhaustive multi-stage testing, every Seekingtex fabric represents the pinnacle of textile manufacturing. Our production process is designed to prevent common defects — yarn breaks, uneven dyeing, shrinkage, dimensional inconsistencies — before they can occur.'
        }
      </p>
      <div class="text-center mt-8">
        <a
          href={`/${lang}/contact`}
          class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-md hover:bg-primary/90"
        >
          {t('engineeringPerfection.cta') || 'Discuss your project'} →
        </a>
      </div>
    </div>
  </section>
  <ExperienceLayer
    title={t('engineeringPerfection.expTitle') || 'Engineering Philosophy in Practice'}
    subtitle={t('engineeringPerfection.expSub') ||
      'Real examples of how our engineering standards translate into field performance.'}
    stories={[
      {
        quote:
          "We tested five manufacturers' fabrics for our uniform program. After 500 industrial launderings, the Seekingtex fabrics had the lowest failure rate — less than 2% vs 8-15% for competitors.",
        narrative:
          'A European hospitality group conducted a year-long comparative test of performance fabrics from five manufacturers for their 200-property uniform program. After 500 industrial launderings per batch, the Seekingtex fabrics showed the least color fade, the fewest seam failures, and the best dimensional stability.',
        context: 'Hospitality uniform comparison, Mediterranean, 2024',
        source: 'Procurement Director',
      },
      {
        quote:
          'When a customer reported pilling after six months, we traced it to an incompatible washing detergent. The fabric itself was still structurally perfect.',
        narrative:
          "Seekingtex's quality team investigates every quality claim thoroughly. In this case, fabric returned with pilling after six months was found to have no manufacturing defects — the weave structure, dye penetration, and finish were all within specification.",
        context: 'Quality analysis, North America, 2024',
        source: 'Quality Assurance Team',
      },
    ]}
  />
  <RelatedPages
    title={t('engineeringPerfection.relatedTitle') || 'Explore More'}
    subtitle={t('engineeringPerfection.relatedSub') || 'Related engineering and manufacturing resources'}
    links={[
      {
        title: t('engineeringPerfection.rel1') || 'Quality Control & Testing',
        description:
          t('engineeringPerfection.rel1desc') ||
          'Multi-layered QC system with stringent checks at each critical manufacturing step.',
        href: `/${lang}/quality`,
        label: 'Quality',
      },
      {
        title: t('engineeringPerfection.rel2') || 'R&D Center',
        description:
          t('engineeringPerfection.rel2desc') ||
          'Our research facilities including Textile Testing Lab, Materials Analysis Lab, and Prototype Workshop.',
        href: `/${lang}/randdcenter`,
        label: 'R&D',
      },
      {
        title: t('engineeringPerfection.rel3') || 'Factory Overview',
        description:
          t('engineeringPerfection.rel3desc') ||
          '12,000 m² facility with advanced weaving, finishing, and custom production lines.',
        href: `/${lang}/factory`,
        label: 'Facility',
      },
      {
        title: t('engineeringPerfection.rel4') || 'Design & Innovation',
        description:
          t('engineeringPerfection.rel4desc') ||
          'Full-service design studio for custom ODM projects, from concept to production.',
        href: `/${lang}/design-powerhouse`,
        label: 'Design',
      },
    ]}
  />
</Layout>
