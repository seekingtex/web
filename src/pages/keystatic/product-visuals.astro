---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/product-visuals.yaml';

interface VisualEntry {
  id: string;
  image: string;
}

const defaultVisuals: VisualEntry[] = [
  { id: 'upf50-polyester', image: '/images/seekingtex/products/fabric-upf50.webp' },
  { id: 'waterproof-breathable', image: '/images/seekingtex/products/fabric-waterproof.webp' },
  { id: 'quick-dry-mesh', image: '/images/seekingtex/products/fabric-quickdry.webp' },
  { id: '4way-stretch', image: '/images/seekingtex/products/fabric-stretch.webp' },
  { id: 'antibacterial', image: '/images/seekingtex/products/fabric-antibacterial.webp' },
  { id: 'eco-recycled', image: '/images/seekingtex/products/fabric-recycled.webp' },
  { id: 'flame-retardant', image: '/images/seekingtex/products/fabric-fr.webp' },
  { id: 'high-tenacity', image: '/images/seekingtex/products/fabric-high-tenacity.webp' },
];

let visuals: VisualEntry[] = defaultVisuals.map((v) => ({ ...v }));
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed?.visuals && Array.isArray(parsed.visuals)) {
    visuals = parsed.visuals.map((v: any, i: number) => ({
      id: v.id || defaultVisuals[i]?.id || '',
      image: v.image || defaultVisuals[i]?.image || '',
    }));
  }
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}
---

<AdminLayout title="Product Visuals" active="visuals" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Product Visuals</h1>
    <p class="mt-1 text-sm text-gray-500">
      8 product image mappings (product ID → image path). Used on homepage and products page. File: <code
        class="font-mono">{file}</code
      >
    </p>
  </div>

  {
    loadError && (
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
        Failed to read: {loadError}
      </div>
    )
  }

  <form id="visuals-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    {
      visuals.map((v, i) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
          <h2 class="text-base font-semibold">
            <span class="text-xs text-gray-400 font-mono mr-2">#{i + 1}</span>
            <span class="font-mono text-sm">{v.id}</span>
          </h2>
          <input type="hidden" name={'v' + i + '.id'} value={v.id} />
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image Path</label>
            <input
              type="text"
              name={'v' + i + '.image'}
              value={v.image}
              placeholder="/images/seekingtex/products/..."
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
            />
          </div>
          {v.image && (
            <div class="flex items-center gap-3">
              <img src={v.image} alt="" class="w-16 h-16 object-cover rounded-lg border border-gray-200" />
              <span class="text-xs text-gray-400 truncate max-w-md">{v.image}</span>
            </div>
          )}
        </div>
      ))
    }

    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40"
    >
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500">File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline"
            >Cancel</a
          >
          <button
            id="submit-btn"
            type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md"
            >Save & Push</button
          >
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('visuals-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Pushing...';
        }

        const fd = new FormData(form);
        const visuals = [];
        for (let i = 0; i < 8; i++) {
          visuals.push({
            id: String(fd.get('v' + i + '.id') || '').trim(),
            image: String(fd.get('v' + i + '.image') || '').trim(),
          });
        }

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              format: 'yaml',
              path: file,
              sha,
              data: { visuals },
              commitMessage: 'Update product visuals',
            }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save & Push';
            }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save & Push';
          }
        }
      });
    })();
  </script>
</AdminLayout>
