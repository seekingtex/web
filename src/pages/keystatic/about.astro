---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/about.yaml';

const defaultData = {
  origin: {
    tagline: 'Our Origin',
    heading: 'Built on the water,<br />\n<span class="text-sky-600">driven by purpose</span>',
    paragraphs: [
      'Seekingtex started in a dedicated textile workshop with a stubborn belief: functional fabrics should be engineered like they matter — because they do.',
      'Our founders, two textile engineers, saw an industry where corners were cut, materials were downgraded, and quality was treated as a checkbox. They developed the first Seekingtex fabric not for profit, but to prove that performance textiles could also be genuinely reliable.',
      'That first fabric standard is still in production today. That principle never changed.',
      'We are not the biggest manufacturer. We do not make the cheapest products. But every roll that leaves our workshop passes through the same hands that started the company — and meets the same standard that first fabric set.',
    ],
    image: '/images/seekingtex/hero/tech-meeting-small.webp',
    image_alt: 'Seekingtex coastal workshop',
  },
  philosophy: {
    tagline: 'Our Philosophy',
    heading: 'Rooted in Performance',
    description:
      'Performance is not an accident. Every fabric design starts with understanding how materials behave, how conditions change, and how textiles must respond.',
    cards: [
      {
        emoji: '\u{1F30A}',
        title: 'Respect the Application',
        description:
          'Every application is unique. Our fabrics are engineered to meet specific performance targets — UPF protection, waterproofness, breathability, antimicrobial effectiveness — not generic specifications.',
      },
      {
        emoji: '\u{1F527}',
        title: 'Built to Last, Not to Replace',
        description:
          'The most sustainable product is the one that does not need replacing. OEKO-TEX certified materials, precision coatings, and quality construction are chosen for longevity. We stand behind every roll we ship.',
      },
      {
        emoji: '\u{1F3C6}',
        title: 'Accessible by Design',
        description:
          'Performance fabrics should not be a luxury. We engineer textiles that deliver professional-grade performance at a price that makes sense for brands, manufacturers, and small businesses — not just large corporations.',
      },
    ],
  },
  design: {
    tagline: 'Design Philosophy',
    heading: 'Engineered for the edge<br />\n<span class="text-sky-600">of conditions</span>',
    paragraphs: [
      'Every Seekingtex product starts with one question: <em>what is the worst condition this will face?</em> We design from the edge inward, not from the center outward.',
      'Our fabrics are engineered to exceed industry standards —not because minimums are insufficient for typical use, but because real-world applications demand headroom. Every yarn, weave, and finish is selected with the most demanding use case in mind.',
      'We do not design to a price point. We design to a failure point —then build well above it.',
    ],
    image: '/images/seekingtex/hero/hero-4.webp',
    image_alt: 'Seekingtex design and engineering',
    stats: [
      { value: '50+', label: 'countries<br />served' },
      { value: '1,500+', label: 'UV hours<br />tested' },
      { value: '200+', label: 'skilled<br />workers' },
    ],
  },
};

let data = JSON.parse(JSON.stringify(defaultData));
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed && typeof parsed === 'object') {
    data = { ...data, ...parsed };
  }
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}
---

<AdminLayout title="About Page" active="about" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">About Page Content</h1>
    <p class="mt-1 text-sm text-gray-500">
      Brand story, philosophy, and design content for the /about page. File: <code class="font-mono">{file}</code>
    </p>
  </div>

  {
    loadError && (
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
        Failed to read: {loadError}
      </div>
    )
  }

  <form id="about-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    <!-- Origin Story -->
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
      <h2 class="text-base font-semibold">Brand Origin Story</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
          <input
            type="text"
            name="origin.tagline"
            value={data.origin?.tagline || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Heading (HTML allowed)</label>
          <input
            type="text"
            name="origin.heading"
            value={data.origin?.heading || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
          />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Paragraphs</label>
        <div class="space-y-2" id="origin-paragraphs">
          {
            (data.origin?.paragraphs || ['']).map((p: string, i: number) => (
              <textarea
                name={'origin.paragraph' + i}
                rows="3"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm paragraph-input"
              >
                {p || ''}
              </textarea>
            ))
          }
          <div class="flex gap-2">
            <button
              type="button"
              onclick="addParagraph('origin')"
              class="text-xs px-3 py-1.5 bg-gray-100 dark:bg-gray-800 rounded-md hover:bg-gray-200 dark:hover:bg-gray-700"
              >+ Add paragraph</button
            >
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image Path</label>
          <input
            type="text"
            name="origin.image"
            value={data.origin?.image || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image Alt Text</label>
          <input
            type="text"
            name="origin.image_alt"
            value={data.origin?.image_alt || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
      </div>
      {
        data.origin?.image && (
          <img src={data.origin.image} alt="" class="h-24 rounded-lg border border-gray-200 object-cover" />
        )
      }
    </div>

    <!-- Philosophy -->
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
      <h2 class="text-base font-semibold">Ocean Philosophy Section</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
          <input
            type="text"
            name="philosophy.tagline"
            value={data.philosophy?.tagline || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Heading</label>
          <input
            type="text"
            name="philosophy.heading"
            value={data.philosophy?.heading || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
        <textarea
          name="philosophy.description"
          rows="3"
          class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          >{data.philosophy?.description || ''}</textarea
        >
      </div>
      <div class="space-y-4">
        {
          (data.philosophy?.cards || []).map((card: any, i: number) => (
            <div class="border border-gray-100 dark:border-gray-700 rounded-lg p-4 space-y-3">
              <h3 class="text-sm font-semibold text-gray-500">Card #{i + 1}</h3>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">Emoji</label>
                  <input
                    type="text"
                    name={'philosophy.card' + i + '.emoji'}
                    value={card.emoji || ''}
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
                  />
                </div>
                <div>
                  <label class="block text-xs font-medium text-gray-500 mb-1">Title</label>
                  <input
                    type="text"
                    name={'philosophy.card' + i + '.title'}
                    value={card.title || ''}
                    class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
                  />
                </div>
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Description</label>
                <textarea
                  name={'philosophy.card' + i + '.description'}
                  rows="3"
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
                >
                  {card.description || ''}
                </textarea>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Design Philosophy -->
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
      <h2 class="text-base font-semibold">Design Philosophy Section</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tagline</label>
          <input
            type="text"
            name="design.tagline"
            value={data.design?.tagline || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Heading (HTML allowed)</label>
          <input
            type="text"
            name="design.heading"
            value={data.design?.heading || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
          />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Paragraphs</label>
        <div class="space-y-2" id="design-paragraphs">
          {
            (data.design?.paragraphs || ['']).map((p: string, i: number) => (
              <textarea
                name={'design.paragraph' + i}
                rows="3"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm paragraph-input"
              >
                {p || ''}
              </textarea>
            ))
          }
          <div class="flex gap-2">
            <button
              type="button"
              onclick="addParagraph('design')"
              class="text-xs px-3 py-1.5 bg-gray-100 dark:bg-gray-800 rounded-md hover:bg-gray-200 dark:hover:bg-gray-700"
              >+ Add paragraph</button
            >
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image Path</label>
          <input
            type="text"
            name="design.image"
            value={data.design?.image || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Image Alt Text</label>
          <input
            type="text"
            name="design.image_alt"
            value={data.design?.image_alt || ''}
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
          />
        </div>
      </div>
      {
        data.design?.image && (
          <img src={data.design.image} alt="" class="h-24 rounded-lg border border-gray-200 object-cover" />
        )
      }
      <div class="grid grid-cols-3 gap-4">
        {
          (data.design?.stats || []).map((s: any, i: number) => (
            <div class="border border-gray-100 dark:border-gray-700 rounded-lg p-3 space-y-2">
              <h3 class="text-xs font-semibold text-gray-500">Stat #{i + 1}</h3>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Value</label>
                <input
                  type="text"
                  name={'design.stat' + i + '.value'}
                  value={s.value || ''}
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
                />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1">Label (HTML allowed)</label>
                <input
                  type="text"
                  name={'design.stat' + i + '.label'}
                  value={s.label || ''}
                  class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm font-mono"
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40"
    >
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500">File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline"
            >Cancel</a
          >
          <button
            id="submit-btn"
            type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md"
            >Save & Push</button
          >
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('about-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;

      window.addParagraph = function (prefix) {
        const container = document.getElementById(prefix + '-paragraphs');
        if (!container) return;
        const textarea = document.createElement('textarea');
        textarea.name = prefix + '.paragraph' + container.querySelectorAll('textarea.paragraph-input').length;
        textarea.rows = 3;
        textarea.className =
          'w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm paragraph-input';
        container.insertBefore(textarea, container.lastElementChild);
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Pushing...';
        }

        const fd = new FormData(form);

        function collectParagraphs(prefix) {
          const out = [];
          for (let i = 0; i < 20; i++) {
            const val = fd.get(prefix + '.paragraph' + i);
            if (val !== null && String(val).trim()) out.push(String(val).trim());
            else if (val !== null) break;
          }
          return out;
        }

        const data = {
          origin: {
            tagline: String(fd.get('origin.tagline') || '').trim(),
            heading: String(fd.get('origin.heading') || '').trim(),
            paragraphs: collectParagraphs('origin'),
            image: String(fd.get('origin.image') || '').trim(),
            image_alt: String(fd.get('origin.image_alt') || '').trim(),
          },
          philosophy: {
            tagline: String(fd.get('philosophy.tagline') || '').trim(),
            heading: String(fd.get('philosophy.heading') || '').trim(),
            description: String(fd.get('philosophy.description') || '').trim(),
            cards: [0, 1, 2].map((i) => ({
              emoji: String(fd.get('philosophy.card' + i + '.emoji') || '').trim(),
              title: String(fd.get('philosophy.card' + i + '.title') || '').trim(),
              description: String(fd.get('philosophy.card' + i + '.description') || '').trim(),
            })),
          },
          design: {
            tagline: String(fd.get('design.tagline') || '').trim(),
            heading: String(fd.get('design.heading') || '').trim(),
            paragraphs: collectParagraphs('design'),
            image: String(fd.get('design.image') || '').trim(),
            image_alt: String(fd.get('design.image_alt') || '').trim(),
            stats: [0, 1, 2].map((i) => ({
              value: String(fd.get('design.stat' + i + '.value') || '').trim(),
              label: String(fd.get('design.stat' + i + '.label') || '').trim(),
            })),
          },
        };

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ format: 'yaml', path: file, sha, data, commitMessage: 'Update about page content' }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save & Push';
            }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => window.location.reload(), 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save & Push';
          }
        }
      });
    })();
  </script>
</AdminLayout>
