---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/trust-badges.yaml';

interface Badge {
  icon: string;
  title: string;
  desc: string;
  variant: string;
}

const defaults: Badge[] = [
  {
    icon: '\u2B50',
    title: 'ISO and CE Certified',
    desc: 'Every product meets international safety and quality standards.',
    variant: 'cert',
  },
  {
    icon: '\u2B50',
    title: 'Material Excellence',
    desc: 'Premium PVC and Hypalon fabrics tested for UV, abrasion, and temperature extremes.',
    variant: 'material',
  },
  {
    icon: '\u2B50',
    title: 'Rigorous Testing',
    desc: 'Each vessel undergoes pressure, buoyancy, and load tests before shipment.',
    variant: 'standard',
  },
  {
    icon: '\u2B50',
    title: '2-Year Warranty',
    desc: 'All Seekingtex products backed by comprehensive manufacturer warranty.',
    variant: 'warranty',
  },
];

let badges: Badge[] = defaults.map((b) => ({ ...b }));
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed?.badges && Array.isArray(parsed.badges)) {
    badges = parsed.badges.map((b: any, i: number) => ({
      icon: b.icon || defaults[i]?.icon || '\u2B50',
      title: b.title || defaults[i]?.title || '',
      desc: b.desc || defaults[i]?.desc || '',
      variant: b.variant || defaults[i]?.variant || 'standard',
    }));
  }
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}
---

<AdminLayout title="Trust Badges" active="trust" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Trust Badges</h1>
    <p class="mt-1 text-sm text-gray-500">
      4 trust badges shown on the homepage. File: <code class="font-mono">{file}</code>
    </p>
  </div>

  {
    loadError && (
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
        Failed to read: {loadError}
      </div>
    )
  }

  <form id="trust-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    {
      badges.map((badge, i) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
          <h2 class="text-base font-semibold">Badge {i + 1}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Title</label>
              <input
                type="text"
                name={'badge' + i + '.title'}
                value={badge.title}
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
                Icon (emoji or text)
              </label>
              <input
                type="text"
                name={'badge' + i + '.icon'}
                value={badge.icon}
                placeholder="Star emoji"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
              />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
            <textarea
              name={'badge' + i + '.desc'}
              rows="2"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
            >
              {badge.desc}
            </textarea>
          </div>
          <input type="hidden" name={'badge' + i + '.variant'} value={badge.variant} />
        </div>
      ))
    }

    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40"
    >
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500">File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline"
            >Cancel</a
          >
          <button
            id="submit-btn"
            type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md"
            >Save & Push</button
          >
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('trust-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Pushing...';
        }

        const fd = new FormData(form);
        const badges = [];
        for (let i = 0; i < 4; i++) {
          badges.push({
            icon: String(fd.get('badge' + i + '.icon') || '').trim(),
            title: String(fd.get('badge' + i + '.title') || '').trim(),
            desc: String(fd.get('badge' + i + '.desc') || '').trim(),
            variant: String(fd.get('badge' + i + '.variant') || 'standard').trim(),
          });
        }

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              format: 'yaml',
              path: file,
              sha,
              data: { badges },
              commitMessage: 'Update trust badges',
            }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save & Push';
            }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save & Push';
          }
        }
      });
    })();
  </script>
</AdminLayout>
