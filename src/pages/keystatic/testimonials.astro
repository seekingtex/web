---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/testimonials.yaml';

interface TestimonialEntry {
  name: string;
  quote: string;
  rating: number;
}

const defaultTestimonials: TestimonialEntry[] = [
  {
    name: 'Sarah K.',
    quote: 'Stable even for a complete beginner. Took it out on the lake my first day and never fell.',
    rating: 5,
  },
  {
    name: 'James T.',
    quote: 'Took it to Bali 鈥?packed in a backpack, inflated in 5 minutes. Perfect travel companion.',
    rating: 5,
  },
  {
    name: 'Mike R.',
    quote:
      'Excellent fabric quality. Handles industrial laundering way better than I expected from a standard textile.',
    rating: 5,
  },
];

let testimonials: TestimonialEntry[] = defaultTestimonials.map((t) => ({ ...t }));
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed?.testimonials && Array.isArray(parsed.testimonials)) {
    testimonials = parsed.testimonials.map((item: any, i: number) => ({
      name: item.name || defaultTestimonials[i]?.name || '',
      quote: item.quote || defaultTestimonials[i]?.quote || '',
      rating: typeof item.rating === 'number' ? item.rating : defaultTestimonials[i]?.rating || 5,
    }));
  }
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}
---

<AdminLayout title="Testimonials" active="testimonials" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Homepage Testimonials</h1>
    <p class="mt-1 text-sm text-gray-500">
      3 customer reviews displayed on the homepage community section. File: <code class="font-mono">{file}</code>
    </p>
  </div>

  {
    loadError && (
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
        Failed to read: {loadError}
      </div>
    )
  }

  <form id="testimonials-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    {
      testimonials.map((item, i) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
          <h2 class="text-base font-semibold">Review #{i + 1}</h2>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Reviewer Name</label>
            <input
              type="text"
              name={'t' + i + '.name'}
              value={item.name}
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Quote</label>
            <textarea
              name={'t' + i + '.quote'}
              rows="3"
              class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
            >
              {item.quote}
            </textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Rating <span class="text-gray-400 font-normal">(1鈥?)</span>
            </label>
            <input
              type="number"
              name={'t' + i + '.rating'}
              value={item.rating}
              min="1"
              max="5"
              class="w-20 px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
            />
          </div>
        </div>
      ))
    }

    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40"
    >
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500">File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline"
            >Cancel</a
          >
          <button
            id="submit-btn"
            type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md"
            >Save & Push</button
          >
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('testimonials-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Pushing...';
        }

        const fd = new FormData(form);
        const testimonials = [];
        for (let i = 0; i < 3; i++) {
          testimonials.push({
            name: String(fd.get('t' + i + '.name') || '').trim(),
            quote: String(fd.get('t' + i + '.quote') || '').trim(),
            rating: parseInt(String(fd.get('t' + i + '.rating') || '5'), 10) || 5,
          });
        }

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              format: 'yaml',
              path: file,
              sha,
              data: { testimonials },
              commitMessage: 'Update homepage testimonials',
            }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save & Push';
            }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save & Push';
          }
        }
      });
    })();
  </script>
</AdminLayout>
