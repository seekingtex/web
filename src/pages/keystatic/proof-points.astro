---
export const prerender = false;
import AdminLayout from '~/layouts/AdminLayout.astro';
import { verifySessionToken } from '~/lib/auth';
import { readTokenFromCookies } from '~/lib/token-store';
import { GitHubClient } from '~/lib/github';

const session = Astro.cookies.get('ks-admin-session')?.value;
const verified = session ? verifySessionToken(session) : null;
if (!verified) return Astro.redirect('/login');
const token = readTokenFromCookies(Astro.cookies);
if (!token) return Astro.redirect('/keystatic/github-token');

const file = 'src/data/site/proof-points.yaml';

interface PointEntry {
  id: string;
  metric: string;
  label: string;
  detail: string;
}

const defaultPoints: PointEntry[] = [
  {
    id: 'products',
    metric: '12',
    label: 'products across 6 categories',
    detail: 'UPF 50+, Waterproof, Quick-Dry, Antibacterial, Stretch, Eco-Friendly',
  },
  {
    id: 'countries',
    metric: '50+',
    label: 'countries served',
    detail: 'Global distribution network across EU, US, ASIA',
  },
  { id: 'founded', metric: '2012', label: 'founded', detail: 'Over a decade of functional textile manufacturing excellence' },
  {
    id: 'certified',
    metric: 'ISO',
    label: 'CE certified',
    detail: 'Every product meets international safety standards',
  },
];

let points: PointEntry[] = defaultPoints.map((p) => ({ ...p }));
let sha = '';
let loadError: string | null = null;

try {
  const client = new GitHubClient(token);
  const f = await client.readFile(file);
  const yamlMod = await import('js-yaml');
  const parsed = yamlMod.load(f.content) as Record<string, any>;
  if (parsed?.points && Array.isArray(parsed.points)) {
    points = parsed.points.map((p: any, i: number) => ({
      id: p.id || defaultPoints[i]?.id || '',
      metric: p.metric || defaultPoints[i]?.metric || '',
      label: p.label || defaultPoints[i]?.label || '',
      detail: p.detail || defaultPoints[i]?.detail || '',
    }));
  }
  sha = f.sha;
} catch (err) {
  loadError = err instanceof Error ? err.message : 'Failed to read';
}
---

<AdminLayout title="Proof Points" active="proofs" username={verified?.username}>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Proof Points (Stats)</h1>
    <p class="mt-1 text-sm text-gray-500">
      4 statistics shown on the homepage CTA section. File: <code class="font-mono">{file}</code>
    </p>
  </div>

  {
    loadError && (
      <div class="mb-4 rounded-md border border-red-200 bg-red-50 dark:bg-red-950/40 dark:border-red-900 p-3 text-sm text-red-700 dark:text-red-300">
        Failed to read: {loadError}
      </div>
    )
  }

  <form id="proofs-form" class="space-y-6 pb-32" data-file={file} data-sha={sha}>
    {
      points.map((p, i) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-6 space-y-4">
          <h2 class="text-base font-semibold">
            <span class="text-xs text-gray-400 font-mono mr-2">#{i + 1}</span>
            {p.id}
          </h2>
          <input type="hidden" name={'p' + i + '.id'} value={p.id} />

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Metric (big number)</label>
              <input
                type="text"
                name={'p' + i + '.metric'}
                value={p.metric}
                placeholder="12"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Label</label>
              <input
                type="text"
                name={'p' + i + '.label'}
                value={p.label}
                placeholder="products across 6 categories"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Detail</label>
              <input
                type="text"
                name={'p' + i + '.detail'}
                value={p.detail}
                placeholder="UPF 50+, Waterproof, Antibacterial, Stretch, Eco-Friendly"
                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-700 rounded-md bg-white dark:bg-gray-900 text-sm"
              />
            </div>
          </div>
        </div>
      ))
    }

    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800 z-40"
    >
      <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
        <div class="text-xs text-gray-500">File: <code class="font-mono">{file}</code></div>
        <div class="flex gap-2">
          <a href="/keystatic" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:underline"
            >Cancel</a
          >
          <button
            id="submit-btn"
            type="submit"
            class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md"
            >Save & Push</button
          >
        </div>
      </div>
    </div>
  </form>

  <script is:inline>
    (function () {
      const form = document.getElementById('proofs-form');
      if (!form) return;
      const submitBtn = document.getElementById('submit-btn');
      const file = form.dataset.file;
      const sha = form.dataset.sha;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Pushing...';
        }

        const fd = new FormData(form);
        const points = [];
        for (let i = 0; i < 4; i++) {
          points.push({
            id: String(fd.get('p' + i + '.id') || '').trim(),
            metric: String(fd.get('p' + i + '.metric') || '').trim(),
            label: String(fd.get('p' + i + '.label') || '').trim(),
            detail: String(fd.get('p' + i + '.detail') || '').trim(),
          });
        }

        try {
          const res = await fetch('/api/admin/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              format: 'yaml',
              path: file,
              sha,
              data: { points },
              commitMessage: 'Update proof points',
            }),
          });
          const result = await res.json();
          if (!res.ok || !result.success) {
            window.__adminToast?.(result.error || 'Save failed', 'error');
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Save & Push';
            }
            return;
          }
          window.__adminToast?.('Saved, Cloudflare is redeploying...', 'success');
          setTimeout(() => {
            window.location.reload();
          }, 800);
        } catch {
          window.__adminToast?.('Network error', 'error');
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save & Push';
          }
        }
      });
    })();
  </script>
</AdminLayout>
