---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Media Center & Press Coverage — News, Events & Media Resources | ${SITE.name}`,
  description: `Seekingtex media center. Press releases, company news, product launches, trade show appearances, and downloadable media resources for journalists and partners.`,
  ignoreTitleTemplate: true,
};

const pressReleases = [
  { date: '2026-06-15', title: 'Seekingtex Launches UPF 50+ Eco Series — Sustainable Sun-Protection Fabric Line', summary: 'New eco-friendly fabric line features recycled polyester with certified UPF 50+ protection and bluesign approval.', href: '/news/upf-50-eco-series-launch' },
  { date: '2026-05-20', title: 'Seekingtex Receives ISO 14001 Environmental Management Certification', summary: 'Suzhou facility earns ISO 14001 certification for environmental management systems and sustainable textile manufacturing practices.', href: '/news/iso-14001-certification' },
  { date: '2026-04-10', title: 'Seekingtex Partners with US Uniform Supplier for Tactical Fabric Contract', summary: 'Strategic partnership to supply high-tenacity FR fabrics for law enforcement and military uniforms across the United States.', href: '/news/us-uniform-partnership' },
  { date: '2026-03-05', title: 'Seekingtex Opens Textile R&D Innovation Center in Suzhou', summary: 'New 2,000 m² research and development facility houses textile lab, coating development center, and sample workshop.', href: '/news/seekingtex-rd-center-innovation' },
  { date: '2026-02-18', title: 'Seekingtex Antibacterial Fabric Receives OEKO-TEX Standard 100 Certification', summary: 'Complete fabric range certified to OEKO-TEX Standard 100 for consumer safety and chemical compliance.', href: '/news/antibacterial-oeko-tex' },
  { date: '2026-01-22', title: 'Seekingtex Debuts Recycled Polyester Initiative Across Fabric Lines', summary: 'Company-wide sustainability program introduces GRS-certified recycled polyester in performance fabric collections.', href: '/news/recycled-polyester-initiative' },
];

const events = [
  { date: '2026-09-15', title: 'Intertextile Shanghai 2026', location: 'Shanghai, China', booth: 'Hall 5, Stand 1425', desc: 'Showcasing 2027 fabric collection and new sustainable textile series.' },
  { date: '2026-11-08', title: 'Techtextil 2026', location: 'Frankfurt, Germany', booth: 'Hall 10, Stand 312', desc: 'International technical textiles trade show. OEM/ODM partnership meetings.' },
];

const mediaKit = [
  { title: 'Brand Guidelines', desc: 'Seekingtex logo files, color palette, typography, and brand usage guidelines.', icon: 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z' },
  { title: 'Fabric Photography', desc: 'High-resolution fabric and product images for editorial and commercial use.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { title: 'Factory Tour Video', desc: 'B-roll footage of manufacturing facility, production lines, and quality testing laboratory.', icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z' },
  { title: 'Executive Bios', desc: 'Biographical information and headshots for executive team and engineering leadership.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
];
---

<Layout metadata={metadata}>
  <JsonLd type="BreadcrumbList" breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Media Center' }]} />
  <JsonLd type="Article"
    article={{
      headline: 'Seekingtex Media Center & Press Coverage',
      description: 'Press releases, events, and media resources for journalists and partners.',
      datePublished: '2026-07-07',
    }}
    data={{ url: 'https://seekingtex.com/media' }}
  />

  <section class="max-w-5xl mx-auto py-24 px-6 text-center">
    <span class="text-xs font-medium uppercase tracking-[0.2em] text-sky-600">Media Center</span>
    <h1 class="mt-4 text-4xl md:text-5xl font-bold text-gray-900">Press & Media Resources</h1>
    <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">Press releases, product announcements, trade show appearances, and downloadable media assets.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="#press" class="px-6 py-3 bg-gray-900 text-white rounded-full text-sm font-medium hover:bg-gray-800 transition">Press Releases</a>
      <a href="#events" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition">Upcoming Events</a>
      <a href="/contact" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-gray-400 transition">Media Inquiries</a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto pb-24 px-6" id="press">
    <div class="flex items-center gap-4 mb-10">
      <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900">Press Releases</h2>
    </div>
    <div class="divide-y divide-gray-200 border border-gray-200 rounded-2xl overflow-hidden">
      {pressReleases.map((pr) => (
        <a href={pr.href} class="flex items-start gap-4 px-6 py-5 bg-white hover:bg-gray-50 transition-colors group">
          <div class="text-center shrink-0 w-12">
            <span class="block text-xs font-bold text-gray-400 uppercase">{pr.date.slice(5, 7)}/{pr.date.slice(8, 10)}</span>
            <span class="block text-sm font-bold text-gray-900">{pr.date.slice(0, 4)}</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-gray-900 group-hover:text-sky-600 transition-colors">{pr.title}</h3>
            <p class="mt-1 text-sm text-gray-500">{pr.summary}</p>
          </div>
          <span class="text-sky-600 group-hover:translate-x-1 transition-transform shrink-0">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-gray-50 py-24 px-6" id="events">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900">Upcoming Events</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {events.map((e) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6">
            <span class="text-sm font-semibold text-amber-600">{e.date}</span>
            <h3 class="mt-1 text-lg font-semibold text-gray-900">{e.title}</h3>
            <p class="text-sm text-gray-500">{e.location}</p>
            <p class="text-sm text-gray-500">Booth: {e.booth}</p>
            <p class="mt-2 text-sm text-gray-600">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto py-24 px-6">
    <div class="flex items-center gap-4 mb-10">
      <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900">Media Kit</h2>
    </div>
    <p class="text-gray-500 mb-10">Resources for journalists, analysts, and content creators covering Seekingtex.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {mediaKit.map((m) => (
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
          <svg class="w-8 h-8 text-sky-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={m.icon} /></svg>
          <h3 class="font-semibold text-gray-900">{m.title}</h3>
          <p class="mt-1 text-sm text-gray-500">{m.desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900 text-white rounded-full font-semibold hover:bg-gray-800 transition">
        Request Media Access
        <span>→</span>
      </a>
    </div>
  </section>
</Layout>
