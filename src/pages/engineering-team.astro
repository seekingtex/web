---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';

const metadata = {
  title: `Engineering & R&D Team — Functional Textile Design & Manufacturing | ${SITE.name}`,
  description: `${SITE.name}'s 25+ R&D engineers and production specialists. Expertise in weave engineering, coating technology, fabric finishing, and OEKO-TEX compliance. Based in Suzhou, China.`,
  ignoreTitleTemplate: true,
};

const teamMembers = [
  {
    name: 'Peng Zhang',
    role: 'Director of Engineering',
    experience: '18 years in textile engineering, formerly at ISO accredited textile manufacturers.',
    expertise: ['Weave structure engineering', 'Yarn formulation & composite layup', 'OEKO-TEX compliance design'],
    area: 'Product Architecture & Compliance',
  },
  {
    name: 'Lina Chen',
    role: 'Senior Materials Engineer',
    experience:
      '12 years specializing in polymer coating technology, laminate development, and accelerated aging testing.',
    expertise: ['PU & acrylic coating formulation', 'Lamination & bond optimization', 'ASTM tensile & tear testing'],
    area: 'Materials Science Lab',
  },
  {
    name: 'Wei Liu',
    role: 'Product Design Lead',
    experience: '15 years in textile product design. 40+ fabric platform designs in production.',
    expertise: ['CAD weave design (NedGraphics, Arahne)', 'Coating process optimization', 'Color & finish development'],
    area: 'Design & Sampling',
  },
  {
    name: 'James Huang',
    role: 'Quality Systems Manager',
    experience: '10 years managing ISO QMS for textile manufacturing. Lead auditor for OEKO-TEX and BSCI compliance.',
    expertise: ['ISO 9001 internal auditing', '100-point QC workflow design', 'Supplier quality traceability systems'],
    area: 'Quality Assurance',
  },
  {
    name: 'Mei Wang',
    role: 'Coating & Finish Specialist',
    experience:
      '14 years in functional coating and finishing, including waterproof, FR, and antibacterial applications.',
    expertise: [
      'PU coating & formulation',
      'DWR & stain-resistant application',
      'Hydrostatic head testing & optimization',
    ],
    area: 'Coating Production Line',
  },
  {
    name: 'Dong Li',
    role: 'OEM/ODM Project Engineer',
    experience: '9 years managing custom manufacturing programs for European, North American, and Asian brands.',
    expertise: [
      'Technical proposal & BOM engineering',
      'Custom fabric development through production ramp',
      'Multi-language specification management',
    ],
    area: 'OEM Programs',
  },
];

const researchAreas = [
  {
    title: 'Microporous Coating Technology',
    desc: 'Developing breathable waterproof coatings that maintain UPF 50+ while achieving moisture vapor transmission rates above 5000 g/m²/24h.',
  },
  {
    title: 'Bio-Based & Recycled Fiber Integration',
    desc: 'Incorporating recycled polyester and bio-based nylon into performance fabrics while maintaining tensile strength and color consistency.',
  },
  {
    title: 'Antibacterial Finish Durability',
    desc: 'Extended wash-cycle testing for silver-ion and zinc-based antibacterial finishes targeting 50+ industrial washes with >99% bacterial reduction.',
  },
  {
    title: 'Automated QC Vision System',
    desc: 'Machine vision integration for real-time coating thickness, weave defect detection, and color uniformity on continuous production lines.',
  },
];
---

<Layout metadata={metadata}>
  <JsonLd
    type="Article"
    article={{
      headline: 'Engineering & R&D Team — Functional Textile Design & Manufacturing',
      description:
        "Meet the 25+ R&D engineers and production specialists behind Seekingtex's functional textile manufacturing.",
      datePublished: '2026-07-07',
    }}
    data={{ url: 'https://seekingtex.com/engineering-team' }}
  />
  <JsonLd
    type="BreadcrumbList"
    breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'About', href: '/about' }, { name: 'Engineering Team' }]}
  />

  <section class="bg-gradient-to-br from-[#001830] via-[#002d4a] to-[#003355] text-white py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <span class="text-xs font-medium uppercase tracking-[0.2em] text-sky-300">R&D & Engineering</span>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight">The People Behind the Fabric</h1>
      <p class="mt-4 text-lg text-white/70">
        25+ engineers and specialists across textile science, product design, quality engineering, and production
        management.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {
          ['Textile Science', 'Product Design', 'Quality Engineering', 'OEM Programs', 'Coating Technology'].map(
            (tag) => <span class="px-4 py-2 border border-white/20 text-white/80 text-sm rounded-full">{tag}</span>
          )
        }
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-24 px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-semibold text-gray-900 dark:text-gray-100">Engineering Leadership</h2>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
        Key members of our R&D and production engineering team.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        teamMembers.map((m) => (
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center mb-4">
              <span class="text-2xl font-bold text-sky-600 dark:text-sky-400">{m.name.charAt(0)}</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">{m.name}</h3>
            <p class="text-sm text-sky-600 dark:text-sky-400 font-medium">{m.role}</p>
            <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{m.experience}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {m.expertise.map((e) => (
                <span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 px-2 py-1 rounded">
                  {e}
                </span>
              ))}
            </div>
            <div class="mt-3 pt-3 border-t border-gray-100 dark:border-gray-800">
              <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">{m.area}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-gray-50 dark:bg-gray-950 py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-semibold text-gray-900 dark:text-gray-100">Active Research & Development</h2>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
          Current engineering projects focused on material performance, manufacturing quality, and product innovation.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {
          researchAreas.map((r) => (
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-2 h-2 rounded-full bg-sky-500" />
                <h3 class="font-semibold text-gray-900 dark:text-gray-100">{r.title}</h3>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400">{r.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto py-24 px-6 text-center">
    <h2 class="text-3xl font-semibold text-gray-900 dark:text-gray-100">Join the Engineering Team</h2>
    <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
      We are always looking for talented engineers in textile science, product design, and quality engineering.
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="/contact"
        class="px-10 py-4 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-full font-semibold hover:bg-gray-800 dark:hover:bg-gray-100 transition"
        >Contact Us</a
      >
      <a
        href="/about/seekingtex"
        class="px-10 py-4 border-2 border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 rounded-full font-semibold hover:border-gray-400 transition"
        >About Seekingtex</a
      >
    </div>
  </section>

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>
      Seekingtex R&D and engineering team: 25+ engineers across textile science, product design, quality assurance, and
      production engineering. Key personnel include Peng Zhang (Director of Engineering, 18 years), Lina Chen (Senior
      Materials Engineer, coating and laminate specialist), Wei Liu (Product Design Lead, 40+ platforms), James Huang
      (Quality Systems Manager, ISO lead auditor), Mei Wang (Coating & Finish Specialist, 14 years), and Dong Li
      (OEM/ODM Project Engineer, 9 years). Active research areas: microporous coating technology, bio-based fiber
      integration, antibacterial finish durability, and automated QC vision systems. Based in Suzhou, China. OEKO-TEX
      and ISO certified facility.
    </p>
  </section>
</Layout>
