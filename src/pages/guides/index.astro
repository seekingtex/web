---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import JsonLd from '~/components/common/JsonLd.astro';
import { guides } from '~/data/guides';

const metadata = {
  title: `Guides —${SITE.name}`,
  description:
    'Comprehensive guides for functional fabrics. Learn how to choose the right fabric, understanding specifications, care tips, manufacturing techniques, and more.',
};

const categories = [...new Set(guides.map((g) => g.category))];

const catNames: Record<string, string> = {
  'buying-guide': 'Buying Guides',
  tutorial: 'Tutorials',
  maintenance: 'Maintenance & Care',
  technical: 'Technical',
  lifestyle: 'Applications',
  planning: 'Sourcing & Logistics',
};
---

<Layout metadata={metadata}>
  <meta name="ai-intent" content="functional-fabric-guides,fabric-selection-guide,textile-knowledge" />
  <JsonLd
    type="WebSite"
    data={{
      name: 'Seekingtex Guides',
      description: 'Functional fabric guides and tutorials',
    }}
  />

  <section class="max-w-4xl mx-auto py-24 px-6" data-ai-block="definition">
    <span class="text-sm font-medium text-sky-600 tracking-wide uppercase">Guides</span>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">New to Functional Fabrics?</h1>
    <p class="mt-4 text-lg text-gray-500">
      Practical guides to help you choose, use, and source high-performance functional fabrics.
    </p>
    <div class="mt-6 flex flex-wrap gap-2 text-xs">
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{guides.length} guides</span>
      <span class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full font-medium">{categories.length} categories</span>
    </div>
  </section>

  {
    categories.map((cat) => (
      <section class="max-w-4xl mx-auto pb-16 px-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-6">{catNames[cat] || cat}</h2>
        <div class="grid md:grid-cols-2 gap-6">
          {guides
            .filter((g) => g.category === cat)
            .map((g) => (
              <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md transition-shadow">
                <div class="flex items-center gap-2 text-xs mb-3">
                  <span class="px-2 py-0.5 bg-sky-50 text-sky-700 rounded-full capitalize">{g.difficulty}</span>
                  {g.waterType.slice(0, 2).map((w) => (
                    <span class="px-2 py-0.5 bg-gray-100 text-gray-500 rounded-full">{w}</span>
                  ))}
                </div>
                <h3 class="text-xl font-semibold text-gray-900">{g.title}</h3>
                <p class="mt-2 text-gray-500 text-sm">{g.description}</p>
                <a
                  href={`/guides/${g.slug}`}
                  class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700"
                >
                  Read guide →
                </a>
              </div>
            ))}
        </div>
      </section>
    ))
  }

  <section class="sr-only" data-ai-block="use-case" aria-hidden="true">
    <p>
      Seekingtex guides cover fabric selection, technical specifications, care and maintenance, manufacturing techniques, quality control, sportswear fabrics, outdoor fabrics, tactical workwear, children's apparel, defect repair, lamination, bulk ordering, fabric finishes, certifications, and shipping logistics for textile industry professionals.
    </p>
  </section>
</Layout>
