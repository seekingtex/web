<script is:inline>
  (function () {
    // Carousel
    const slides = document.querySelectorAll('[data-carousel-slide]');
    const dots = document.querySelectorAll('[data-carousel-dot]');
    if (slides.length > 1) {
      let current = 0;
      let interval = setInterval(next, 5000);
      function goTo(i) {
        if (i === current) return;
        slides[current].classList.remove('opacity-100');
        slides[current].classList.add('opacity-0');
        dots[current].classList.remove('bg-white', 'scale-125');
        dots[current].classList.add('bg-transparent');
        current = i;
        slides[current].classList.remove('opacity-0');
        slides[current].classList.add('opacity-100');
        dots[current].classList.remove('bg-transparent');
        dots[current].classList.add('bg-white', 'scale-125');
      }
      function next() {
        goTo((current + 1) % slides.length);
      }
      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          clearInterval(interval);
          goTo(parseInt(this.getAttribute('data-carousel-dot')));
          interval = setInterval(next, 5000);
        });
      });
    }

    // FAQ filter
    var faqTabs = document.querySelector('[data-faq-tabs]');
    var faqList = document.querySelector('[data-faq-list]');
    if (faqTabs && faqList) {
      var faqAllItems = faqList.querySelectorAll('[data-faq-item]');
      function filterFaq(cat) {
        faqTabs.querySelectorAll('[data-faq-tab]').forEach(function (btn) {
          var isActive = btn.getAttribute('data-faq-tab') === cat;
          if (isActive) { btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900'); btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-300'); }
          else { btn.classList.remove('bg-gray-900', 'text-white', 'border-gray-900'); btn.classList.add('bg-white', 'text-gray-600', 'border-gray-300'); }
        });
        faqAllItems.forEach(function (item) {
          item.style.display = item.getAttribute('data-category') === cat ? '' : 'none';
        });
      }
      faqTabs.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-faq-tab]');
        if (btn) filterFaq(btn.getAttribute('data-faq-tab'));
      });
      filterFaq('sun-protection');
    }

    // AI Ask
    const btn = document.getElementById('ask-btn');
    const input = document.getElementById('q');
    const out = document.getElementById('out');
    if (!btn || !input || !out) return;

    btn.addEventListener('click', async function () {
      const q = input.value.trim();
      if (!q) return;
      out.classList.add('hidden');
      out.textContent = 'Thinking...';
      out.classList.remove('hidden');

      try {
        const res = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question: q }),
        });
        const data = await res.json();
        out.textContent = res.ok && data.answer ? data.answer : 'Error: ' + (data.error || 'Request failed');
      } catch (err) {
        out.textContent = 'Error: ' + err.message;
      }
    });
  })();
</script>
