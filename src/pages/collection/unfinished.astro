---
import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import { SITE } from 'astrowind:config';
import { getProducts, isProductsEnabled, isProductsListEnabled } from '~/utils/products';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

const products = await getProducts();
const hidden = !isProductsEnabled() || !isProductsListEnabled();
const metadata = merge({
  title: `Greige Fabrics — Unfinished & Raw Textiles | ${SITE.name}`,
  description: `${SITE.name} greige (unfinished) fabrics — raw woven and knitted textiles in their natural state, ready for finishing, dyeing, and coating. Ideal for converters, finishers, and vertical mills.`,
  canonical: getCanonical(getPermalink('/collection/unfinished')),
  robots: { index: !hidden, follow: true },
  openGraph: { type: 'website' },
}, {}) as MetaData;
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mb-12 text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-2">Collection</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">Greige Fabrics</h1>
      <p class="mt-3 md:mt-4 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium">
        Raw, unfinished textiles in their greige state — the starting point for custom finishing, dyeing, and coating processes.
      </p>
    </header>

    <section class="max-w-4xl mx-auto mb-12">
      <div class="prose prose-gray dark:prose-invert max-w-none">
        <p class="text-lg text-gray-600 dark:text-slate-400">
          Greige (also spelled greige or grey) fabric is textile in its unfinished state — straight from the loom or knitting machine, without any dyeing, bleaching, or finishing treatments. For converters, finishers, and vertical mills, greige fabric is the blank canvas for creating custom textiles. We supply greige fabrics in polyester, nylon, cotton, and blends, in standard and custom constructions.
        </p>
      </div>
    </section>

    <section class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
        <h3 class="font-semibold text-gray-900 dark:text-slate-200">Woven Greige</h3>
        <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">Plain, twill, satin, and dobby weaves in polyester, nylon, cotton, and blends. Widths from 44" to 126". Available for custom finishing including dyeing, coating, and lamination.</p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
        <h3 class="font-semibold text-gray-900 dark:text-slate-200">Knitted Greige</h3>
        <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">Single jersey, interlock, rib, and fleece constructions. Circular knit greige fabrics ready for dyeing, brushing, and finishing. Compacted or open-width options.</p>
      </div>
      <div class="p-6 rounded-xl bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-slate-700">
        <h3 class="font-semibold text-gray-900 dark:text-slate-200">Custom Development</h3>
        <p class="mt-2 text-sm text-gray-500 dark:text-slate-400">Develop custom greige constructions for specific end uses. We engineer the yarn, weave/knit structure, and density to meet your target finished fabric specifications.</p>
      </div>
    </section>

    {
      products.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {products.map((p) => <ProductCard product={p} />)}
        </div>
      ) : (
        <div class="text-center py-16 text-muted dark:text-slate-400">
          <p class="text-lg">Browse our product catalog or contact us for greige fabric specifications.</p>
          <a class="text-primary dark:text-blue-400 hover:underline mt-2 inline-block" href="/products">View all products</a>
        </div>
      )
    }
  </section>
</Layout>
