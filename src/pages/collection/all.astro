---
import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getProducts, getProductCategories, isProductsEnabled, isProductsListEnabled, CATEGORY_SLUG_TO_URL } from '~/utils/products';
import { PRODUCT_LIST, getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

const products = await getProducts();
const categories = await getProductCategories();
const totalCount = products.length;
const hidden = !isProductsEnabled() || !isProductsListEnabled();

const metadata = merge({
  title: `All Functional Fabrics — Complete Product Catalog | ${SITE.name}`,
  description: `Browse the complete ${SITE.name} product catalog — UPF 50+ sun protection, waterproof, quick-dry, antibacterial, stretch, breathable, and eco-friendly performance fabrics. OEM/ODM available.`,
  canonical: getCanonical(getPermalink(PRODUCT_LIST)),
  robots: { index: !hidden, follow: true },
  openGraph: { type: 'website' },
}, {}) as MetaData;
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mb-12 text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-2">Catalog</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">All Fabrics</h1>
      <p class="mt-3 md:mt-4 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium">
        The complete {SITE.name} fabric catalog — {totalCount} products across all categories.
      </p>
    </header>

    {
      categories.length > 0 && (
        <WidgetWrapper containerClass="mb-10">
          <div class="flex flex-wrap items-center justify-center gap-2">
            <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium bg-primary text-white border-primary dark:bg-blue-500 dark:border-blue-500">
              <Icon name="tabler:layout-grid" class="w-4 h-4" />
              All ({totalCount})
            </span>
            {categories.map((c) => (
              <a href={`/${CATEGORY_SLUG_TO_URL[c.slug]}`}
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-default dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                {c.title} ({c.count})
              </a>
            ))}
          </div>
        </WidgetWrapper>
      )
    }

    {
      products.length === 0 ? (
        <div class="text-center py-16 text-muted dark:text-slate-400">
          <Icon name="tabler:package-off" class="w-12 h-12 mx-auto mb-4" />
          <p class="text-lg">No products available yet.</p>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {products.map((p) => <ProductCard product={p} />)}
        </div>
      )
    }
  </section>
</Layout>
