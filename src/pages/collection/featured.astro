---
import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getProducts, isProductsEnabled, isProductsListEnabled } from '~/utils/products';
import { getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

const products = await getProducts({ featured: true });
const hidden = !isProductsEnabled() || !isProductsListEnabled();

const metadata = merge({
  title: `Featured Fabrics — Spotlight Performance Textiles | ${SITE.name}`,
  description: `Discover ${SITE.name} featured performance fabrics — our spotlight collection of innovative textiles including UPF 50+ sun protection, waterproof breathable membranes, and eco-friendly recycled fabrics.`,
  canonical: getCanonical(getPermalink('/collection/featured')),
  robots: { index: !hidden, follow: true },
  openGraph: { type: 'website' },
}, {}) as MetaData;
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mb-12 text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-2">Collection</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">Featured Fabrics</h1>
      <p class="mt-3 md:mt-4 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium">
        Our spotlight collection — the most innovative and in-demand performance textiles.
      </p>
    </header>

    <section class="max-w-4xl mx-auto mb-12">
      <div class="prose prose-gray dark:prose-invert max-w-none text-center">
        <p class="text-lg text-gray-600 dark:text-slate-400">
          Each featured fabric represents the forefront of textile engineering — from permanent UV-blocking technologies to high-performance waterproof breathable membranes. These are the fabrics our customers choose most for demanding applications.
        </p>
      </div>
    </section>

    {
      products.length === 0 ? (
        <div class="text-center py-16 text-muted dark:text-slate-400">
          <Icon name="tabler:star-off" class="w-12 h-12 mx-auto mb-4" />
          <p class="text-lg">No featured products at this time.</p>
          <a class="text-primary dark:text-blue-400 hover:underline mt-2 inline-block" href="/products">View all products</a>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {products.map((p) => <ProductCard product={p} />)}
        </div>
      )
    }
  </section>
</Layout>
