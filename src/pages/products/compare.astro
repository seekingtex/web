---
import Layout from '~/layouts/PageLayout.astro';
import { SITE } from 'astrowind:config';
import { getProducts } from '~/utils/products';

const metadata = {
  title: `Product Comparison —${SITE.name}`,
  description:
    'Compare Seekingtex functional fabrics side by side. UPF rating, waterproof rating, weight, composition, width, and performance specifications.',
};

const products = await getProducts();

const comparisonRows = [
  { label: 'Category', key: 'categoryLabel' as const, transform: (v: string) => v },
  {
    label: 'UPF Rating',
    key: 'upf' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('upf') || s.label.toLowerCase().includes('uv'));
      return s?.value || '-';
    },
  },
  {
    label: 'Waterproof Rating',
    key: 'waterproof' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('waterproof') || s.label.toLowerCase().includes('hydrostatic') || s.label.toLowerCase().includes('water column'));
      return s?.value || '-';
    },
  },
  {
    label: 'Fabric Weight',
    key: 'fabricWeight' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('weight') || s.label.toLowerCase().includes('gsm'));
      return s?.value || '-';
    },
  },
  {
    label: 'Composition',
    key: 'composition' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('composition') || s.label.toLowerCase().includes('content') || s.label.toLowerCase().includes('material'));
      return s?.value || '-';
    },
  },
  {
    label: 'Width',
    key: 'width' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('width'));
      return s?.value || '-';
    },
  },
  {
    label: 'Breathability',
    key: 'breathability' as const,
    getter: (p: (typeof products)[number]) => {
      const s = p.specs?.find((s) => s.label.toLowerCase().includes('breathability') || s.label.toLowerCase().includes('mvtr'));
      return s?.value || '-';
    },
  },
  {
    label: 'Price',
    key: 'price' as const,
    getter: (p: (typeof products)[number]) => {
      return p.price?.amount ? `$${p.price.amount}` : 'Contact';
    },
  },
];
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto py-24 px-6">
    <a href="/products" class="text-sm text-sky-600 hover:text-sky-700">&larr; Products</a>
    <h1 class="mt-4 text-4xl font-semibold text-gray-900">Product Comparison</h1>
    <p class="mt-4 text-lg text-gray-500">
      Compare all Seekingtex functional fabrics side by side. Find the right performance textile for your application.
    </p>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr>
            <th
              class="sticky left-0 bg-white z-10 px-4 py-3 text-left font-semibold text-gray-900 border-b-2 border-gray-200 min-w-[140px]"
              >Specification</th
            >
            {
              products.map((p) => (
                <th class="px-4 py-3 text-center font-semibold text-gray-900 border-b-2 border-gray-200 min-w-[120px]">
                  <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">{p.categoryLabel}</div>
                  <a href={`/products/${p.slug}`} class="hover:text-sky-600">
                    {p.title}
                  </a>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            comparisonRows.map((row, i) => (
              <tr class={i % 2 === 0 ? 'bg-gray-50' : 'bg-white'}>
                <td
                  class="sticky left-0 px-4 py-3 font-medium text-gray-700 border-b border-gray-200"
                  style={i % 2 === 0 ? 'background:#f9fafb' : 'background:white'}
                >
                  {row.label}
                </td>
                {products.map((p) => {
                  const value = row.getter ? row.getter(p) : (p as any)[row.key];
                  return <td class="px-4 py-3 text-center text-gray-600 border-b border-gray-200">{value || '-'}</td>;
                })}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        products.map((p) => (
          <a
            href={`/products/${p.slug}`}
            class="block p-4 bg-white border border-gray-200 rounded-xl hover:shadow-md transition-shadow text-center"
          >
            <div class="text-xs uppercase tracking-wider text-sky-600 font-medium">{p.categoryLabel}</div>
            <div class="mt-1 font-semibold text-gray-900">{p.title}</div>
            {p.price?.amount && <div class="mt-1 text-sm text-gray-500">${p.price.amount}</div>}
            <div class="mt-2 text-xs text-sky-600 hover:underline">View details →</div>
          </a>
        ))
      }
    </div>

    <section class="sr-only" data-ai-block="definition" aria-hidden="true">
      <p>
        Seekingtex product comparison table covering {products.length} products across {
          ['sun-protection', 'waterproof', 'quick-dry', 'antibacterial', 'stretch', 'breathable', 'eco-friendly'].filter((c) => products.some((p) => p.category === c)).length
        } categories. Compare UPF rating, waterproof rating, fabric weight, composition, width, breathability, and price.
      </p>
    </section>
  </section>
</Layout>
