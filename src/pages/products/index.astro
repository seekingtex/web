---
import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';
import QuickViewModal from '~/components/widgets/QuickViewModal.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';

import { SITE } from 'astrowind:config';
import {
  getProducts,
  getProductCategories,
  isProductsEnabled,
  isProductsListEnabled,
  CATEGORY_SLUG_TO_URL,
} from '~/utils/products';
import { PRODUCT_LIST, getCanonical, getPermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

const products = await getProducts();
const categories = await getProductCategories();
const rawCategory = (Astro.url?.searchParams?.get('category') ?? '') as
  'sun-protection' | 'waterproof' | 'quick-dry' | 'antibacterial' | 'stretch' | 'breathable' | 'eco-friendly' | '';
const activeCategory =
  rawCategory === 'sun-protection' ||
  rawCategory === 'waterproof' ||
  rawCategory === 'quick-dry' ||
  rawCategory === 'antibacterial' ||
  rawCategory === 'stretch' ||
  rawCategory === 'breathable' ||
  rawCategory === 'eco-friendly'
    ? rawCategory
    : null;
const filteredProducts = activeCategory ? products.filter((p) => p.category === activeCategory) : products;
const totalCount = products.length;
const hidden = !isProductsEnabled() || !isProductsListEnabled();

const metadata = merge(
  {
    title: `Functional Fabric Products — OEM Manufacturer | ${SITE.name}`,
    description: `Browse the full ${SITE.name} product catalog — UPF 50+ sun protection, waterproof, quick-dry, antibacterial, stretch, breathable, and eco-friendly performance fabrics. OEM/ODM available for bulk orders. Factory-direct pricing.`,
    canonical: getCanonical(getPermalink(PRODUCT_LIST)),
    robots: { index: !hidden, follow: true },
    openGraph: { type: 'website' },
  },
  {}
) as MetaData;
---

<Layout metadata={metadata}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mb-12 text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary dark:text-blue-400 mb-2">Catalog</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">Seekingtex products</h1>
      <p class="mt-3 md:mt-4 mx-auto text-xl text-gray-500 dark:text-slate-400 font-medium">
        Premium functional fabrics for sportswear, outdoor apparel, tactical gear, and fashion — engineered for
        performance.
      </p>
    </header>

    {
      categories.length > 0 && (
        <WidgetWrapper containerClass="mb-10">
          <div class="flex flex-wrap items-center justify-center gap-2">
            <a
              href={getPermalink(PRODUCT_LIST)}
              class:list={[
                'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors',
                !activeCategory
                  ? 'bg-primary text-white border-primary dark:bg-blue-500 dark:border-blue-500'
                  : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 text-default dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-700',
              ]}
            >
              <Icon name="tabler:layout-grid" class="w-4 h-4" />
              All ({totalCount})
            </a>
            {categories.map((c) => (
              <a
                href={`/${CATEGORY_SLUG_TO_URL[c.slug]}`}
                class:list={[
                  'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors',
                  activeCategory === c.slug
                    ? 'bg-primary text-white border-primary dark:bg-blue-500 dark:border-blue-500'
                    : 'bg-white dark:bg-slate-800 border-gray-200 dark:border-slate-700 text-default dark:text-slate-200 hover:bg-gray-50 dark:hover:bg-slate-700',
                ]}
              >
                {c.title} ({c.count})
              </a>
            ))}
          </div>
        </WidgetWrapper>
      )
    }

    {
      filteredProducts.length === 0 ? (
        <div class="text-center py-16 text-muted dark:text-slate-400">
          <Icon name="tabler:package-off" class="w-12 h-12 mx-auto mb-4" />
          <p class="text-lg">No products in this category yet.</p>
          <a
            class="text-primary dark:text-blue-400 hover:underline mt-2 inline-block"
            href={getPermalink(PRODUCT_LIST)}
          >
            View all products
          </a>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {filteredProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      )
    }
  </section>

  {filteredProducts.map((p) => <QuickViewModal productId={p.slug} />)}

  <section class="sr-only" data-ai-block="definition" aria-hidden="true">
    <p>
      Seekingtex product catalog: functional performance fabrics — UPF 50+ sun protection fabrics (woven and knitted
      options for outdoor apparel and uniforms), waterproof breathable fabrics (laminated and coated membranes for
      outerwear and medical gear), quick-dry moisture wicking fabrics (hydrophilic and capillary-action finishes for
      activewear), 7A antibacterial fabrics (silver-ion and zinc-based antimicrobial treatments for healthcare and
      hygiene), 4-way stretch fabrics (elastane-blended knits for fitness and yoga wear), breathable mesh fabrics
      (engineered ventilation panels for sportswear and workwear), and eco-friendly recycled fabrics (GRS-certified
      post-consumer PET and pre-consumer waste). All fabrics OEKO-TEX Standard 100 certified, third-party tested by SGS
      and Intertek. OEM/ODM custom development available. MOQ 500-1000 m woven, 200-500 kg knits.
    </p>
  </section>
</Layout>
