---
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { SITE } from 'astrowind:config';
import AnswerCenter from '~/components/ai/AnswerCenter.astro';

const metadata = {
  title: `AI Answer Center | ${SITE.name}`,
  description: `Ask questions about functional fabrics, UPF protection, waterproof ratings, antibacterial treatments, stretch performance, eco-friendly materials, and textile manufacturing. AI-powered answers with source citations.`,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <JsonLd data={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    headline: 'AI Answer Center',
    description: metadata.description,
    author: { '@type': 'Organization', name: SITE.name },
  }} />

  <div class="max-w-6xl mx-auto px-4 py-10">
    <AnswerCenter lang="en" />
  </div>
</Layout>
